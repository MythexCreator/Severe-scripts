    updateDiedTp(dt)
    updateNoclip()
    updateInfJump()
    updateAntiVoid()
    updateFov()
    updateThirdPerson()
    updateInstantInteract()
    
    -- ClickTP cache refresh
    if Features.clickTpEnabled then
        local now = os_clock()
        if now - ClickTP.LastCacheTime >= ClickTP.CACHE_REFRESH_INTERVAL then
            ClickTP.LastCacheTime = now
            RefreshClickTPCache()
        end
    end
    
    -- Legacy teleport system (for tp, goto, spawn commands)
    if Teleport.frames > 0 and Teleport.target then
        pcall(function()
            local char = LocalPlayer.Character
            if char then
                local root = char:FindFirstChild("HumanoidRootPart")
                if not root then root = char.PrimaryPart end
                if root and root:IsA("BasePart") then
                    root.CFrame = CFrame.new(Teleport.target)
                    root.Velocity = Vector3.new(0, 0, 0)
                    
                    -- Prevent stun by resetting humanoid state
                    if Teleport.instantMove then
                        local hum = char:FindFirstChildOfClass("Humanoid")
                        if hum then
                            pcall(function()
                                hum:ChangeState(Enum.HumanoidStateType.Running)
                            end)
                        end
                    end
                end
            end
        end)
        Teleport.frames = Teleport.frames - 1
        if Teleport.frames == 0 then 
            Teleport.target = nil 
            Teleport.instantMove = false
        end
    end
    
    Features.specTimer = Features.specTimer + dt
    if Features.specTimer >= 0.5 then
        Features.specTimer = 0
        checkSpec()
    end
    
    if Options.open and Options.tab == "keybinds" and not Options.scrollDragging then
        local diff = Options.targetScroll - Options.scrollOffset
        if math.abs(diff) > 0.01 then
            Options.scrollOffset = Options.scrollOffset + diff * math.min(1, dt * Settings.scrollSpeed)
            Options.scrollOffset = math.clamp(Options.scrollOffset, 0, optionsMaxScroll())
            Options.needsRedraw = true
        end
    end
end

local function handleScroll(delta)
    local mPos = Vector2.new(0, 0)
    pcall(function() mPos = UserInputService:GetMouseLocation() end)
    
    if CommandPanel.open and CommandPanelDrawing.contentBounds then
        if inRect(mPos, CommandPanelDrawing.contentBounds.pos, CommandPanelDrawing.contentBounds.size) then
            local filtered = getFilteredPanelCommands()
            local maxScroll = math.max(0, #filtered - CommandPanelDrawing.maxVisible)
            CommandPanelDrawing.scrollOffset = math.clamp(CommandPanelDrawing.scrollOffset - delta, 0, maxScroll)
            CommandPanelDrawing.needsRedraw = true
            return true
        end
    end
    
    if Options.open and Options.tab == "keybinds" then
        local contentY = Options.posY + Options.HEADER + Options.TAB_H + 25 + Options.SEARCH_H + 10
        local contentH = Options.VISIBLE * (Options.ITEM_H + 4)
        local contentBounds = {pos = Vector2.new(Options.posX, contentY), size = Vector2.new(Options.W, contentH)}
        if inRect(mPos, contentBounds.pos, contentBounds.size) then
            Options.targetScroll = math.clamp(Options.targetScroll - delta, 0, optionsMaxScroll())
            Options.needsRedraw = true
            return true
        end
    end
    
    return false
end

local function updateInput()
    local keys = getpressedkeys()
    local mPos = Vector2.new(0, 0)
    pcall(function() mPos = UserInputService:GetMouseLocation() end)
    
    local mDown = isleftpressed()
    local mClick = mDown and not Input.lastMouse
    local currentTime = os_clock()
    
    -- Track Ctrl key
    Input.ctrlHeld = false
    for _, key in keys do
        if isKey(key, "leftcontrol", "rightcontrol", "control") then
            Input.ctrlHeld = true
            break
        end
    end
    
    -- Scroll
    local scrollDelta = 0
    for _, key in keys do
        if not table.find(Input.lastKeys, key) then
            if isKey(key, "mousewheelforward", "scrollup") then scrollDelta = 1
            elseif isKey(key, "mousewheelbackward", "scrolldown") then scrollDelta = -1 end
        end
    end
    if scrollDelta ~= 0 then handleScroll(scrollDelta) end
    
    -- ClickTP handling with bound key
    if Features.clickTpEnabled and not Bar.open and not CommandPanel.open and not Options.open and not ServerInfo.open then
        local boundKey, mode = getClickTPBoundKey()
        
        if boundKey then
            local keyHeld = false
            for _, key in keys do
                if string.lower(key) == boundKey then
                    keyHeld = true
                    break
                end
            end
            
            if mode == "toggle" then
                -- Toggle mode: just click while key was pressed this frame
                local keyJustPressed = false
                for _, key in keys do
                    if string.lower(key) == boundKey and not table.find(Input.lastKeys, key) then
                        keyJustPressed = true
                        break
                    end
                end
                
                if keyHeld and mClick then
                    performClickTP()
                end
            else
                -- Hold mode: must hold key while clicking
                if keyHeld and mClick then
                    performClickTP()
                end
            end
        end
    end
    
    -- Keybinds execution (except clicktp which is handled above)
    if not Bar.open and not CommandPanel.open and not Options.open and not ServerInfo.open then
        for _, key in keys do
            if not table.find(Input.lastKeys, key) then
                local keyLower = string.lower(key)
                local data = Keybinds.binds[keyLower]
                if data then
                    local cmdName = type(data) == "table" and data.cmd or data
                    if cmdName ~= "clicktp" then
                        executeKeybind(keyLower, true)
                    end
                end
            end
        end
        
        for _, oldKey in Input.lastKeys do
            if not table.find(keys, oldKey) then
                local keyLower = string.lower(oldKey)
                local data = Keybinds.binds[keyLower]
                if data then
                    local cmdName = type(data) == "table" and data.cmd or data
                    if cmdName ~= "clicktp" then
                        executeKeybind(keyLower, false)
                    end
                end
            end
        end
    end
    
    -- Command bar key setting
    if Keybinds.settingCommandBarKey and Options.open then
        for _, key in keys do
            if not table.find(Input.lastKeys, key) then
                local keyLower = string.lower(key)
                if isKey(key, "esc") then
                    Keybinds.settingCommandBarKey = false
                    Options.needsRedraw = true
                elseif not isKey(key, "return", "enter", "mouse", "scroll", "control", "shift", "alt") then
                    Settings.commandBarKey = keyLower
                    notify("Command bar key set to " .. formatKeyName(keyLower))
                    Keybinds.settingCommandBarKey = false
                    Options.needsRedraw = true
                end
            end
        end
    end
    
    -- Keybind setting
    if Keybinds.settingFor and Options.open and not Keybinds.settingCommandBarKey then
        for _, key in keys do
            if not table.find(Input.lastKeys, key) then
                local keyLower = string.lower(key)
                if isKey(key, "esc") then
                    if removeKeybind(Keybinds.settingFor) then
                        notify("Keybind removed for " .. Keybinds.settingFor)
                    end
                    Keybinds.settingFor = nil
                    Options.needsRedraw = true
                elseif not isKey(key, "return", "enter", "mouse", "scroll", "control", "shift", "alt") then
                    setKeybind(keyLower, Keybinds.settingFor)
                    notify("Bound " .. Keybinds.settingFor .. " to " .. formatKeyName(keyLower))
                    Keybinds.settingFor = nil
                    Options.needsRedraw = true
                end
            end
        end
    end
    
    -- Key hold tracking
    local currentKeySet = {}
    for _, k in keys do currentKeySet[k] = true end
    for key in Input.heldKeys do
        if not currentKeySet[key] then Input.heldKeys[key] = nil end
    end
    
    -- Ctrl+V paste
    for _, key in keys do
        if not table.find(Input.lastKeys, key) then
            if Input.ctrlHeld and isKey(key, "v") then
                pasteFromClipboard()
            end
        end
    end
    
    -- Character input
    for _, key in keys do
        local char = getCharFromKey(key)
        local isBackspace = isKey(key, "back")
        if char or isBackspace then
            local shouldType = Bar.open or (Options.searchFocused and Options.tab == "keybinds") or (CommandPanel.open and CommandPanel.searchFocused)
            if Input.heldKeys[key] then
                local holdData = Input.heldKeys[key]
                if currentTime - holdData.startTime >= Input.KEY_INITIAL_DELAY then
                    if currentTime - holdData.lastRepeat >= Input.KEY_REPEAT_RATE then
                        if isBackspace then deleteChar()
                        elseif char and shouldType and not Input.ctrlHeld then addChar(char) end
                        holdData.lastRepeat = currentTime
                    end
                end
            else
                if not table.find(Input.lastKeys, key) then
                    Input.heldKeys[key] = {startTime = currentTime, lastRepeat = currentTime}
                    if isBackspace then deleteChar()
                    elseif char and shouldType and not Input.ctrlHeld then addChar(char) end
                end
            end
        end
    end
    
    -- Command Panel input
    if CommandPanel.open then
        if mClick and CommandPanelDrawing.closeBounds and CommandPanelDrawing.closeBounds.pos then
            if inRect(mPos, CommandPanelDrawing.closeBounds.pos, CommandPanelDrawing.closeBounds.size) then
                hideCommandPanel()
                Input.lastMouse = mDown
                Input.lastKeys = keys
                return
            end
        end
        
        if mClick and CommandPanelDrawing.headerBounds and CommandPanelDrawing.headerBounds.pos then
            if inRect(mPos, CommandPanelDrawing.headerBounds.pos, CommandPanelDrawing.headerBounds.size) then
                -- Check if NOT clicking on search bar
                local clickedSearch = false
                if CommandPanelDrawing.searchBounds and CommandPanelDrawing.searchBounds.pos then
                    if inRect(mPos, CommandPanelDrawing.searchBounds.pos, CommandPanelDrawing.searchBounds.size) then
                        clickedSearch = true
                    end
                end
                if not clickedSearch then
                    CommandPanel.dragging = true
                    CommandPanel.dragOffset = Vector2.new(mPos.X - CommandPanel.posX, mPos.Y - CommandPanel.posY)
                end
            end
        end
        if not mDown then
            CommandPanel.dragging = false
            CommandPanelDrawing.scrollDragging = false
        end
        if CommandPanel.dragging then
            CommandPanel.posX = mPos.X - CommandPanel.dragOffset.X
            CommandPanel.posY = mPos.Y - CommandPanel.dragOffset.Y
            CommandPanelDrawing.needsRedraw = true
        end
        
        -- Scrollbar dragging
        if CommandPanelDrawing.scrollBounds and CommandPanelDrawing.scrollBounds.pos and CommandPanelDrawing.scrollBounds.maxScroll then
            if mClick and inRect(mPos, CommandPanelDrawing.scrollBounds.pos, CommandPanelDrawing.scrollBounds.size) then
                CommandPanelDrawing.scrollDragging = true
                CommandPanelDrawing.scrollDragStartY = mPos.Y
                CommandPanelDrawing.scrollDragStartOff = CommandPanelDrawing.scrollOffset
            end
            if CommandPanelDrawing.scrollDragging then
                local delta = mPos.Y - CommandPanelDrawing.scrollDragStartY
                local scrollbarH = CommandPanelDrawing.scrollBounds.size.Y
                local thumbH = CommandPanelDrawing.scrollBounds.thumbH
                local scrollRange = scrollbarH - thumbH
                if scrollRange > 0 then
                    local scrollDeltaVal = (delta / scrollRange) * CommandPanelDrawing.scrollBounds.maxScroll
                    CommandPanelDrawing.scrollOffset = math.clamp(CommandPanelDrawing.scrollDragStartOff + scrollDeltaVal, 0, CommandPanelDrawing.scrollBounds.maxScroll)
                    CommandPanelDrawing.needsRedraw = true
                end
            end
        end
        
        -- Search bar click - FIXED
        if mClick and not CommandPanel.dragging then
            local clickedSearch = false
            
            if CommandPanelDrawing.searchBounds and CommandPanelDrawing.searchBounds.pos and CommandPanelDrawing.searchBounds.size then
                local sb = CommandPanelDrawing.searchBounds
                if mPos.X >= sb.pos.X and mPos.X <= sb.pos.X + sb.size.X and
                   mPos.Y >= sb.pos.Y and mPos.Y <= sb.pos.Y + sb.size.Y then
                    clickedSearch = true
                    if not CommandPanel.searchFocused then
                        CommandPanel.searchFocused = true
                        CommandPanelDrawing.needsRedraw = true
                    end
                end
            end
            
            if not clickedSearch then
                if CommandPanel.searchFocused then
                    CommandPanel.searchFocused = false
                    CommandPanelDrawing.needsRedraw = true
                end
                
                -- Category clicks
                for _, cat in CommandPanelDrawing.categoryBounds do
                    if inRect(mPos, cat.pos, cat.size) then
                        CommandPanel.selectedCategory = cat.name
                        CommandPanelDrawing.scrollOffset = 0
                        CommandPanelDrawing.needsRedraw = true
                        break
                    end
                end
                
                -- Item clicks
                for _, item in CommandPanelDrawing.itemBounds do
                    if inRect(mPos, item.pos, item.size) then
                        local cmdName = string.match(item.cmd.name, "^(%S+)")
                        if cmdName then runCmd(";" .. cmdName) end
                        break
                    end
                end
            end
        end
    end
    
    -- Options input
    if Options.open then
        if mClick and inRect(mPos, Options.closeBounds.pos, Options.closeBounds.size) then
            toggleOptions()
            Input.lastMouse = mDown
            Input.lastKeys = keys
            return
        end
        
        if mClick and inRect(mPos, Options.headerBounds.pos, Options.headerBounds.size) then
            Options.dragging = true
            Options.dragOffset = Vector2.new(mPos.X - Options.posX, mPos.Y - Options.posY)
        end
        if not mDown then
            Options.dragging = false
            Options.scrollDragging = false
        end
        if Options.dragging then
            Options.posX = mPos.X - Options.dragOffset.X
            Options.posY = mPos.Y - Options.dragOffset.Y
            Options.needsRedraw = true
        end
        
        -- Search bar click in keybinds tab
        if Options.tab == "keybinds" and mClick and not Options.dragging then
            if Options.searchBounds and Options.searchBounds.pos then
                if inRect(mPos, Options.searchBounds.pos, Options.searchBounds.size) then
                    if not Options.searchFocused then
                        Options.searchFocused = true
                        Options.needsRedraw = true
                    end
                else
                    if Options.searchFocused then
                        Options.searchFocused = false
                        Options.needsRedraw = true
                    end
                end
            end
        end
        
        -- Scrollbar
        if Options.tab == "keybinds" and Options.scrollBounds and Options.scrollBounds.pos then
            if mClick and inRect(mPos, Options.scrollBounds.pos, Options.scrollBounds.size) then
                Options.scrollDragging = true
                Options.scrollDragStartY = mPos.Y
                Options.scrollDragStartOff = Options.scrollOffset
            end
        end
        if Options.scrollDragging and Options.scrollBounds and Options.scrollBounds.maxScroll then
            local delta = mPos.Y - Options.scrollDragStartY
            local scrollbarH = Options.scrollBounds.size.Y
            local thumbH = Options.scrollBounds.thumbH
            local scrollRange = scrollbarH - thumbH
            if scrollRange > 0 then
                local scrollDeltaVal = (delta / scrollRange) * Options.scrollBounds.maxScroll
                Options.scrollOffset = math.clamp(Options.scrollDragStartOff + scrollDeltaVal, 0, Options.scrollBounds.maxScroll)
                Options.targetScroll = Options.scrollOffset
                Options.needsRedraw = true
            end
        end
        
        -- Tab clicks
        if mClick and not Options.dragging then
            for tabId, bounds in Options.tabBounds do
                if inRect(mPos, bounds.pos, bounds.size) then
                    if tabId == "theme_accent" then Options.themeTab = "accent" Options.needsRedraw = true
                    elseif tabId == "theme_fill" then Options.themeTab = "fill" Options.needsRedraw = true
                    elseif tabId == "keybinds" or tabId == "theme" or tabId == "general" then
                        Options.tab = tabId
                        Options.scrollOffset = 0
                        Options.targetScroll = 0
                        Options.searchQuery = ""
                        Options.searchFocused = false
                        Options.filteredCache = {}
                        Options.lastSearchQuery = ""
                        Options.needsRedraw = true
                    end
                    break
                end
            end
        end
        
        -- Keybind items
        if Options.tab == "keybinds" and mClick and not Options.dragging then
            for _, item in Options.keybindItems do
                if inRect(mPos, item.keyBounds.pos, item.keyBounds.size) then
                    if Keybinds.settingFor == item.cmd.name then 
                        Keybinds.settingFor = nil
                    else 
                        Keybinds.settingFor = item.cmd.name 
                    end
                    Options.needsRedraw = true
                    break
                end
                if inRect(mPos, item.modeBounds.pos, item.modeBounds.size) then
                    local currentMode = getModeForCommand(item.cmd.name)
                    local newMode = currentMode == "toggle" and "hold" or "toggle"
                    setModeForCommand(item.cmd.name, newMode)
                    notify(item.cmd.name .. " mode: " .. string.upper(newMode))
                    Options.needsRedraw = true
                    break
                end
            end
        end
        
        -- Theme items
        if Options.tab == "theme" and Options.themeTab == "accent" and mClick and not Options.dragging then
            for _, item in Options.themeItems do
                if inRect(mPos, item.bounds.pos, item.bounds.size) then
                    Theme.Accent = item.preset.accent
                    Theme.AccentLight = item.preset.light
                    Theme.AccentDark = item.preset.dark
                    notify("Accent: " .. item.preset.name)
                    applyThemeChange()
                    break
                end
            end
        end
        
        if Options.tab == "theme" and Options.themeTab == "fill" and mClick and not Options.dragging then
            for _, item in Options.fillItems do
                if inRect(mPos, item.bounds.pos, item.bounds.size) then
                    Theme.Primary = item.preset.primary
                    Theme.Secondary = item.preset.secondary
                    Theme.Tertiary = item.preset.tertiary
                    Theme.Card = item.preset.card
                    Theme.Border = item.preset.border
                    notify("Background: " .. item.preset.name)
                    applyThemeChange()
                    break
                end
            end
        end
        
        -- General items
        if Options.tab == "general" and mClick and not Options.dragging then
            for _, item in Options.generalItems do
                if inRect(mPos, item.bounds.pos, item.bounds.size) then
                    if item.id == "commandBarKey" then
                        Keybinds.settingCommandBarKey = not Keybinds.settingCommandBarKey
                        Options.needsRedraw = true
                    elseif item.id == "hideUsername" then
                        Settings.hideUsername = not Settings.hideUsername
                        notify(Settings.hideUsername and "Username hidden" or "Username visible")
                        Options.needsRedraw = true
                        if CommandPanel.open then CommandPanelDrawing.needsRedraw = true end
                        if ServerInfo.open then ServerInfo.drawn = false end
                    elseif item.id == "watermark" then
                        Settings.watermarkEnabled = not Settings.watermarkEnabled
                        notify(Settings.watermarkEnabled and "Watermark enabled" or "Watermark disabled")
                        Options.needsRedraw = true
                    elseif item.id == "statusBar" then
                        Settings.statusBarEnabled = not Settings.statusBarEnabled
                        notify(Settings.statusBarEnabled and "Status Bar enabled" or "Status Bar disabled")
                        Options.needsRedraw = true
                    elseif string.sub(item.id, 1, 7) == "corner_" then
                        Settings.statusBarCorner = string.sub(item.id, 8)
                        notify("Status Bar: " .. Settings.statusBarCorner)
                        Options.needsRedraw = true
                    elseif string.sub(item.id, 1, 7) == "orient_" then
                        Settings.statusBarOrientation = string.sub(item.id, 8)
                        notify("Layout: " .. Settings.statusBarOrientation)
                        Options.needsRedraw = true
                    end
                    break
                end
            end
        end
    end
    
    -- KeybindsGui input
    if KeybindsGui.open then
        if mClick and KeybindsGui.headerBounds and inRect(mPos, KeybindsGui.headerBounds.pos, KeybindsGui.headerBounds.size) then
            KeybindsGui.dragging = true
            KeybindsGui.dragOffset = Vector2.new(mPos.X - KeybindsGui.posX, mPos.Y - KeybindsGui.posY)
        end
        if not mDown then KeybindsGui.dragging = false end
        if KeybindsGui.dragging then
            KeybindsGui.posX = mPos.X - KeybindsGui.dragOffset.X
            KeybindsGui.posY = mPos.Y - KeybindsGui.dragOffset.Y
            KeybindsGui.needsRedraw = true
        end
        if mClick and not KeybindsGui.dragging then
            for _, item in KeybindsGui.itemBounds do
                if inRect(mPos, item.pos, item.size) then
                    local checkFn = toggleFeatures[item.cmd]
                    if checkFn then
                        if checkFn() then runCmd(";un" .. item.cmd) else runCmd(";" .. item.cmd) end
                    end
                    break
                end
            end
        end
    end
    
    Input.lastMouse = mDown
    
    -- Key handling
    for _, key in keys do
        if not table.find(Input.lastKeys, key) then
            if isKey(key, "esc") then
                if Keybinds.settingFor then 
                    -- Handled above
                elseif Keybinds.settingCommandBarKey then 
                    -- Handled above
                elseif CommandPanel.searchFocused then 
                    CommandPanel.searchFocused = false 
                    CommandPanelDrawing.needsRedraw = true
                elseif CommandPanel.open then 
                    hideCommandPanel()
                elseif Options.searchFocused then 
                    Options.searchFocused = false 
                    Options.needsRedraw = true
                elseif ServerInfo.open then 
                    toggleServerInfo()
                elseif Bar.open then 
                    hideBar() 
                end
            elseif isKey(key, "return", "enter") then
                if Bar.open then runCmd(Bar.input) hideBar()
                elseif Options.searchFocused then Options.searchFocused = false Options.needsRedraw = true
                elseif CommandPanel.searchFocused then CommandPanel.searchFocused = false CommandPanelDrawing.needsRedraw = true end
            elseif isKey(key, "tab") and Bar.open then
                applyAC()
            elseif isKey(key, "up") then
                if Bar.open then
                    if Bar.showingPlayerSuggestions and #Bar.playerSuggestions > 0 then
                        Bar.playerSuggestionSelected = Bar.playerSuggestionSelected - 1
                        if Bar.playerSuggestionSelected < 1 then Bar.playerSuggestionSelected = #Bar.playerSuggestions end
                        Bar.needsRedraw = true
                    elseif #Bar.acResults > 0 then
                        Bar.acSelected = Bar.acSelected - 1
                        if Bar.acSelected < 1 then Bar.acSelected = #Bar.acResults end
                        Bar.needsRedraw = true
                    end
                elseif CommandPanel.open then
                    CommandPanelDrawing.scrollOffset = math.max(0, CommandPanelDrawing.scrollOffset - 1)
                    CommandPanelDrawing.needsRedraw = true
                elseif Options.open and Options.tab == "keybinds" then
                    Options.targetScroll = math.max(0, Options.targetScroll - 1)
                end
            elseif isKey(key, "down") then
                if Bar.open then
                    if Bar.showingPlayerSuggestions and #Bar.playerSuggestions > 0 then
                        Bar.playerSuggestionSelected = Bar.playerSuggestionSelected + 1
                        if Bar.playerSuggestionSelected > #Bar.playerSuggestions then Bar.playerSuggestionSelected = 1 end
                        Bar.needsRedraw = true
                    elseif #Bar.acResults > 0 then
                        Bar.acSelected = Bar.acSelected + 1
                        if Bar.acSelected > #Bar.acResults then Bar.acSelected = 1 end
                        Bar.needsRedraw = true
                    end
                elseif CommandPanel.open then
                    local filtered = getFilteredPanelCommands()
                    local maxScroll = math.max(0, #filtered - CommandPanelDrawing.maxVisible)
                    CommandPanelDrawing.scrollOffset = math.min(maxScroll, CommandPanelDrawing.scrollOffset + 1)
                    CommandPanelDrawing.needsRedraw = true
                elseif Options.open and Options.tab == "keybinds" then
                    Options.targetScroll = math.min(optionsMaxScroll(), Options.targetScroll + 1)
                end
            elseif not Bar.open and not CommandPanel.open and not ServerInfo.open and not Options.open then
                local keyLower = string.lower(key)
                local cmdKey = Settings.commandBarKey
                local shouldOpen = false
                if (cmdKey == "semicolon" or cmdKey == "oem_1") and isKey(key, "semicolon", "oem_1") then shouldOpen = true
                elseif keyLower == cmdKey then shouldOpen = true end
                if shouldOpen then
                    Bar.open = true
                    Bar.input = ";"
                    Bar.acSelected = 0
                    Bar.playerSuggestionSelected = 0
                    Bar.playerSuggestions = {}
                    Bar.showingPlayerSuggestions = false
                    Input.heldKeys = {}
                    Bar.needsRedraw = true
                end
            end
        end
    end
    
    Input.lastKeys = keys
end

local function updateRender()
    updateIntro()
    
    if Bar.open then
        Bar.needsRedraw = true
        createBar()
    end
    if Options.open and Options.needsRedraw then createOptions() end
    if CommandPanel.open and CommandPanelDrawing.needsRedraw then createCommandPanelDrawing() end
    if KeybindsGui.open and KeybindsGui.needsRedraw then createKeybindsGui() end
    if ServerInfo.open then createServerInfo() end
    
    updateStatusBar()
end

