local function createCommandPanelDrawing()
    clearCommandPanelDrawing()
    
    local cam = workspace.CurrentCamera
    if not cam then return end
    
    local vw, vh = cam.ViewportSize.X, cam.ViewportSize.Y
    local W, H = CommandPanelDrawing.W, CommandPanelDrawing.H
    
    if CommandPanel.posX == nil then
        CommandPanel.posX = math_floor(vw / 2 - W / 2)
        CommandPanel.posY = math_floor(vh / 2 - H / 2)
    end
    
    CommandPanel.posX = math_clamp(CommandPanel.posX, 0, vw - W)
    CommandPanel.posY = math_clamp(CommandPanel.posY, 0, vh - H)
    
    local px, py = CommandPanel.posX, CommandPanel.posY
