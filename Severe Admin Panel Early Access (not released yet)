local function updateWatermark(dt)
    if not State.settingsLoaded then return end
    
    if not Settings.watermarkEnabled then
        if #Watermark.elements > 0 then
            clearWatermark()
            Watermark.initialized = false
        end
        return
    end
    
    if State.sessionStartTime then
        Watermark.sessionTime = os_clock() - State.sessionStartTime
    end
    
    Watermark.fpsCounter = Watermark.fpsCounter + 1
    Watermark.fpsTimer = Watermark.fpsTimer + dt
    if Watermark.fpsTimer >= 1 then
        Watermark.fps = Watermark.fpsCounter
        Watermark.fpsCounter = 0
        Watermark.fpsTimer = 0
    end
    
    if not Watermark.initialized or #Watermark.elements < 9 then 
        createWatermark() 
        return
    end
    
    pcall(function()
        if #Watermark.elements >= 9 then
            Watermark.elements[8].Text = tostring(Watermark.fps) .. " FPS"
