local function tpToPlayer(name)
    local char = LocalPlayer.Character
    if not char then notify("No character") return end
    local target = findPlayer(name)
    if not target then notify("Player not found: " .. name) return end
    local tChar = target.Character
    if not tChar then notify("Target has no character") return end
    local root = tChar:FindFirstChild("HumanoidRootPart")
    if not root then return end
    Teleport.target = root.Position + Vector3.new(0, 3, 0)
    Teleport.frames = 3
    Teleport.instantMove = true
