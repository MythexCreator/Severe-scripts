local function getFilteredPanelCommands()
    local filtered = {}
    local query = string.lower(CommandPanel.searchQuery)
    for _, cmd in commandsForPanel do
        local matchesCategory = (CommandPanel.selectedCategory == "ALL" or cmd.cat == CommandPanel.selectedCategory)
        local matchesSearch = true
        
        if query ~= "" then
            local nameMatch = string.find(string.lower(cmd.name), query, 1, true)
            local descMatch = string.find(string.lower(cmd.desc), query, 1, true)
            local catMatch = string.find(string.lower(cmd.cat), query, 1, true)
            matchesSearch = nameMatch or descMatch or catMatch
        end
        
        if matchesCategory and matchesSearch then
            table.insert(filtered, cmd)
        end
    end
    return filtered
end

local function getDisplayUsername()
    if Settings.hideUsername then
        return "Anonymous"
    end
    return LocalPlayer.Name
end

