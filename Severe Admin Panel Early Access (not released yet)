local function createBar()
    clearBar()
    
    local cam = workspace.CurrentCamera
    if not cam then return end
    
    local vw, vh = cam.ViewportSize.X, cam.ViewportSize.Y
    local cmdName, playerArg = parseCommandForPlayerArg(Bar.input)
    
    if cmdName and playerArg ~= nil then
        Bar.playerSuggestions = getPlayerSuggestions(playerArg)
        Bar.showingPlayerSuggestions = #Bar.playerSuggestions > 0
        Bar.acResults = {}
    else
        Bar.playerSuggestions = {}
        Bar.showingPlayerSuggestions = false
        local c = string.lower(string.gsub(Bar.input, "^;", ""))
        Bar.acResults = {}
        if c ~= "" and not string.find(c, " ") then
            for _, cmd in commands do
                if string.find(string.lower(cmd.name), c, 1, true) == 1 then
                    table.insert(Bar.acResults, cmd)
                    if #Bar.acResults >= 5 then break end
                end
            end
        end
    end
    
    local dropdownCount = Bar.showingPlayerSuggestions and #Bar.playerSuggestions or #Bar.acResults
    local acH = dropdownCount * 36
