-- CLICKTP (NAPRAWIONY KIERUNEK)
-- ============================================
local function RefreshClickTPCache()
    ClickTP.CachedParts = {}
    pcall(function()
        for _, obj in workspace:GetDescendants() do
            if obj:IsA("BasePart") and obj.CanCollide and obj.Transparency < 1 then
                table_insert(ClickTP.CachedParts, obj)
            end
        end
    end)
    ClickTP.LastCacheTime = os_clock()
end

local function PerformClickTPRaycast()
    local cam = workspace.CurrentCamera
    if not cam then return nil end
    
    local char = LocalPlayer.Character
    if not char then return nil end
    
    local mousePos = Vector2.new(0, 0)
    pcall(function() mousePos = UserInputService:GetMouseLocation() end)
    
    local viewportSize = cam.ViewportSize
    local camCFrame = cam.CFrame
    local camPos = camCFrame.Position
    local fov = cam.FieldOfView
    
    local normalizedX = (mousePos.X / viewportSize.X) * 2 - 1
    local normalizedY = -((mousePos.Y / viewportSize.Y) * 2 - 1)
    
    local aspectRatio = viewportSize.X / viewportSize.Y
    local tanHalfFov = math.tan(math_rad(fov / 2))
    
    local localDirX = normalizedX * tanHalfFov * aspectRatio
    local localDirY = normalizedY * tanHalfFov
    local localDirZ = 1
    
    local length = math.sqrt(localDirX * localDirX + localDirY * localDirY + localDirZ * localDirZ)
    localDirX = localDirX / length
    localDirY = localDirY / length
    localDirZ = localDirZ / length
    
    local rightVec = camCFrame.RightVector
    local upVec = camCFrame.UpVector
    local lookVec = camCFrame.LookVector
    
    local worldDir = Vector3.new(
        rightVec.X * localDirX + upVec.X * localDirY + lookVec.X * localDirZ,
        rightVec.Y * localDirX + upVec.Y * localDirY + lookVec.Y * localDirZ,
        rightVec.Z * localDirX + upVec.Z * localDirY + lookVec.Z * localDirZ
    )
    
    local closestHit = nil
    local closestDist = 1000
    
    if #ClickTP.CachedParts == 0 then
        RefreshClickTPCache()
    end
    
    for _, part in ClickTP.CachedParts do
        if part and part.Parent and part:IsDescendantOf(workspace) then
            local success, result = pcall(function()
                if char and part:IsDescendantOf(char) then return nil end
                
                local partCF = part.CFrame
                local partPos = partCF.Position
                local partSize = part.Size
                local halfSize = partSize / 2
                
                local invCF = partCF:Inverse()
                local localOrigin = invCF:PointToObjectSpace(camPos)
                local localDir = invCF:VectorToObjectSpace(worldDir)
                
                local epsilon = 0.0001
                local tMin = 0
                local tMax = closestDist
                
                if math.abs(localDir.X) > epsilon then
                    local t1 = (-halfSize.X - localOrigin.X) / localDir.X
                    local t2 = (halfSize.X - localOrigin.X) / localDir.X
                    if t1 > t2 then t1, t2 = t2, t1 end
                    tMin = math.max(tMin, t1)
                    tMax = math.min(tMax, t2)
                elseif localOrigin.X < -halfSize.X or localOrigin.X > halfSize.X then
                    return nil
                end
                
                if tMin > tMax then return nil end
                
                if math.abs(localDir.Y) > epsilon then
                    local t1 = (-halfSize.Y - localOrigin.Y) / localDir.Y
                    local t2 = (halfSize.Y - localOrigin.Y) / localDir.Y
                    if t1 > t2 then t1, t2 = t2, t1 end
                    tMin = math.max(tMin, t1)
                    tMax = math.min(tMax, t2)
                elseif localOrigin.Y < -halfSize.Y or localOrigin.Y > halfSize.Y then
                    return nil
                end
                
                if tMin > tMax then return nil end
                
                if math.abs(localDir.Z) > epsilon then
                    local t1 = (-halfSize.Z - localOrigin.Z) / localDir.Z
                    local t2 = (halfSize.Z - localOrigin.Z) / localDir.Z
                    if t1 > t2 then t1, t2 = t2, t1 end
                    tMin = math.max(tMin, t1)
                    tMax = math.min(tMax, t2)
                elseif localOrigin.Z < -halfSize.Z or localOrigin.Z > halfSize.Z then
                    return nil
                end
                
                if tMin > tMax or tMax < 0 then return nil end
                
                local hitDist = tMin > 0 and tMin or tMax
                if hitDist > 0 and hitDist < closestDist then
                    local hitPoint = camPos + worldDir * hitDist
                    return {
                        dist = hitDist,
                        pos = Vector3.new(hitPoint.X, partPos.Y + halfSize.Y + 3, hitPoint.Z)
                    }
                end
                
                return nil
            end)
            
            if success and result and result.dist < closestDist then
                closestDist = result.dist
                closestHit = result.pos
            end
        end
    end
    
    if not closestHit then
        local fallbackDist = 50
        local targetPos = camPos + worldDir * fallbackDist
        closestHit = Vector3.new(targetPos.X, targetPos.Y, targetPos.Z)
    end
    
    return closestHit
end
