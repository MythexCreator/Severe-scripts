    Spawnpoint.respawnDetected = false
    KeybindsGui.needsRedraw = true
    notify("Spawnpoint cleared")
end

local function checkSpawnpoint()
    if not Spawnpoint.enabled or not Spawnpoint.position then return end
    
    if Spawnpoint.teleportCooldown > 0 then
        Spawnpoint.teleportCooldown = Spawnpoint.teleportCooldown - 0.016
        return
    end
    
    local char = LocalPlayer.Character
    if not char then 
        Spawnpoint.lastAliveState = false 
        return 
    end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root or not root:IsA("BasePart") then 
        Spawnpoint.lastAliveState = false 
        return 
    end
    
    local hum = char:FindFirstChildOfClass("Humanoid")
    local isAlive = hum and hum.Health > 0
    
    local currentCharId = getCharacterId(char)
    
    local isNewCharacter = currentCharId ~= Spawnpoint.lastCharacterId and Spawnpoint.lastCharacterId ~= nil
    local justRespawned = not Spawnpoint.lastAliveState and isAlive
    
    if isNewCharacter or justRespawned then
        Spawnpoint.respawnDetected = true
        Spawnpoint.respawnFrame = 0
        Spawnpoint.hasTeleportedThisRespawn = false
    end
    
    if Spawnpoint.respawnDetected and not Spawnpoint.hasTeleportedThisRespawn then
        Spawnpoint.respawnFrame = Spawnpoint.respawnFrame + 1
        
        if Spawnpoint.respawnFrame == 20 then
            local success = pcall(function()
                root.CFrame = CFrame.new(Spawnpoint.position)
                root.Velocity = Vector3.new(0, 0, 0)
            end)
            
            if success then
                notify("Respawn → Spawnpoint")
                Spawnpoint.hasTeleportedThisRespawn = true
                Spawnpoint.teleportCooldown = 2
                Spawnpoint.respawnDetected = false
            end
        end
        
        if Spawnpoint.respawnFrame > 60 then
            Spawnpoint.respawnDetected = false
            Spawnpoint.hasTeleportedThisRespawn = true
        end
    end
    
    Spawnpoint.lastCharacterId = currentCharId
    Spawnpoint.lastAliveState = isAlive
end

local function initWorldPtr()
    if Gravity.worldPtr and Gravity.worldPtr ~= 0 then return true end
    
    local success, result = pcall(function() 
        return memory.readu64(workspace, Gravity.workspaceToWorldOffset)
    end)
    
    if success and result and result ~= 0 then
        Gravity.worldPtr = result
        return true
    end
    
    Gravity.worldPtr = nil
    return false
end

local function setGravity(value)
    local num = tonumber(value)
    if not num then notify("Invalid gravity value") return end
    
    local attempts = 0
    local maxAttempts = 3
    
    while attempts < maxAttempts do
        if initWorldPtr() then
            local success = pcall(function() 
                memory.writef32(Gravity.worldPtr, Gravity.offset, num) 
            end)
            if success then
                notify("Gravity set to " .. num)
                return
            end
        end
        attempts = attempts + 1
        if attempts < maxAttempts then
            Gravity.worldPtr = nil
            task.wait(0.1)
        end
    end
    
    notify("Failed to set gravity")
end

local function resetGravity()
    if not initWorldPtr() then notify("Failed to get world pointer") return end
    local success = pcall(function() memory.writef32(Gravity.worldPtr, Gravity.offset, Gravity.default) end)
    if success then
        notify("Gravity reset to " .. Gravity.default)
    else
        notify("Failed to reset gravity")
    end
end

