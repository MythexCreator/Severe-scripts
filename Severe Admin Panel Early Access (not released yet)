local function color3ToTable(c)
    if not c then return nil end
    return {r = math_floor(c.R * 255), g = math_floor(c.G * 255), b = math_floor(c.B * 255)}
end

local function tableToColor3(t)
    if not t or t.r == nil then return nil end
    return Color3.fromRGB(t.r, t.g, t.b)
end

local function saveSettings()
    local data = {
        version = "3.5",
        settings = {
            commandBarKey = Settings.commandBarKey,
            scrollSpeed = Settings.scrollSpeed,
            statusBarEnabled = Settings.statusBarEnabled,
            statusBarCorner = Settings.statusBarCorner,
            statusBarOrientation = Settings.statusBarOrientation,
            hideUsername = Settings.hideUsername,
            watermarkEnabled = Settings.watermarkEnabled,
            autoSaveEnabled = Settings.autoSaveEnabled,
        },
        theme = {
            accent = color3ToTable(Theme.Accent),
            accentLight = color3ToTable(Theme.AccentLight),
            accentDark = color3ToTable(Theme.AccentDark),
            primary = color3ToTable(Theme.Primary),
            secondary = color3ToTable(Theme.Secondary),
            tertiary = color3ToTable(Theme.Tertiary),
            card = color3ToTable(Theme.Card),
            border = color3ToTable(Theme.Border),
        },
        positions = {
            watermarkX = Watermark.posX,
            watermarkY = Watermark.posY,
            keybindsGuiX = KeybindsGui.posX,
            keybindsGuiY = KeybindsGui.posY,
            optionsX = Options.posX,
            optionsY = Options.posY,
            commandPanelX = CommandPanel.posX,
            commandPanelY = CommandPanel.posY,
        },
    }
    
    local success, encoded = pcall(function()
        return crypt.json.encode(data)
    end)
    
    if success and encoded then
        pcall(function()
            writefile(SETTINGS_FILE, encoded)
        end)
    end
end

local function loadSettings()
    if State.settingsLoaded then return end
    
    local success, content = pcall(function()
        return readfile(SETTINGS_FILE)
    end)
    
    if not success or not content then 
        State.settingsLoaded = true
        return 
    end
    
    local decodeSuccess, data = pcall(function()
        return crypt.json.decode(content)
    end)
    
    if not decodeSuccess or not data then 
        State.settingsLoaded = true
        return 
    end
    
    if data.settings then
        if data.settings.commandBarKey then Settings.commandBarKey = data.settings.commandBarKey end
        if data.settings.scrollSpeed then Settings.scrollSpeed = data.settings.scrollSpeed end
        if data.settings.statusBarEnabled ~= nil then Settings.statusBarEnabled = data.settings.statusBarEnabled end
        if data.settings.statusBarCorner then Settings.statusBarCorner = data.settings.statusBarCorner end
        if data.settings.statusBarOrientation then Settings.statusBarOrientation = data.settings.statusBarOrientation end
        if data.settings.hideUsername ~= nil then Settings.hideUsername = data.settings.hideUsername end
        if data.settings.watermarkEnabled ~= nil then Settings.watermarkEnabled = data.settings.watermarkEnabled end
        if data.settings.autoSaveEnabled ~= nil then Settings.autoSaveEnabled = data.settings.autoSaveEnabled end
    end
    
    if Settings.autoSaveEnabled and data.theme then
        local t = data.theme
        local loadedColor
        loadedColor = tableToColor3(t.accent)
        if loadedColor then Theme.Accent = loadedColor end
        loadedColor = tableToColor3(t.accentLight)
        if loadedColor then Theme.AccentLight = loadedColor end
        loadedColor = tableToColor3(t.accentDark)
        if loadedColor then Theme.AccentDark = loadedColor end
        loadedColor = tableToColor3(t.primary)
        if loadedColor then Theme.Primary = loadedColor end
        loadedColor = tableToColor3(t.secondary)
        if loadedColor then Theme.Secondary = loadedColor end
        loadedColor = tableToColor3(t.tertiary)
        if loadedColor then Theme.Tertiary = loadedColor end
        loadedColor = tableToColor3(t.card)
        if loadedColor then Theme.Card = loadedColor end
        loadedColor = tableToColor3(t.border)
        if loadedColor then Theme.Border = loadedColor end
    end
    
    if data.positions then
        if data.positions.watermarkX ~= nil then Watermark.posX = data.positions.watermarkX end
        if data.positions.watermarkY ~= nil then Watermark.posY = data.positions.watermarkY end
        if data.positions.keybindsGuiX ~= nil then KeybindsGui.posX = data.positions.keybindsGuiX end
        if data.positions.keybindsGuiY ~= nil then KeybindsGui.posY = data.positions.keybindsGuiY end
        if data.positions.optionsX ~= nil then Options.posX = data.positions.optionsX end
        if data.positions.optionsY ~= nil then Options.posY = data.positions.optionsY end
        if data.positions.commandPanelX ~= nil then CommandPanel.posX = data.positions.commandPanelX end
        if data.positions.commandPanelY ~= nil then CommandPanel.posY = data.positions.commandPanelY end
    end
    
    State.settingsLoaded = true
    Watermark.initialized = false
end

