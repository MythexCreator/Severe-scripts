local function showCommandPanel()
    if CommandPanel.open then return end
    CommandPanel.open = true
    CommandPanel.selectedCategory = "ALL"
    CommandPanel.searchQuery = ""
    CommandPanel.searchFocused = false
    CommandPanelDrawing.scrollOffset = 0
    CommandPanelDrawing.targetScroll = 0
    CommandPanelDrawing.scrollDragging = false
    CommandPanelDrawing.needsRedraw = true
    createCommandPanelDrawing()
end

local function hideCommandPanel()
    if not CommandPanel.open then return end
    CommandPanel.open = false
    CommandPanel.searchFocused = false
    CommandPanelDrawing.scrollDragging = false
    clearCommandPanelDrawing()
    saveSettings()
end

toggleCommandPanel = function()
    if CommandPanel.open then hideCommandPanel() else showCommandPanel() end
end

toggleOptions = function()
    Options.open = not Options.open
    if Options.open then
        Keybinds.settingFor = nil
        Keybinds.settingCommandBarKey = false
        Keybinds.previousKey = nil
        Options.searchQuery = ""
        Options.searchFocused = false
        Options.scrollOffset = 0
        Options.targetScroll = 0
        Options.scrollDragging = false
        Options.themeScroll = 0
        Options.themeTargetScroll = 0
        Options.themeScrollDragging = false
        Options.lastSearchQuery = ""
        Options.filteredCache = {}
        Input.heldKeys = {}
        Options.needsRedraw = true
    else
        clearOptions()
        saveSettings()
    end
end

showKeybindsGui = function()
    if KeybindsGui.open then return end
    KeybindsGui.open = true
    KeybindsGui.needsRedraw = true
    notify("Keybinds panel opened")
end

hideKeybindsGui = function()
    if not KeybindsGui.open then return end
    KeybindsGui.open = false
    clearKeybindsGui()
    notify("Keybinds panel closed")
end

toggleServerInfo = function()
    ServerInfo.open = not ServerInfo.open
    if not ServerInfo.open then clearServerInfo() end
end

