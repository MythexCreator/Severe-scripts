local function handleScroll(delta)
    local mPos = Vector2.new(0, 0)
    pcall(function() mPos = UserInputService:GetMouseLocation() end)
    
    if CommandPanel.open and CommandPanelDrawing.contentBounds then
        if inRect(mPos, CommandPanelDrawing.contentBounds.pos, CommandPanelDrawing.contentBounds.size) then
            local filtered = getFilteredPanelCommands()
            local maxScroll = math.max(0, #filtered - CommandPanelDrawing.maxVisible)
            CommandPanelDrawing.targetScroll = math_clamp(CommandPanelDrawing.targetScroll - delta, 0, maxScroll)
            CommandPanelDrawing.needsRedraw = true
            return true
        end
    end
    
    if Options.open then
        if Options.tab == "keybinds" then
            Options.targetScroll = math_clamp(Options.targetScroll - delta, 0, optionsMaxScroll())
            Options.needsRedraw = true
            return true
        elseif Options.tab == "theme" and Options.themeScrollBounds then
            if inRect(mPos, Options.themeScrollBounds.pos, Options.themeScrollBounds.size) then
                Options.themeTargetScroll = math_clamp(Options.themeTargetScroll - delta * 30, 0, Options.themeScrollBounds.maxScroll)
                Options.needsRedraw = true
                return true
            end
        end
    end
    
    return false
end

local function updateInput()
    local keys = getpressedkeys()
    local mPos = Vector2.new(0, 0)
    pcall(function() mPos = UserInputService:GetMouseLocation() end)
    
    local mDown = isleftpressed()
    local mClick = mDown and not Input.lastMouse
    local mRelease = not mDown and Input.lastMouse
    local currentTime = os_clock()
    
    local currentKeysSet = {}
    for _, k in keys do currentKeysSet[string_lower(k)] = true end
    
    local scrollDelta = 0
    for _, key in keys do
        if not table_find(Input.lastKeys, key) then
            if isKey(key, "mousewheelforward", "scrollup") then scrollDelta = 1
            elseif isKey(key, "mousewheelbackward", "scrolldown") then scrollDelta = -1 end
        end
    end
    if scrollDelta ~= 0 then handleScroll(scrollDelta) end
    
    -- Command Panel scrollbar drag
    if CommandPanel.open and CommandPanelDrawing.scrollBounds then
        local sb = CommandPanelDrawing.scrollBounds
        if mClick and inRect(mPos, sb.pos, sb.size) then
            CommandPanelDrawing.scrollDragging = true
            CommandPanelDrawing.scrollDragStartY = mPos.Y
            CommandPanelDrawing.scrollDragStartOffset = CommandPanelDrawing.scrollOffset
        end
    end
    
    if CommandPanelDrawing.scrollDragging then
        if mDown then
            local sb = CommandPanelDrawing.scrollBounds
            if sb then
                local filtered = getFilteredPanelCommands()
                local maxScroll = math.max(0, #filtered - CommandPanelDrawing.maxVisible)
                local dragDelta = mPos.Y - CommandPanelDrawing.scrollDragStartY
                local scrollPerPixel = maxScroll / math.max(1, (sb.size.Y - sb.thumbH))
                CommandPanelDrawing.targetScroll = math_clamp(
                    CommandPanelDrawing.scrollDragStartOffset + dragDelta * scrollPerPixel,
                    0, maxScroll
                )
                CommandPanelDrawing.needsRedraw = true
            end
        else
            CommandPanelDrawing.scrollDragging = false
        end
    end
    
    -- Options keybinds scrollbar drag
    if Options.open and Options.tab == "keybinds" and Options.scrollBounds then
        local sb = Options.scrollBounds
        if mClick and inRect(mPos, sb.pos, sb.size) then
            Options.scrollDragging = true
            Options.scrollDragStartY = mPos.Y
            Options.scrollDragStartOffset = Options.scrollOffset
        end
    end
    
    if Options.scrollDragging and Options.tab == "keybinds" then
        if mDown then
            local sb = Options.scrollBounds
            if sb then
                local maxScroll = sb.maxScroll
                local dragDelta = mPos.Y - Options.scrollDragStartY
                local scrollPerPixel = maxScroll / math.max(1, (sb.size.Y - sb.thumbH))
                Options.targetScroll = math_clamp(
                    Options.scrollDragStartOffset + dragDelta * scrollPerPixel,
                    0, maxScroll
                )
                Options.needsRedraw = true
            end
        else
            Options.scrollDragging = false
        end
    end
    
    -- Options theme scrollbar drag (NAPRAWIONY)
    if Options.open and Options.tab == "theme" and Options.themeScrollBounds and Options.themeScrollBounds.scrollbarX then
        local sb = Options.themeScrollBounds
        local scrollbarX = sb.scrollbarX
        local scrollbarY = sb.scrollbarY or sb.gridY
        local scrollbarH = sb.scrollbarH or sb.gridH
        
        if mClick and mPos.X >= scrollbarX - 5 and mPos.X <= scrollbarX + 10 and mPos.Y >= scrollbarY and mPos.Y <= scrollbarY + scrollbarH then
            Options.themeScrollDragging = true
            Options.themeScrollDragStartY = mPos.Y
            Options.themeScrollDragStartOffset = Options.themeScroll
        end
    end
    
    if Options.themeScrollDragging then
        if mDown then
            local sb = Options.themeScrollBounds
            if sb and sb.maxScroll > 0 then
                local scrollbarH = sb.scrollbarH or sb.gridH
                local thumbH = sb.thumbH or 30
                local dragDelta = mPos.Y - Options.themeScrollDragStartY
                local scrollPerPixel = sb.maxScroll / math.max(1, (scrollbarH - thumbH))
                Options.themeTargetScroll = math_clamp(
                    Options.themeScrollDragStartOffset + dragDelta * scrollPerPixel,
                    0, sb.maxScroll
                )
                Options.needsRedraw = true
            end
        else
            Options.themeScrollDragging = false
        end
    end
    
    -- Watermark dragging
    if Settings.watermarkEnabled and Watermark.bounds and #Watermark.elements > 0 then
        if mClick and inRect(mPos, Watermark.bounds.pos, Watermark.bounds.size) then
            Watermark.dragging = true
            Watermark.dragOffset = Vector2.new(mPos.X - Watermark.posX, mPos.Y - Watermark.posY)
        end
    end
    
    if Watermark.dragging then
        if mDown then
            local cam = workspace.CurrentCamera
            if cam then
                Watermark.posX = math_clamp(mPos.X - Watermark.dragOffset.X, 0, cam.ViewportSize.X - Watermark.W)
                Watermark.posY = math_clamp(mPos.Y - Watermark.dragOffset.Y, 0, cam.ViewportSize.Y - Watermark.H)
                updateWatermarkPosition()
            end
        else
            Watermark.dragging = false
            saveSettings()
        end
    end
    
    -- ClickTP
    if Features.clickTpEnabled and not Bar.open and not CommandPanel.open and not Options.open and not ServerInfo.open then
        if mClick and not Watermark.dragging and not CommandPanelDrawing.scrollDragging and not Options.scrollDragging and not Options.themeScrollDragging then
            local clickedKeybindsGui = false
            if KeybindsGui.open and KeybindsGui.headerBounds then
                local features = getActiveFeatures()
                local KB_H = KeybindsGui.HEADER + 15 + math.max(#features, 1) * 36 + 15
                local kgBounds = {pos = Vector2.new(KeybindsGui.posX or 0, KeybindsGui.posY or 0), size = Vector2.new(KeybindsGui.W, KB_H)}
                if inRect(mPos, kgBounds.pos, kgBounds.size) then
                    clickedKeybindsGui = true
                end
            end
            
            if not clickedKeybindsGui then
                performClickTP()
            end
        end
    end
    
    -- Keybinds execution
    if not Bar.open and not CommandPanel.open and not Options.open and not ServerInfo.open then
        for _, key in keys do
            if not table_find(Input.lastKeys, key) then
                local keyLower = string_lower(key)
                if Keybinds.binds[keyLower] then
                    executeKeybind(keyLower, true)
                end
            end
        end
        for _, oldKey in Input.lastKeys do
            if not table_find(keys, oldKey) then
                local keyLower = string_lower(oldKey)
                if Keybinds.binds[keyLower] then
                    executeKeybind(keyLower, false)
                end
            end
        end
    end
    
    -- Setting command bar key
    if Keybinds.settingCommandBarKey and Options.open then
        for _, key in keys do
            if not table_find(Input.lastKeys, key) then
                local keyLower = string_lower(key)
                if isKey(key, "esc") then
                    Keybinds.settingCommandBarKey = false
                    Options.needsRedraw = true
                elseif not isKey(key, "return", "enter", "mouse", "scroll", "control", "shift", "alt") then
                    Settings.commandBarKey = keyLower
                    notify("Command bar key set to " .. formatKeyName(keyLower))
                    Keybinds.settingCommandBarKey = false
                    Options.needsRedraw = true
                    saveSettings()
                end
            end
        end
    end
    
    -- Setting keybind
    if Keybinds.settingFor and Options.open and not Keybinds.settingCommandBarKey then
        for _, key in keys do
            if not table_find(Input.lastKeys, key) then
                local keyLower = string_lower(key)
                if isKey(key, "esc") then
                    if removeKeybind(Keybinds.settingFor) then notify("Keybind removed for " .. Keybinds.settingFor) end
                    Keybinds.settingFor = nil
                    Options.needsRedraw = true
                elseif not isKey(key, "return", "enter", "mouse", "scroll", "control", "shift", "alt") then
                    setKeybind(keyLower, Keybinds.settingFor)
                    notify("Bound " .. Keybinds.settingFor .. " to " .. formatKeyName(keyLower))
                    Keybinds.settingFor = nil
                    Options.needsRedraw = true
                end
            end
        end
    end
    
    -- Key repeat
    for key in pairs(Input.heldKeys) do
        if not currentKeysSet[string_lower(key)] then Input.heldKeys[key] = nil end
    end
    
    for _, key in keys do
        local char = getCharFromKey(key)
        local isBackspace = isKey(key, "back")
        if char or isBackspace then
            local shouldType = Bar.open or (Options.searchFocused and Options.tab == "keybinds") or (CommandPanel.open and CommandPanel.searchFocused)
            if Input.heldKeys[key] then
                local holdData = Input.heldKeys[key]
                if currentTime - holdData.startTime >= Input.KEY_INITIAL_DELAY then
                    if currentTime - holdData.lastRepeat >= Input.KEY_REPEAT_RATE then
                        if isBackspace then deleteChar() elseif char and shouldType then addChar(char) end
                        holdData.lastRepeat = currentTime
                    end
                end
            else
                if not table_find(Input.lastKeys, key) then
                    Input.heldKeys[key] = {startTime = currentTime, lastRepeat = currentTime}
                    if isBackspace then deleteChar() elseif char and shouldType then addChar(char) end
                end
            end
        end
    end
    
    -- Command Panel input
    if CommandPanel.open then
        if mClick and CommandPanelDrawing.closeBounds and inRect(mPos, CommandPanelDrawing.closeBounds.pos, CommandPanelDrawing.closeBounds.size) then
            hideCommandPanel()
            Input.lastMouse = mDown
            Input.lastKeys = keys
            return
        end
        if mClick and CommandPanelDrawing.headerBounds and inRect(mPos, CommandPanelDrawing.headerBounds.pos, CommandPanelDrawing.headerBounds.size) then
            if not (CommandPanelDrawing.searchBounds and inRect(mPos, CommandPanelDrawing.searchBounds.pos, CommandPanelDrawing.searchBounds.size)) then
                if not CommandPanelDrawing.scrollDragging then
                    CommandPanel.dragging = true
                    CommandPanel.dragOffset = Vector2.new(mPos.X - CommandPanel.posX, mPos.Y - CommandPanel.posY)
                end
            end
        end
        if mRelease then
            if CommandPanel.dragging then saveSettings() end
            CommandPanel.dragging = false
        end
        if CommandPanel.dragging then
            CommandPanel.posX = mPos.X - CommandPanel.dragOffset.X
            CommandPanel.posY = mPos.Y - CommandPanel.dragOffset.Y
            CommandPanelDrawing.needsRedraw = true
        end
        if mClick and not CommandPanel.dragging and not CommandPanelDrawing.scrollDragging then
            if CommandPanelDrawing.searchBounds and inRect(mPos, CommandPanelDrawing.searchBounds.pos, CommandPanelDrawing.searchBounds.size) then
                CommandPanel.searchFocused = true
                CommandPanelDrawing.needsRedraw = true
            else
                CommandPanel.searchFocused = false
                CommandPanelDrawing.needsRedraw = true
                for _, cat in CommandPanelDrawing.categoryBounds do
                    if inRect(mPos, cat.pos, cat.size) then
                        CommandPanel.selectedCategory = cat.name
                        CommandPanelDrawing.scrollOffset = 0
                        CommandPanelDrawing.targetScroll = 0
                        CommandPanelDrawing.needsRedraw = true
                        break
                    end
                end
                for _, item in CommandPanelDrawing.itemBounds do
                    if inRect(mPos, item.pos, item.size) then
                        local cmdName = string_match(item.cmd.name, "^(%S+)")
                        if cmdName then runCmd(";" .. cmdName) end
                        break
                    end
                end
            end
        end
    end
    
    -- Options input
    if Options.open then
        if mClick and Options.closeBounds and inRect(mPos, Options.closeBounds.pos, Options.closeBounds.size) then
            toggleOptions()
            Input.lastMouse = mDown
            Input.lastKeys = keys
            return
        end
        if mClick and Options.headerBounds and inRect(mPos, Options.headerBounds.pos, Options.headerBounds.size) then
            if not Options.scrollDragging and not Options.themeScrollDragging then
                Options.dragging = true
                Options.dragOffset = Vector2.new(mPos.X - Options.posX, mPos.Y - Options.posY)
            end
        end
        if mRelease then
            if Options.dragging then saveSettings() end
            Options.dragging = false
            Options.scrollDragging = false
            Options.themeScrollDragging = false
        end
        if Options.dragging then
            Options.posX = mPos.X - Options.dragOffset.X
            Options.posY = mPos.Y - Options.dragOffset.Y
            Options.needsRedraw = true
        end
        if mClick and not Options.dragging and not Options.scrollDragging and not Options.themeScrollDragging then
            for tabId, bounds in pairs(Options.tabBounds) do
                if inRect(mPos, bounds.pos, bounds.size) then
                    if tabId == "theme_accent" then Options.themeTab = "accent" Options.themeScroll = 0 Options.themeTargetScroll = 0
                    elseif tabId == "theme_fill" then Options.themeTab = "fill" Options.themeScroll = 0 Options.themeTargetScroll = 0
                    elseif tabId == "keybinds" or tabId == "theme" or tabId == "general" then Options.tab = tabId end
                    Options.needsRedraw = true
                    break
                end
            end
            if Options.tab == "keybinds" then
                if Options.searchBounds and inRect(mPos, Options.searchBounds.pos, Options.searchBounds.size) then
                    Options.searchFocused = true
                    Options.needsRedraw = true
                else
                    Options.searchFocused = false
                end
                for _, item in Options.keybindItems do
                    if inRect(mPos, item.keyBounds.pos, item.keyBounds.size) then
                        Keybinds.settingFor = Keybinds.settingFor == item.cmd.name and nil or item.cmd.name
                        Options.needsRedraw = true
                        break
                    end
                    if inRect(mPos, item.modeBounds.pos, item.modeBounds.size) then
                        local newMode = getModeForCommand(item.cmd.name) == "toggle" and "hold" or "toggle"
                        setModeForCommand(item.cmd.name, newMode)
                        notify(item.cmd.name .. " mode: " .. string.upper(newMode))
                        Options.needsRedraw = true
                        break
                    end
                end
            elseif Options.tab == "theme" then
                if Options.themeTab == "accent" then
                    for _, item in Options.themeItems do
                        if inRect(mPos, item.bounds.pos, item.bounds.size) then
                            Theme.Accent = item.preset.accent
                            Theme.AccentLight = item.preset.light
                            Theme.AccentDark = item.preset.dark
                            notify("Accent: " .. item.preset.name)
                            applyThemeChange()
                            updateWatermarkColors()
                            saveSettings()
                            break
                        end
                    end
                else
                    for _, item in Options.fillItems do
                        if inRect(mPos, item.bounds.pos, item.bounds.size) then
                            Theme.Primary = item.preset.primary
                            Theme.Secondary = item.preset.secondary
                            Theme.Tertiary = item.preset.tertiary
                            Theme.Card = item.preset.card
                            Theme.Border = item.preset.border
                            notify("Background: " .. item.preset.name)
                            applyThemeChange()
                            updateWatermarkColors()
                            saveSettings()
                            break
                        end
                    end
                end
            elseif Options.tab == "general" then
                for _, item in Options.generalItems do
                    if inRect(mPos, item.bounds.pos, item.bounds.size) then
                        if item.id == "commandBarKey" then
                            Keybinds.settingCommandBarKey = not Keybinds.settingCommandBarKey
                        elseif item.id == "hideUsername" then
                            Settings.hideUsername = not Settings.hideUsername
                            notify(Settings.hideUsername and "Username hidden" or "Username visible")
                            saveSettings()
                        elseif item.id == "watermark" then
                            Settings.watermarkEnabled = not Settings.watermarkEnabled
                            notify(Settings.watermarkEnabled and "Watermark enabled" or "Watermark disabled")
                            Watermark.initialized = false
                            saveSettings()
                        elseif item.id == "statusBar" then
                            Settings.statusBarEnabled = not Settings.statusBarEnabled
                            notify(Settings.statusBarEnabled and "Status Bar enabled" or "Status Bar disabled")
                            saveSettings()
                        elseif item.id == "statusBarCorner" then
                            local corners = {"top-left", "top-right", "bottom-left", "bottom-right"}
                            local idx = 1
                            for i, c in corners do if c == Settings.statusBarCorner then idx = i break end end
                            idx = idx % 4 + 1
                            Settings.statusBarCorner = corners[idx]
                            notify("Status Bar Corner: " .. Settings.statusBarCorner)
                            saveSettings()
                        elseif item.id == "statusBarOrientation" then
                            Settings.statusBarOrientation = Settings.statusBarOrientation == "vertical" and "horizontal" or "vertical"
                            notify("Status Bar Layout: " .. Settings.statusBarOrientation)
                            saveSettings()
                        elseif item.id == "autoSave" then
                            Settings.autoSaveEnabled = not Settings.autoSaveEnabled
                            notify(Settings.autoSaveEnabled and "Auto-Save enabled" or "Auto-Save disabled")
                            saveSettings()
                        end
                        Options.needsRedraw = true
                        break
                    end
                end
            end
        end
    end
    
    -- KeybindsGui input
    if KeybindsGui.open then
        if mClick and KeybindsGui.headerBounds and inRect(mPos, KeybindsGui.headerBounds.pos, KeybindsGui.headerBounds.size) then
            KeybindsGui.dragging = true
            KeybindsGui.dragOffset = Vector2.new(mPos.X - (KeybindsGui.posX or 0), mPos.Y - (KeybindsGui.posY or 0))
        end
        if mRelease then
            if KeybindsGui.dragging then saveSettings() end
            KeybindsGui.dragging = false
        end
        if KeybindsGui.dragging then
            KeybindsGui.posX = mPos.X - KeybindsGui.dragOffset.X
            KeybindsGui.posY = mPos.Y - KeybindsGui.dragOffset.Y
            KeybindsGui.needsRedraw = true
        end
    end
    
    Input.lastMouse = mDown
    
    -- Key events
    for _, key in keys do
        if not table_find(Input.lastKeys, key) then
            if isKey(key, "esc") then
                if CommandPanel.searchFocused then CommandPanel.searchFocused = false CommandPanelDrawing.needsRedraw = true
                elseif CommandPanel.open then hideCommandPanel()
                elseif Options.searchFocused then Options.searchFocused = false Options.needsRedraw = true
                elseif ServerInfo.open then toggleServerInfo()
                elseif Bar.open then hideBar() end
            elseif isKey(key, "return", "enter") then
                if Bar.open then runCmd(Bar.input) hideBar()
                elseif Options.searchFocused then Options.searchFocused = false Options.needsRedraw = true
                elseif CommandPanel.searchFocused then CommandPanel.searchFocused = false CommandPanelDrawing.needsRedraw = true end
            elseif isKey(key, "tab") and Bar.open then
                applyAC()
            elseif isKey(key, "up") and Bar.open then
                if Bar.showingPlayerSuggestions and #Bar.playerSuggestions > 0 then
                    Bar.playerSuggestionSelected = Bar.playerSuggestionSelected - 1
                    if Bar.playerSuggestionSelected < 1 then Bar.playerSuggestionSelected = #Bar.playerSuggestions end
                elseif #Bar.acResults > 0 then
                    Bar.acSelected = Bar.acSelected - 1
                    if Bar.acSelected < 1 then Bar.acSelected = #Bar.acResults end
                end
                Bar.needsRedraw = true
            elseif isKey(key, "down") and Bar.open then
                if Bar.showingPlayerSuggestions and #Bar.playerSuggestions > 0 then
                    Bar.playerSuggestionSelected = Bar.playerSuggestionSelected + 1
                    if Bar.playerSuggestionSelected > #Bar.playerSuggestions then Bar.playerSuggestionSelected = 1 end
                elseif #Bar.acResults > 0 then
                    Bar.acSelected = Bar.acSelected + 1
                    if Bar.acSelected > #Bar.acResults then Bar.acSelected = 1 end
                end
                Bar.needsRedraw = true
            elseif not Bar.open and not CommandPanel.open and not ServerInfo.open and not Options.open then
                local keyLower = string_lower(key)
                local cmdKey = Settings.commandBarKey
                local shouldOpen = false
                if (cmdKey == "semicolon" or cmdKey == "oem_1") and isKey(key, "semicolon", "oem_1") then shouldOpen = true
                elseif keyLower == cmdKey then shouldOpen = true end
                if shouldOpen then
                    Bar.open = true
                    Bar.input = ";"
                    Bar.acSelected = 0
                    Bar.playerSuggestionSelected = 0
                    Bar.playerSuggestions = {}
                    Bar.showingPlayerSuggestions = false
                    Input.heldKeys = {}
                    Bar.needsRedraw = true
                end
            end
        end
    end
    
    Input.lastKeys = keys
end

local function updateRender()
    updateIntro()
    if Bar.open then Bar.needsRedraw = true createBar() end
    if Options.open then Options.needsRedraw = true createOptions() end
    if CommandPanel.open then CommandPanelDrawing.needsRedraw = true createCommandPanelDrawing() end
    if KeybindsGui.open and KeybindsGui.needsRedraw then createKeybindsGui() end
    if ServerInfo.open then createServerInfo() end
    updateStatusBar()
end

-- ============================================
-- MAIN LOOP
-- ============================================
local lastTime = os_clock()

RunService.Render:Connect(function()
    local currentTime = os_clock()
    local dt = math.min(currentTime - lastTime, 0.1)
    lastTime = currentTime
    
    updateLogic(dt)
    updateInput()
    updateRender()
    updateWatermark(dt)
end)
