local function updateDiedTp(dt)
    if not DiedTp.enabled then return end
    if DiedTp.cooldown > 0 then DiedTp.cooldown = DiedTp.cooldown - dt return end
    pcall(function()
        local char = LocalPlayer.Character
        if not char then 
            DiedTp.wasDead = true 
            DiedTp.wasAliveLastFrame = false
            return 
        end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root or not root:IsA("BasePart") then 
            DiedTp.wasDead = true 
            DiedTp.wasAliveLastFrame = false
            return 
        end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum then return end
        
        local currentHealth = hum.Health
        local isAliveNow = currentHealth > 0
        
        if isAliveNow then 
            DiedTp.lastPos = root.Position 
        end
        
        if DiedTp.wasAliveLastFrame and not isAliveNow then
            if DiedTp.lastPos then 
                DiedTp.deathPos = DiedTp.lastPos 
            end
            DiedTp.wasDead = true
        end
        
        if DiedTp.wasDead and isAliveNow and DiedTp.deathPos then
            root.CFrame = CFrame.new(DiedTp.deathPos + Vector3.new(0, 3, 0))
            root.Velocity = Vector3.new(0, 0, 0)
            notify("But it refused.")
            DiedTp.wasDead = false
            DiedTp.deathPos = nil
            DiedTp.cooldown = 2
        end
        
        DiedTp.lastHealth = currentHealth
        DiedTp.wasAliveLastFrame = isAliveNow
    end)
end

