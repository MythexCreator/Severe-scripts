local function notify(msg)
    pcall(function() send_notification(tostring(msg)) end)
end

local function inRect(p, pos, size)
    if not pos or not size then return false end
    return p.X >= pos.X and p.X <= pos.X + size.X and p.Y >= pos.Y and p.Y <= pos.Y + size.Y
end

local function catColor(cat)
    if cat == "Movement" or cat == "MOVEMENT" then return Theme.Movement
    elseif cat == "Visual" or cat == "VISUALS" then return Theme.Visual
    elseif cat == "Teleport" or cat == "TELEPORT" then return Theme.Teleport
    elseif cat == "Utility" or cat == "ETC" then return Theme.Utility
    elseif cat == "Fun" or cat == "FUN" then return Theme.Fun
    else return Theme.TextMuted end
end

local function isKey(key, ...)
    local k = string.lower(key)
    for _, v in {...} do 
        if string.find(k, v, 1, true) then return true end 
    end
    return false
end

local function formatKeyName(key)
    if not key then return "NONE" end
    local k = string.upper(key)
    if k == "SEMICOLON" or k == "OEM_1" then return ";" end
    if k == "SPACE" then return "SPACE" end
    if k == "LEFTSHIFT" or k == "SHIFT" then return "SHIFT" end
    if k == "LEFTCONTROL" or k == "CONTROL" then return "CTRL" end
    if k == "LEFTALT" or k == "ALT" then return "ALT" end
    return k
end

local function cacheSpawnLocation()
    if State.spawnLocationCached or State.spawnLocationCaching then return end
    State.spawnLocationCaching = true
    
    task.spawn(function()
        local found = false
        pcall(function()
            for _, obj in workspace:GetDescendants() do
                if found then return end
                if obj.ClassName == "SpawnLocation" then
                    State.cachedSpawnLocation = obj.Position + Vector3.new(0, 3, 0)
                    State.spawnLocationCached = true
                    found = true
                end
            end
        end)
        
        if not found then
            State.cachedSpawnLocation = Vector3.new(0, 50, 0)
            State.spawnLocationCached = true
        end
        State.spawnLocationCaching = false
    end)
end

local function getSpawnLocation()
    if not State.spawnLocationCached then 
        cacheSpawnLocation() 
        return Vector3.new(0, 50, 0)
    end
    return State.cachedSpawnLocation or Vector3.new(0, 50, 0)
end

local function findPlayer(name)
    if not name or name == "" then return nil end
    local nameLower = string.lower(name)
    local nameLen = #nameLower
    local players = Players:GetChildren()
    
    for _, p in players do
        if p:IsA("Player") and string.lower(p.Name) == nameLower then return p end
    end
    for _, p in players do
        if p:IsA("Player") and string.lower(p.DisplayName) == nameLower then return p end
    end
    for _, p in players do
        if p:IsA("Player") and string.sub(string.lower(p.Name), 1, nameLen) == nameLower then return p end
    end
    for _, p in players do
        if p:IsA("Player") and string.sub(string.lower(p.DisplayName), 1, nameLen) == nameLower then return p end
    end
    for _, p in players do
        if p:IsA("Player") and string.find(string.lower(p.Name), nameLower, 1, true) then return p end
    end
    for _, p in players do
        if p:IsA("Player") and string.find(string.lower(p.DisplayName), nameLower, 1, true) then return p end
    end
    return nil
end

local function getPlayerSuggestions(query)
    local results = {}
    local q = string.lower(query)
    for _, p in Players:GetChildren() do
        if p:IsA("Player") and p ~= LocalPlayer then
            local nameLower = string.lower(p.Name)
            local displayLower = string.lower(p.DisplayName)
            if q == "" or string.find(nameLower, q, 1, true) or string.find(displayLower, q, 1, true) then
                table.insert(results, {name = p.Name, displayName = p.DisplayName, player = p})
                if #results >= 5 then break end
            end
        end
    end
    return results
end

local function parseCommandForPlayerArg(input)
    local noPrefix = string.gsub(input, "^;", "")
    local parts = {}
    for p in string.gmatch(noPrefix, "%S+") do table.insert(parts, p) end
    if #parts == 0 then return nil, nil end
    local cmdName = string.lower(parts[1])
    if playerArgCommands[cmdName] then
        if string.find(noPrefix, " ") then
            local argStart = string.find(noPrefix, " ")
            return cmdName, string.sub(noPrefix, argStart + 1)
        else
            return cmdName, ""
        end
    end
    return nil, nil
end

local function getKeybindForCommand(cmdName)
    for key, data in Keybinds.binds do
        if type(data) == "table" and data.cmd == cmdName then 
            return key, data.mode or Keybinds.modes[cmdName] or "toggle"
        elseif type(data) == "string" and data == cmdName then
            return key, Keybinds.modes[cmdName] or "toggle"
        end
    end
    return nil, Keybinds.modes[cmdName] or "toggle"
end

local function getModeForCommand(cmdName)
    return Keybinds.modes[cmdName] or "toggle"
end

local function setModeForCommand(cmdName, mode)
    Keybinds.modes[cmdName] = mode
    for key, data in Keybinds.binds do
        local cmd = type(data) == "table" and data.cmd or data
        if cmd == cmdName then
            Keybinds.binds[key] = {cmd = cmdName, mode = mode}
            return true
        end
    end
    return true
end

local function setKeybind(key, cmdName)
    local mode = Keybinds.modes[cmdName] or "toggle"
    for k, data in Keybinds.binds do
        local cmd = type(data) == "table" and data.cmd or data
        if cmd == cmdName then 
            Keybinds.binds[k] = nil 
            break 
        end
    end
    Keybinds.binds[key] = {cmd = cmdName, mode = mode}
end

local function removeKeybind(cmdName)
    for key, data in Keybinds.binds do
        local cmd = type(data) == "table" and data.cmd or data
        if cmd == cmdName then 
            Keybinds.binds[key] = nil 
            return true
        end
    end
    return false
end

