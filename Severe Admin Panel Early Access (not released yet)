local function deleteChar()
    if CommandPanel.searchFocused and CommandPanel.open and #CommandPanel.searchQuery > 0 then
        CommandPanel.searchQuery = string_sub(CommandPanel.searchQuery, 1, -2)
        CommandPanelDrawing.scrollOffset = 0
        CommandPanelDrawing.targetScroll = 0
        CommandPanelDrawing.needsRedraw = true
        return true
    elseif Bar.open and #Bar.input > 1 then
        Bar.input = string_sub(Bar.input, 1, -2)
        Bar.acSelected = 0
        Bar.playerSuggestionSelected = 0
        Bar.needsRedraw = true
        return true
