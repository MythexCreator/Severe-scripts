local function updateWatermark(dt)
    if not State.introComplete then return end
    
    if Settings.watermarkEnabled then
        Watermark.targetOpacity = 1
        if #Watermark.elements == 0 then
            createWatermark()
        end
    else
        Watermark.targetOpacity = 0
    end
    
    -- Smooth fade
    local diff = Watermark.targetOpacity - Watermark.opacity
    if math.abs(diff) > 0.01 then
        Watermark.opacity = Watermark.opacity + diff * math.min(1, dt * Watermark.fadeSpeed)
    else
        Watermark.opacity = Watermark.targetOpacity
    end
    
    -- Update elements
    local fpsVal = get_overlay_fps and get_overlay_fps() or 0
    local pingVal = game.GetPing and game:GetPing() or 0
    
    for _, item in Watermark.elements do
        local el = item.obj
        if item.type == "glow" then
            el.Opacity = Watermark.opacity * 0.08 / item.layer
        elseif item.type == "bg" then
            el.Opacity = Watermark.opacity * 0.95
        elseif item.type == "border" or item.type == "accent" or item.type == "logo" then
            el.Opacity = Watermark.opacity
        elseif item.type == "text" then
            el.Opacity = Watermark.opacity
        elseif item.type == "fps" then
            el.Text = tostring(math.floor(fpsVal)) .. " FPS"
            el.Opacity = Watermark.opacity
        elseif item.type == "ping" then
            el.Text = tostring(math.floor(pingVal)) .. " ms"
            el.Opacity = Watermark.opacity
        end
    end
    
    -- Hide if opacity is 0
    if Watermark.opacity <= 0.01 and #Watermark.elements > 0 then
        clearWatermark()
    end
end

-- ============================================
-- CLICKTP SYSTEM (Improved with terrain detection)
-- ============================================
local ClickTP = {
    VERTICAL_OFFSET = 3,
    GROUND_CHECK_OFFSET = 5,
    RENDER_DISTANCE_SQ = 500 * 500,
    CACHE_REFRESH_INTERVAL = 0.3,
    RAY_PARALLEL_EPSILON = 1e-5,
    DISTANCE_MIN_EPSILON = 1e-10,
    ANCESTOR_LIMIT = 4,
    
    OBBCache = {},
    OBBCount = 0,
    CharacterRoots = {},
    LastCacheTime = 0,
    WasClicked = false,
    BoundKey = nil,
}

local function IsCharacterDescendant(instance)
    local current = instance.Parent
    for _ = 1, ClickTP.ANCESTOR_LIMIT do
        if current == nil or current == workspace then return false end
        if ClickTP.CharacterRoots[current] then return true end
        current = current.Parent
    end
    return false
end

local function RefreshClickTPCache()
    table.clear(ClickTP.CharacterRoots)
    for _, obj in Players:GetChildren() do
        if obj.ClassName ~= "Player" then continue end
        local char = obj.Character
        if char ~= nil then ClickTP.CharacterRoots[char] = true end
    end

    local camera = workspace.CurrentCamera
    if camera == nil then return end
    local camPos = camera.Position
    local cx, cy, cz = camPos.X, camPos.Y, camPos.Z
    local cache = ClickTP.OBBCache
    local count = 0

    local validClasses = {Part = true, MeshPart = true, UnionOperation = true, WedgePart = true, CornerWedgePart = true, TrussPart = true, SpawnLocation = true}

    for _, inst in workspace:GetDescendants() do
        if not validClasses[inst.ClassName] or inst.Parent == nil or IsCharacterDescendant(inst) then continue end
        
        -- Skip non-collidable parts for terrain detection
        if inst.Transparency >= 1 then continue end
        
        local part = inst
        local cf = part.CFrame
        local pos = cf.Position
        local dx, dy, dz = pos.X - cx, pos.Y - cy, pos.Z - cz
        if dx * dx + dy * dy + dz * dz > ClickTP.RENDER_DISTANCE_SQ then continue end
        local size = part.Size
        local hx, hy, hz = size.X * 0.5, size.Y * 0.5, size.Z * 0.5
        local r, u, l = cf.RightVector, cf.UpVector, cf.LookVector
        count = count + 1
        local entry = cache[count]
        if entry ~= nil then
            entry.PX = pos.X ; entry.PY = pos.Y ; entry.PZ = pos.Z
            entry.RX = r.X   ; entry.RY = r.Y   ; entry.RZ = r.Z   ; entry.HX = hx
            entry.UX = u.X   ; entry.UY = u.Y   ; entry.UZ = u.Z   ; entry.HY = hy
            entry.FX = -l.X  ; entry.FY = -l.Y  ; entry.FZ = -l.Z  ; entry.HZ = hz
            entry.BSR = hx * hx + hy * hy + hz * hz
            entry.TopY = pos.Y + hy
        else
            cache[count] = {
                PX = pos.X, PY = pos.Y, PZ = pos.Z,
                RX = r.X,   RY = r.Y,   RZ = r.Z,   HX = hx,
                UX = u.X,   UY = u.Y,   UZ = u.Z,   HY = hy,
                FX = -l.X,  FY = -l.Y,  FZ = -l.Z,  HZ = hz,
                BSR = hx * hx + hy * hy + hz * hz,
                TopY = pos.Y + hy,
            }
        end
    end

    for i = count + 1, #cache do cache[i] = nil end
    ClickTP.OBBCount = count
end

local function RayOBB(ox, oy, oz, dx, dy, dz, e)
    local ex, ey, ez = e.PX - ox, e.PY - oy, e.PZ - oz
    local tMin, tMax = -math.huge, math.huge
    local proj, dot, near, far, half

    proj = e.RX * ex + e.RY * ey + e.RZ * ez
    dot  = e.RX * dx + e.RY * dy + e.RZ * dz
    half = e.HX
    if dot > ClickTP.RAY_PARALLEL_EPSILON or dot < -ClickTP.RAY_PARALLEL_EPSILON then
        near = (proj + half) / dot ; far = (proj - half) / dot
        if near > far then near, far = far, near end
        if near > tMin then tMin = near end
        if far  < tMax then tMax = far  end
        if tMin > tMax or tMax < ClickTP.RAY_PARALLEL_EPSILON then return nil end
    elseif -proj - half > 0 or -proj + half < 0 then return nil end

    proj = e.UX * ex + e.UY * ey + e.UZ * ez
    dot  = e.UX * dx + e.UY * dy + e.UZ * dz
    half = e.HY
    if dot > ClickTP.RAY_PARALLEL_EPSILON or dot < -ClickTP.RAY_PARALLEL_EPSILON then
        near = (proj + half) / dot ; far = (proj - half) / dot
        if near > far then near, far = far, near end
        if near > tMin then tMin = near end
        if far  < tMax then tMax = far  end
        if tMin > tMax or tMax < ClickTP.RAY_PARALLEL_EPSILON then return nil end
    elseif -proj - half > 0 or -proj + half < 0 then return nil end

    proj = e.FX * ex + e.FY * ey + e.FZ * ez
    dot  = e.FX * dx + e.FY * dy + e.FZ * dz
    half = e.HZ
    if dot > ClickTP.RAY_PARALLEL_EPSILON or dot < -ClickTP.RAY_PARALLEL_EPSILON then
        near = (proj + half) / dot ; far = (proj - half) / dot
        if near > far then near, far = far, near end
        if near > tMin then tMin = near end
        if far  < tMax then tMax = far  end
        if tMin > tMax or tMax < ClickTP.RAY_PARALLEL_EPSILON then return nil end
    elseif -proj - half > 0 or -proj + half < 0 then return nil end

    return tMin >= 0 and tMin or 0
end

local function GetMouseRay(camera, mouse)
    local vp   = camera.ViewportSize
    local half = math.tan(math.rad(camera.FieldOfView * 0.5))
    local asp  = vp.X / vp.Y
    local nx   = (mouse.X / vp.X) * 2 - 1
    local ny   = 1 - (mouse.Y / vp.Y) * 2
    local sx   = nx * asp * half
    local sy   = ny * half
    local r, u, l = camera.RightVector, camera.UpVector, camera.LookVector
    local rx = r.X * sx + u.X * sy + l.X
    local ry = r.Y * sx + u.Y * sy + l.Y
    local rz = r.Z * sx + u.Z * sy + l.Z
    local mag = math.sqrt(rx * rx + ry * ry + rz * rz)
    if mag < ClickTP.DISTANCE_MIN_EPSILON then return 0, 0, 1 end
    return rx / mag, ry / mag, rz / mag
end

local function FindGroundBelow(x, y, z)
    local cache = ClickTP.OBBCache
    local count = ClickTP.OBBCount
    local bestY = -math.huge
    
    for i = 1, count do
        local e = cache[i]
        -- Check if point is within XZ bounds of this part
        local dx = x - e.PX
        local dz = z - e.PZ
        local localX = dx * e.RX + dz * e.RZ
        local localZ = dx * e.FX + dz * e.FZ
        
        if math.abs(localX) <= e.HX + 0.5 and math.abs(localZ) <= e.HZ + 0.5 then
            local topY = e.PY + e.HY
            if topY < y and topY > bestY then
                bestY = topY
            end
        end
    end
    
    return bestY
end

local function PerformClickTPRaycast()
    local character = LocalPlayer.Character
    if not character then return nil end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then
        rootPart = character.PrimaryPart
    end
    if not rootPart or not rootPart:IsA("BasePart") then return nil end

    local camera = workspace.CurrentCamera
    if camera == nil then return nil end

    local camPos = camera.Position
    local ox, oy, oz = camPos.X, camPos.Y, camPos.Z
    
    local mousePos = UserInputService:GetMouseLocation()
    local rdx, rdy, rdz = GetMouseRay(camera, mousePos)
    
    local best = math.huge
    local bestEntry = nil
    local cache = ClickTP.OBBCache
    local count = ClickTP.OBBCount

    for i = 1, count do
        local e = cache[i]
        local bx = e.PX - ox
        local by = e.PY - oy
        local bz = e.PZ - oz
        local cp = bx * rdx + by * rdy + bz * rdz
        if bx * bx + by * by + bz * bz - cp * cp > e.BSR then continue end
        local t = RayOBB(ox, oy, oz, rdx, rdy, rdz, e)
        if t ~= nil and t < best then 
            best = t 
            bestEntry = e
        end
    end

    if best == math.huge then return nil end

    local hitX = ox + rdx * best
    local hitY = oy + rdy * best
    local hitZ = oz + rdz * best
    
    -- Try to find ground surface for better placement
    local groundY = FindGroundBelow(hitX, hitY + 10, hitZ)
    local finalY
    
    if groundY > -math.huge and groundY > hitY - 5 then
        finalY = groundY + ClickTP.VERTICAL_OFFSET
    else
        -- Use the hit point but try to place on top of the surface
        if bestEntry then
            finalY = bestEntry.TopY + ClickTP.VERTICAL_OFFSET
        else
            finalY = hitY + ClickTP.VERTICAL_OFFSET
        end
    end

    return Vector3.new(hitX, finalY, hitZ)
end

local function getClickTPBoundKey()
    for key, data in Keybinds.binds do
        local cmd = type(data) == "table" and data.cmd or data
        if cmd == "clicktp" then
            return key, (type(data) == "table" and data.mode) or Keybinds.modes["clicktp"] or "toggle"
        end
    end
    return nil, "toggle"
end

