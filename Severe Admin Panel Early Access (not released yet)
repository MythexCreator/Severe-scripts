local function updateIntro()
    if State.introComplete then return end
    if not State.introStartTime then return end
    if #State.introElements == 0 then State.introComplete = true return end
    
    local elapsed = os_clock() - State.introStartTime
    local newOpacity
    
    if elapsed < 0.4 then
        newOpacity = elapsed / 0.4
    elseif elapsed < 2.2 then
        newOpacity = 1
    elseif elapsed < 2.6 then
        newOpacity = 1 - ((elapsed - 2.2) / 0.4)
    else
        for i = #State.introElements, 1, -1 do
            local el = State.introElements[i]
            pcall(function() 
                el.Visible = false 
                el:Remove() 
            end)
            State.introElements[i] = nil
        end
        State.introElements = {}
        State.introComplete = true
        notify("Severe Admin loaded! Press " .. formatKeyName(Settings.commandBarKey))
        return
    end
    
    for _, el in State.introElements do
        pcall(function() el.Opacity = newOpacity end)
    end
end

