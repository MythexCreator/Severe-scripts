        Options.searchQuery = string_sub(Options.searchQuery, 1, -2)
        Options.targetScroll = 0
        Options.scrollOffset = 0
        Options.filteredCache = {}
        Options.lastSearchQuery = ""
        Options.needsRedraw = true
        return true
    end
    return false
end

local function applyAC()
    if Bar.showingPlayerSuggestions and #Bar.playerSuggestions > 0 then
        local suggestion = Bar.playerSuggestions[Bar.playerSuggestionSelected] or Bar.playerSuggestions[1]
        if suggestion then
            local cmdName = parseCommandForPlayerArg(Bar.input)
            if cmdName then
                Bar.input = ";" .. cmdName .. " " .. suggestion.name
                Bar.playerSuggestionSelected = 0
                Bar.playerSuggestions = {}
                Bar.showingPlayerSuggestions = false
                Bar.needsRedraw = true
