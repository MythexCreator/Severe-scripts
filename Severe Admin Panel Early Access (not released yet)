runCmd = function(input)
    input = string_gsub(string_gsub(string_gsub(input, ";", ""), "^%s+", ""), "%s+$", "")
    local parts = {}
    for p in string.gmatch(input, "%S+") do table_insert(parts, p) end
    if #parts == 0 then return false end
    local name = string_lower(parts[1])
    table.remove(parts, 1)
    
    for _, c in commands do
        if c.name == name then c.fn(parts) return true end
    end
    notify("Unknown: " .. name)
    return false
end

local function executeKeybind(key, isPressed)
    local data = Keybinds.binds[key]
    if not data then return end
    
    local cmdName = type(data) == "table" and data.cmd or data
    local mode = Keybinds.modes[cmdName] or "toggle"
    
    if cmdName == "clicktp" then
        if mode == "hold" then
            if isPressed then
                if not Features.clickTpEnabled then
                    clickTpOn()
                end
                Keybinds.activeHolds["clicktp"] = true
            else
                if Keybinds.activeHolds["clicktp"] then
                    clickTpOff()
                    Keybinds.activeHolds["clicktp"] = nil
                end
            end
        else
            if isPressed then
                if Features.clickTpEnabled then
                    clickTpOff()
                else
                    clickTpOn()
                end
            end
        end
        return
    end
    
    local checkFn = toggleFeatures[cmdName]
    
    if mode == "hold" then
        if isPressed then
            if checkFn and not checkFn() then
                runCmd(";" .. cmdName)
                Keybinds.activeHolds[cmdName] = true
            end
        else
            if Keybinds.activeHolds[cmdName] then
                runCmd(";un" .. cmdName)
                Keybinds.activeHolds[cmdName] = nil
            end
        end
    else
        if isPressed then
            if checkFn then
                if checkFn() then
                    runCmd(";un" .. cmdName)
                else
                    runCmd(";" .. cmdName)
                end
            else
                runCmd(";" .. cmdName)
            end
        end
    end
end

local function getOptionsFiltered()
    if Options.searchQuery == Options.lastSearchQuery and #Options.filteredCache > 0 then
        return Options.filteredCache
    end
    Options.filteredCache = {}
    local q = string_lower(Options.searchQuery)
    for _, c in commands do
        if bindableCommands[c.name] then
            if q == "" or string_find(string_lower(c.name), q, 1, true) or string_find(string_lower(c.desc), q, 1, true) or string_find(string_lower(c.cat), q, 1, true) then
                table_insert(Options.filteredCache, c)
            end
        end
    end
    Options.lastSearchQuery = Options.searchQuery
    return Options.filteredCache
end

local function optionsMaxScroll()
    return math.max(0, #getOptionsFiltered() - Options.VISIBLE)
end

local function getThemeMaxScroll(presetCount, cols, itemH, gap, availableH)
    local rows = math.ceil(presetCount / cols)
    local totalH = rows * (itemH + gap) - gap
    return math.max(0, totalH - availableH)
end

