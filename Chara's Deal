local function createPiece(points, velX, velY, rotSpeed)
    local sumX, sumY = 0, 0
    for _, p in points do sumX += p.X; sumY += p.Y end
    return { points=points, cx=sumX/#points, cy=sumY/#points, offX=0, offY=0, rot=0, velX=velX, velY=velY, rotVel=rotSpeed, gravity=300, opacity=1 }
end

local function updatePiece(p, dt)
    p.velY += p.gravity * dt
    p.offX += p.velX * dt
    p.offY += p.velY * dt
    p.rot += p.rotVel * dt
end

local function drawPiece(p, opacity)
    if #p.points < 3 then return end
    local cos, sin = math.cos(p.rot), math.sin(p.rot)
    local t = {}
    for _, pt in p.points do
        local dx, dy = pt.X - p.cx, pt.Y - p.cy
        table.insert(t, Vector2.new(p.cx+dx*cos-dy*sin+p.offX, p.cy+dx*sin+dy*cos+p.offY))
    end
    DrawingImmediate.FilledTriangle(t[1], t[2], t[3], RED, opacity * p.opacity)
end

local function generatePieces(cx, cy)
    heartPieces = {}
    local s, r, gap = 24, 12, 24*0.44
    local tipY, topY = cy+s*1.15, cy-s*0.22
    local defs = {
        {{Vector2.new(cx-gap-r, topY-r*0.6), Vector2.new(cx-gap, topY-r*0.8), Vector2.new(cx-gap-r*0.5, topY+r*0.2)}, -120,-180,-3},
        {{Vector2.new(cx-gap, topY-r*0.8), Vector2.new(cx-gap+r*0.3, topY-r*0.5), Vector2.new(cx-gap-r*0.5, topY+r*0.2)}, -80,-200,4},
        {{Vector2.new(cx-gap-r, topY+r*0.2), Vector2.new(cx-gap-r*0.5, topY+r*0.2), Vector2.new(cx-gap-r*0.7, topY+r*0.8)}, -150,-100,-5},
        {{Vector2.new(cx+gap+r, topY-r*0.6), Vector2.new(cx+gap, topY-r*0.8), Vector2.new(cx+gap+r*0.5, topY+r*0.2)}, 120,-180,3},
        {{Vector2.new(cx+gap, topY-r*0.8), Vector2.new(cx+gap-r*0.3, topY-r*0.5), Vector2.new(cx+gap+r*0.5, topY+r*0.2)}, 80,-200,-4},
        {{Vector2.new(cx+gap+r, topY+r*0.2), Vector2.new(cx+gap+r*0.5, topY+r*0.2), Vector2.new(cx+gap+r*0.7, topY+r*0.8)}, 150,-100,5},
        {{Vector2.new(cx-gap-r*0.8, topY+r*0.5), Vector2.new(cx, topY+r*0.3), Vector2.new(cx-s*0.5, tipY*0.5+cy*0.5)}, -100,-60,-2.5},
        {{Vector2.new(cx+gap+r*0.8, topY+r*0.5), Vector2.new(cx, topY+r*0.3), Vector2.new(cx+s*0.5, tipY*0.5+cy*0.5)}, 100,-60,2.5},
        {{Vector2.new(cx-s*0.5, tipY*0.5+cy*0.5), Vector2.new(cx, topY+r*0.6), Vector2.new(cx, tipY)}, -60,-30,-1.5},
        {{Vector2.new(cx+s*0.5, tipY*0.5+cy*0.5), Vector2.new(cx, topY+r*0.6), Vector2.new(cx, tipY)}, 60,-30,1.5},
    }
    for _, def in defs do
        local pts, vx, vy, rv = def[1], def[2], def[3], def[4]
        vx += (math.random()-0.5)*60; vy += (math.random()-0.5)*40; rv += (math.random()-0.5)*2
        table.insert(heartPieces, createPiece(pts, vx, vy, rv))
    end
end

