local function getMouse()
    local ok, result = pcall(getmouseposition)
    if ok and result then return result.X, result.Y end
    return 0, 0
end

local function getClick()
    local cur = isleftpressed()
    local clicked = cur and not prevLeft
    prevLeft = cur
    return clicked
end

local function isMouseIn(mx, my, bx, by, bw, bh)
    return mx >= bx and mx <= bx + bw and my >= by and my <= by + bh
end

