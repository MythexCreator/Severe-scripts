--// ============================================
--// UTILS
--// ============================================

local function lerp(a, b, t) return a + (b - a) * math.clamp(t, 0, 1) end
local function easeOutCubic(t) return 1 - math.pow(1 - math.clamp(t, 0, 1), 3) end
local function easeInQuad(t) t = math.clamp(t, 0, 1) return t * t end
local function easeOutBack(t)
    t = math.clamp(t, 0, 1)
    local c1 = 1.70158
    return 1 + (c1 + 1) * math.pow(t - 1, 3) + c1 * math.pow(t - 1, 2)
end

local function getHRP()
    local char = LocalPlayer.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart")
end

--// ============================================
--// VOID HIDE
--// ============================================

local function voidEnter()
    if voidEnabled then return end
    local hrp = getHRP()
    if not hrp then return end
    voidSavedPosition = hrp.Position
    voidEnabled = true
end

local function voidExit()
    if not voidEnabled then return end
    voidJustDisabled = true
    voidEnabled = false
end

RunService.PostLocal:Connect(function()
    local hrp = getHRP()
    if not hrp then return end

    if voidEnabled then
        local pos = hrp.Position
        hrp.Position = Vector3.new(
            pos.X + VOID_OFFSET,
            pos.Y + VOID_OFFSET,
            pos.Z + VOID_OFFSET
        )
    elseif voidJustDisabled and voidSavedPosition then
        hrp.Position = voidSavedPosition
        hrp.Velocity = Vector3.new(0, 0, 0)
        voidJustDisabled = false
        voidSavedPosition = nil
    end
end)

--// ============================================
--// DIEDTP
--// ============================================

local function updateDiedTp(dt)
    if DiedTp.cooldown > 0 then DiedTp.cooldown = DiedTp.cooldown - dt; return end
    if not fightChosen then return end

    pcall(function()
        local char = LocalPlayer.Character
        if not char then
            DiedTp.wasDead = true
            DiedTp.wasAliveLastFrame = false
            return
        end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then
            DiedTp.wasDead = true
            DiedTp.wasAliveLastFrame = false
            return
        end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum then return end

        local currentHealth = hum.Health
        local isAliveNow = currentHealth > 0

        if isAliveNow and root then
            DiedTp.lastPos = root.Position
        end

        if DiedTp.wasDead and isAliveNow and DiedTp.deathPos then
            local savedPos = DiedTp.deathPos

            if voidEnabled then
                voidSavedPosition = savedPos + Vector3.new(0, 3, 0)
                voidExit()
            end

            task.spawn(function()
                task.wait(0.15)
                pcall(function()
                    local r = getHRP()
                    if r then
                        r.CFrame = CFrame.new(savedPos + Vector3.new(0, 3, 0))
                        r.Velocity = Vector3.new(0, 0, 0)
                    end
                end)
            end)

            DiedTp.wasDead = false
            DiedTp.deathPos = nil
            DiedTp.cooldown = 2
            fightChosen = false
        end

        DiedTp.lastHealth = currentHealth
        DiedTp.wasAliveLastFrame = isAliveNow
    end)
end

