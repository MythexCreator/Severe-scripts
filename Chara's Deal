local function drawHeart(cx, cy, scale, opacity, color)
    if opacity <= 0.001 then return end
    local s = 24 * scale
    local r = s * 0.5
    local gap = s * 0.44
    local lc = Vector2.new(cx - gap, cy - s * 0.22)
    local rc = Vector2.new(cx + gap, cy - s * 0.22)
    local tip = Vector2.new(cx, cy + s * 1.15)
    DrawingImmediate.FilledCircle(lc, r, color, opacity)
    DrawingImmediate.FilledCircle(rc, r, color, opacity)
    DrawingImmediate.FilledTriangle(Vector2.new(cx-gap-r, lc.Y), Vector2.new(cx, lc.Y+r*0.15), tip, color, opacity)
    DrawingImmediate.FilledTriangle(Vector2.new(cx+gap+r, rc.Y), Vector2.new(cx, rc.Y+r*0.15), tip, color, opacity)
    DrawingImmediate.FilledRectangle(Vector2.new(cx-gap, lc.Y-r*0.05), Vector2.new(gap*2, r*0.7), color, opacity)
    DrawingImmediate.FilledTriangle(Vector2.new(cx-gap-r*0.3, lc.Y+r*0.6), Vector2.new(cx+gap+r*0.3, rc.Y+r*0.6), tip, color, opacity)
end

