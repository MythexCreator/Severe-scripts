local function getButtonBounds(cx, cy, isLeft, sv)
    local bw = math.floor(sv.X * 0.15)
    local bh = math.floor(sv.Y * 0.08)
    local spacing = math.floor(sv.X * 0.08)
    local bx
    if isLeft then bx = cx - spacing - bw else bx = cx + spacing end
    local by = math.floor(sv.Y * 0.75)
    return bx, by, bw, bh
end

local function getSkipBounds(cx, cy, sv)
    local bw = math.floor(sv.X * 0.08)
    local bh = math.floor(sv.Y * 0.04)
    local bx = cx - bw / 2
    local by = math.floor(sv.Y * 0.88)
    return bx, by, bw, bh
end

local function drawUndertaleButton(bx, by, bw, bh, text, op, hoverSmooth, baseColor, isLocked)
    if op <= 0 then return end
    if isLocked then
        DrawingImmediate.FilledRectangle(Vector2.new(bx, by), Vector2.new(bw, bh), Color3.fromRGB(15,15,15), op)
        DrawingImmediate.Rectangle(Vector2.new(bx, by), Vector2.new(bw, bh), DARK_GRAY, op, 4)
        drawPixelText(bx+bw/2, by+bh/2-14, text, 28, DARK_GRAY, op, true)
        return
    end
    local bgColor = Color3.new(lerp(0, baseColor.R, hoverSmooth), lerp(0, baseColor.G, hoverSmooth), lerp(0, baseColor.B, hoverSmooth))
    local textColor = Color3.new(lerp(baseColor.R, 1, hoverSmooth), lerp(baseColor.G, 1, hoverSmooth), lerp(baseColor.B, 1, hoverSmooth))
    DrawingImmediate.FilledRectangle(Vector2.new(bx, by), Vector2.new(bw, bh), bgColor, op)
    DrawingImmediate.Rectangle(Vector2.new(bx, by), Vector2.new(bw, bh), baseColor, op, 4)
    drawPixelText(bx+bw/2, by+bh/2-14, text, 28, textColor, op, true)
end

local function drawSkipButton(bx, by, bw, bh, op, hoverSmooth)
    if op <= 0 then return end
    local bgColor = Color3.new(lerp(0, 0.35, hoverSmooth), lerp(0, 0.35, hoverSmooth), lerp(0, 0.35, hoverSmooth))
    local textColor = Color3.new(lerp(0.35, 1, hoverSmooth), lerp(0.35, 1, hoverSmooth), lerp(0.35, 1, hoverSmooth))
    DrawingImmediate.FilledRectangle(Vector2.new(bx, by), Vector2.new(bw, bh), bgColor, op)
    DrawingImmediate.Rectangle(Vector2.new(bx, by), Vector2.new(bw, bh), SKIP_GRAY, op, 2)
    DrawingImmediate.OutlinedText(Vector2.new(bx+bw/2, by+bh/2-8), 14, Color3.new(textColor.R, textColor.G, textColor.B), op, "SKIP", true)
end

local function drawChains(bx, by, bw, bh, op)
    if op <= 0 then return end
    for i = 0, 4 do DrawingImmediate.Line(Vector2.new(bx-20, by+(bh/4)*i), Vector2.new(bx+bw+20, by+(bh/4)*i), CHAIN_COLOR, op, 1, 3) end
    for i = 0, 3 do DrawingImmediate.Line(Vector2.new(bx+(bw/3)*i, by-20), Vector2.new(bx+(bw/3)*i, by+bh+20), CHAIN_COLOR, op, 1, 3) end
    for ix = 0, 3 do for iy = 0, 4 do DrawingImmediate.Circle(Vector2.new(bx+(bw/3)*ix, by+(bh/4)*iy), 6, CHAIN_COLOR, op, 2) end end
end

--// ============================================
--// FAZY
--// ============================================

local function setPhase(p) phase = p; phaseTimer = 0 end

local function goToChoice()
    charaTextOp = 0
    charaGlitchActive = false
    skipOp = 0
    skipHoverSmooth = 0
    skipShown = false
    phase = "choice"
    phaseTimer = 0
    choiceVisible = true
    fightOp = 0; giveUpOp = 0
    fightHoverSmooth = 0; giveUpHoverSmooth = 0
    chainOp = giveUpLocked and 1 or 0
    choiceTimer = 0
end

local function resetAnimState()
    animTimer = 0
    heartVis = 0; heartSc = 1; heartShake = 0
    crackProg = 0; crackOp = 0
    overlayOp = 0; gameOverOp = 0
    charaTextOp = 0; charaTextChars = 0; charaTextIndex = 0; charaGlitchActive = false
    charaStartTime = 0
    skipOp = 0; skipHoverSmooth = 0; skipShown = false
    choiceVisible = false; fightOp = 0; giveUpOp = 0
    fightHoverSmooth = 0; giveUpHoverSmooth = 0
    chainTextOp = 0; chainTextChars = 0; choiceTimer = 0
    fightActive = false; fightHeartVis = 0; fightFlash = 0
    heartPieces = {}; heartBreakPhase = 0; heartBreakTimer = 0
    fightChosen = false
end

local function updatePhases(dt)
    if phase == "none" then return end
    phaseTimer += dt; animTimer += dt

    local sv = workspace.CurrentCamera.ViewportSize
    local cx = sv.X / 2
    local cy = sv.Y / 2
    local mx, my = getMouse()
    local clicked = getClick()

    if phase == "blackout" then
        overlayOp = easeInQuad(phaseTimer / 1.0)
        if phaseTimer >= 1.5 then overlayOp = 1; setPhase("heart_show"); heartBreakPhase = 0; heartBreakTimer = 0 end
    end

    if phase == "heart_show" then
        overlayOp = 1; heartBreakTimer += dt
        if heartBreakPhase == 0 then
            heartVis = easeOutCubic(heartBreakTimer / 0.5); heartSc = 1; heartShake = 0; crackOp = 0
            if heartBreakTimer >= 0.8 then heartBreakPhase = 1; heartBreakTimer = 0 end
        end
        if heartBreakPhase == 1 then
            heartVis = 1; heartShake = heartBreakTimer / 0.5 * 4
            if heartBreakTimer >= 0.5 then heartBreakPhase = 2; heartBreakTimer = 0 end
        end
        if heartBreakPhase == 2 then
            heartVis = 1; heartShake = 3; crackProg = easeOutCubic(heartBreakTimer / 0.3); crackOp = 1
            if heartBreakTimer >= 0.4 then heartBreakPhase = 3; heartBreakTimer = 0; generatePieces(cx, cy) end
        end
        if heartBreakPhase == 3 then
            heartVis = 0; crackOp = 0; heartShake = 0
            for _, p in heartPieces do updatePiece(p, dt) end
            if heartBreakTimer > 0.8 then for _, p in heartPieces do p.opacity = 1 - math.clamp((heartBreakTimer-0.8)/0.7, 0, 1) end end
            if heartBreakTimer >= 1.5 then
                heartPieces = {}
                if deathCount <= 1 then setPhase("game_over") else setPhase("game_over_quick") end
            end
        end
    end

    if phase == "game_over" then
        overlayOp = 1; gameOverOp = easeOutCubic(phaseTimer / 0.8)
        if phaseTimer >= 3.0 then setPhase("chara_appear") end
    end

    if phase == "game_over_quick" then
        overlayOp = 1; gameOverOp = easeOutCubic(phaseTimer / 0.8)
        if phaseTimer >= 1.5 then goToChoice() end
    end

    if phase == "chara_appear" then
        overlayOp = 1; charaGlitchActive = true; gameOverOp = 1
        if phaseTimer >= 2.0 then
            charaGlitchActive = false
            setPhase("chara_text")
            charaTextIndex = 1; charaTextChars = 0
            charaStartTime = animTimer
            skipShown = true
        end
    end

    if phase == "chara_text" then
        overlayOp = 1; gameOverOp = 0.3; charaGlitchActive = false
        charaTextChars = math.floor(phaseTimer / 0.05) + 1
        charaTextOp = 1

        -- Skip stays visible once shown, smooth fade in
        if skipShown then
            skipOp = lerp(skipOp, 1, dt * 5)
        end

        -- Skip hover + click
        local sbx, sby, sbw, sbh = getSkipBounds(cx, cy, sv)
        local sHover = isMouseIn(mx, my, sbx, sby, sbw, sbh) and skipOp >= 0.5
        skipHoverSmooth = lerp(skipHoverSmooth, sHover and 1 or 0, dt * 10)

        if clicked and sHover then
            goToChoice()
            return
        end

        -- Normal text progression
        local fullText = charaTexts[charaTextIndex] or ""
        if charaTextChars >= #fullText and clicked then
            charaTextIndex += 1
            phaseTimer = 0
            charaTextChars = 0

            if charaTextIndex > #charaTexts then
                goToChoice()
                return
            end
        end
    end

    if phase == "choice" then
        overlayOp = 1; gameOverOp = lerp(gameOverOp, 0.4, dt * 3); choiceTimer += dt
        fightOp = math.clamp(choiceTimer / 0.5, 0, 1)
        giveUpOp = math.clamp((choiceTimer - 0.15) / 0.5, 0, 1)
        if giveUpLocked then chainOp = math.clamp((choiceTimer-0.3)/0.5, 0, 1) end

        local fbx, fby, fbw, fbh = getButtonBounds(cx, cy, true, sv)
        local gbx, gby, gbw, gbh = getButtonBounds(cx, cy, false, sv)
        local fHover = isMouseIn(mx, my, fbx, fby, fbw, fbh) and fightOp >= 0.8
        local gHover = not giveUpLocked and isMouseIn(mx, my, gbx, gby, gbw, gbh) and giveUpOp >= 0.8
        fightHoverSmooth = lerp(fightHoverSmooth, fHover and 1 or 0, dt * 10)
        giveUpHoverSmooth = lerp(giveUpHoverSmooth, gHover and 1 or 0, dt * 10)

        if clicked and fHover then
            fightChosen = true
            DiedTp.deathPos = deathPos
            DiedTp.wasDead = true
            if voidEnabled then
                voidSavedPosition = deathPos + Vector3.new(0, 3, 0)
                voidExit()
            end
            setPhase("fight_anim")
            fightActive = true; fightTimer = 0; fightHeartVis = 0; fightHeartSc = 0.5
            choiceVisible = false; charaTextOp = 0
        end

        if clicked and gHover then
            giveUpLocked = true; setPhase("chain_text"); chainOp = 0; chainTextOp = 0; chainTextChars = 0
        end
    end

    if phase == "chain_text" then
        overlayOp = 1; gameOverOp = 0.4; choiceVisible = true
        chainOp = easeOutCubic(phaseTimer / 0.5)
        if phaseTimer > 0.8 then
            local tt = phaseTimer - 0.8
            chainTextOp = math.clamp(tt * 2, 0, 1); chainTextChars = math.floor(tt / 0.04) + 1
        end
        if chainTextChars >= 57 + 25 and clicked then
            setPhase("choice"); choiceVisible = true; choiceTimer = 0.5; fightOp = 1; giveUpOp = 1; chainTextOp = 0; chainTextChars = 0
        end
    end

    if phase == "fight_anim" then
        overlayOp = 1; fightTimer += dt; gameOverOp = lerp(gameOverOp, 0, dt * 5)
        if fightTimer < 0.5 then
            fightHeartVis = easeOutCubic(fightTimer / 0.5)
            fightHeartSc = lerp(0.5, 1.2, easeOutBack(fightTimer / 0.5))
        end
        if fightTimer >= 0.5 and fightTimer < 1.5 then
            fightHeartVis = 1; fightHeartSc = 1 + math.sin((fightTimer-0.5)*math.pi*4)*0.05
        end
        if fightTimer >= 1.5 and fightTimer < 2.0 then
            local p = (fightTimer-1.5)/0.5
            fightFlash = math.max(0, 1-p*2); fightHeartVis = 1-easeInQuad(p); fightHeartSc = lerp(1, 1.5, p)
        end
        if fightTimer >= 2.0 then
            overlayOp = 1 - easeInQuad((fightTimer-2.0)/1.0)
            fightHeartVis = 0; fightFlash = 0; gameOverOp = 0
        end
        if fightTimer >= 3.0 then
            setPhase("none"); fightActive = false; overlayOp = 0; gameOverOp = 0
            dead = false; block_roblox_window(false)
        end
    end
end

--// ============================================
--// ŚMIERĆ
--// ============================================

local function onDeath()
    dead = true; deathCount += 1
    block_roblox_window(true)
    voidEnter()
    resetAnimState()
    setPhase("blackout")
end

--// ============================================
--// RENDER
--// ============================================

RunService.Render:Connect(function()
    local now = tick()
    local dt = lastTick and math.clamp(now - lastTick, 0, 0.04) or 0
    lastTick = now

    updateDiedTp(dt)

    if not dead then
        pcall(function()
            local char = LocalPlayer.Character
            if not char then wasAlive = false; return end
            local hum = char:FindFirstChildOfClass("Humanoid")
            if not hum then wasAlive = false; return end
            local hp = hum.Health
            local isAlive = hp > 0
            if isAlive then
                local root = char:FindFirstChild("HumanoidRootPart")
                if root then lastPos = root.Position end
            end
            if wasAlive and not isAlive then deathPos = lastPos; onDeath() end
            wasAlive = isAlive
        end)
    end

    updatePhases(dt)

    if phase == "none" and overlayOp <= 0 then return end

    local sv = workspace.CurrentCamera.ViewportSize
    local cx = sv.X / 2; local cy = sv.Y / 2

    drawOverlay(overlayOp)

    if heartBreakPhase == 3 and phase == "heart_show" then
        for _, p in heartPieces do drawPiece(p, 1) end
    end

    local shX = (math.random()-0.5) * heartShake; local shY = (math.random()-0.5) * heartShake
    if heartVis > 0 then drawHeart(cx+shX, cy+shY, heartSc, heartVis, RED) end
    if crackOp > 0 then drawCrackLine(cx+shX, cy+shY, heartSc, crackProg, crackOp) end
    if gameOverOp > 0 then drawGameOver(cx, cy, gameOverOp, sv) end

    if phase == "chara_text" and charaTextOp > 0 then
        local txt = charaTexts[charaTextIndex] or ""
        drawPixelTypewriter(cx, sv.Y * 0.55, txt, charaTextChars, 26, CHARA_RED, charaTextOp, true)
        if charaTextChars >= #(charaTexts[charaTextIndex] or "") then
            if math.sin(animTimer * 4) > 0 then
                DrawingImmediate.OutlinedText(Vector2.new(cx, sv.Y*0.55+40), 12, Color3.fromRGB(80,80,80), 0.5, "Click to continue", true)
            end
        end

        -- Skip button
        if skipOp > 0 then
            local sbx, sby, sbw, sbh = getSkipBounds(cx, cy, sv)
            drawSkipButton(sbx, sby, sbw, sbh, skipOp, skipHoverSmooth)
        end
    end

    if choiceVisible or phase == "chain_text" then
        local fbx, fby, fbw, fbh = getButtonBounds(cx, cy, true, sv)
        local gbx, gby, gbw, gbh = getButtonBounds(cx, cy, false, sv)
        drawUndertaleButton(fbx, fby, fbw, fbh, "FIGHT", fightOp, fightHoverSmooth, ORANGE, false)
        drawUndertaleButton(gbx, gby, gbw, gbh, "GIVE UP", giveUpOp, giveUpHoverSmooth, WHITE, giveUpLocked)
        if giveUpLocked and chainOp > 0 then drawChains(gbx, gby, gbw, gbh, chainOp) end
    end

    if chainTextOp > 0 then
        drawPixelTypewriter(cx, sv.Y*0.88, "Did you really think I would let you give up so easily?", chainTextChars, 20, CHARA_RED, chainTextOp, true)
    end

    if fightHeartVis > 0 then drawHeart(cx, cy, fightHeartSc, fightHeartVis, RED) end
    if fightFlash > 0 then DrawingImmediate.FilledRectangle(Vector2.new(0,0), sv, WHITE, fightFlash*0.4) end
end)
