end

-- ============================================
-- SAVEPOS / LOADPOS
-- ============================================
local savedPositions = {}

local function savePos(slot)
    local slotNum = tonumber(slot) or 1
    slotNum = math.clamp(slotNum, 1, 9)
    
    local char = LocalPlayer.Character
    if not char then notify("No character") return end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then notify("No HumanoidRootPart") return end
    
    savedPositions[slotNum] = {
        cframe = root.CFrame,
        position = root.Position
    }
    
    notify("Position saved to slot " .. slotNum)
end

local function loadPos(slot)
    local slotNum = tonumber(slot) or 1
    slotNum = math.clamp(slotNum, 1, 9)
    
    local saved = savedPositions[slotNum]
    if not saved then
        notify("No position saved in slot " .. slotNum)
        return
    end
    
    local char = LocalPlayer.Character
    if not char then notify("No character") return end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then notify("No HumanoidRootPart") return end
    
    pcall(function()
        root.CFrame = saved.cframe
        root.Velocity = Vector3.new(0, 0, 0)
    end)
    
    notify("Loaded position from slot " .. slotNum)
end

