-- KEYBIND FUNCTIONS
-- ============================================
local function getKeybindForCommand(cmdName)
    for key, cmd in Keybinds.binds do
        if cmd == cmdName then return key end
    end
    return nil
end

local function setKeybind(key, cmdName)
    for k, c in Keybinds.binds do
        if c == cmdName then Keybinds.binds[k] = nil break end
    end
    Keybinds.binds[key] = cmdName
end

local function removeKeybind(cmdName)
    for key, cmd in Keybinds.binds do
        if cmd == cmdName then Keybinds.binds[key] = nil return end
    end
end

