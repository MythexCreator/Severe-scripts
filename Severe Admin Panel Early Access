-- ============================================
-- UTILITY
-- ============================================
local function inRect(p, pos, size)
    return p.X >= pos.X and p.X <= pos.X + size.X and p.Y >= pos.Y and p.Y <= pos.Y + size.Y
end

local function getDistance(pos1, pos2)
    if not pos1 or not pos2 then return 0 end
    local dx = (pos1.X or pos1.x or 0) - (pos2.X or pos2.x or 0)
    local dy = (pos1.Y or pos1.y or 0) - (pos2.Y or pos2.y or 0)
    local dz = (pos1.Z or pos1.z or 0) - (pos2.Z or pos2.z or 0)
    return math.sqrt(dx * dx + dy * dy + dz * dz)
end

