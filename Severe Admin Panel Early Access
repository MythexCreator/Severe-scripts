local function hideBar()
    clearBar()
    Bar.open = false
    Bar.input = ""
    Bar.acSelected = 0
    Bar.playerSuggestionSelected = 0
    Bar.playerSuggestions = {}
    Bar.showingPlayerSuggestions = false
    Input.heldKeys = {}
end

-- ============================================
-- CREATE BAR (Drawing)
-- ============================================
local function createBar()
    clearBar()
    
    local cam = workspace.CurrentCamera
    if not cam then return end
    
    local vw, vh = cam.ViewportSize.X, cam.ViewportSize.Y
    local cmdName, playerArg = parseCommandForPlayerArg(Bar.input)
    
    if cmdName and playerArg ~= nil then
        Bar.playerSuggestions = getPlayerSuggestions(playerArg)
        Bar.showingPlayerSuggestions = #Bar.playerSuggestions > 0
        Bar.acResults = {}
    else
        Bar.playerSuggestions = {}
        Bar.showingPlayerSuggestions = false
        local c = string.lower(string.gsub(Bar.input, "^;", ""))
        Bar.acResults = {}
        if c ~= "" and not string.find(c, " ") then
            for _, cmd in commands do
                if string.find(string.lower(cmd.name), c, 1, true) == 1 then
                    table.insert(Bar.acResults, cmd)
                    if #Bar.acResults >= 5 then break end
                end
            end
        end
    end
    
    local dropdownCount = Bar.showingPlayerSuggestions and #Bar.playerSuggestions or #Bar.acResults
    local acH = dropdownCount * 36
    local bW, bH, gap = 480, 48, 8
    local bX = math.floor(vw / 2 - bW / 2)
    local bY = math.floor(vh - 80)
    local els = Bar.elements
    
    local shadow = Drawing.new("Square")
    shadow.Visible = true
    shadow.Filled = true
    shadow.Color = Color3.fromRGB(0, 0, 0)
    shadow.Opacity = 0.5
    shadow.Rounding = 12
    shadow.Position = Vector2.new(bX - 4, bY - 4)
    shadow.Size = Vector2.new(bW + 8, bH + 8)
    table.insert(els, shadow)
    
    local bar = Drawing.new("Square")
    bar.Visible = true
    bar.Filled = true
    bar.Color = Theme.Primary
    bar.Rounding = 8
    bar.Position = Vector2.new(bX, bY)
    bar.Size = Vector2.new(bW, bH)
    table.insert(els, bar)
    
    local border = Drawing.new("Square")
    border.Visible = true
    border.Filled = false
    border.Color = Theme.Accent
    border.Rounding = 8
    border.Thickness = 2
    border.Position = Vector2.new(bX, bY)
    border.Size = Vector2.new(bW, bH)
    table.insert(els, border)
    
    local prompt = Drawing.new("Text")
    prompt.Visible = true
    prompt.Text = ">"
    prompt.Size = 18
    prompt.Color = Theme.Accent
    prompt.Outline = true
    prompt.Position = Vector2.new(bX + 14, bY + 14)
    table.insert(els, prompt)
    
    local cur = (os_clock() % 0.7) > 0.35 and "|" or ""
    local inputT = Drawing.new("Text")
    inputT.Visible = true
    inputT.Text = Bar.input .. cur
    inputT.Size = 15
    inputT.Color = Theme.TextPrimary
    inputT.Outline = true
    inputT.Position = Vector2.new(bX + 36, bY + 16)
    table.insert(els, inputT)
    
    if dropdownCount > 0 then
        local dropY = bY - acH - gap - 8
        
        local dropShadow = Drawing.new("Square")
        dropShadow.Visible = true
        dropShadow.Filled = true
        dropShadow.Color = Color3.fromRGB(0, 0, 0)
        dropShadow.Opacity = 0.5
        dropShadow.Rounding = 8
        dropShadow.Position = Vector2.new(bX - 4, dropY - 4)
        dropShadow.Size = Vector2.new(bW + 8, acH + 16)
        table.insert(els, dropShadow)
        
        local dropBg = Drawing.new("Square")
        dropBg.Visible = true
        dropBg.Filled = true
        dropBg.Color = Theme.Secondary
        dropBg.Rounding = 8
        dropBg.Position = Vector2.new(bX, dropY)
        dropBg.Size = Vector2.new(bW, acH + 8)
        table.insert(els, dropBg)
        
        if Bar.showingPlayerSuggestions then
            for i, suggestion in Bar.playerSuggestions do
                local yP = dropY + (i - 1) * 36 + 4
                local sel = (i == Bar.playerSuggestionSelected)
                
                if sel then
                    local hl = Drawing.new("Square")
                    hl.Visible = true
                    hl.Filled = true
                    hl.Color = Theme.Accent
                    hl.Opacity = 0.2
                    hl.Rounding = 4
                    hl.Position = Vector2.new(bX + 4, yP)
                    hl.Size = Vector2.new(bW - 8, 32)
                    table.insert(els, hl)
                end
                
                local dot = Drawing.new("Circle")
                dot.Visible = true
                dot.Filled = true
                dot.Color = Theme.Visual
                dot.NumSides = 12
                dot.Position = Vector2.new(bX + 18, yP + 16)
                dot.Radius = 4
                table.insert(els, dot)
                
                local displayText = suggestion.displayName
                if suggestion.displayName ~= suggestion.name then
                    displayText = suggestion.displayName .. " (@" .. suggestion.name .. ")"
                end
                
                local nameT = Drawing.new("Text")
                nameT.Visible = true
                nameT.Text = displayText
                nameT.Size = 13
                nameT.Color = sel and Theme.AccentLight or Theme.TextPrimary
                nameT.Outline = true
                nameT.Position = Vector2.new(bX + 30, yP + 8)
                table.insert(els, nameT)
            end
        else
            for i, cmd in Bar.acResults do
                local yP = dropY + (i - 1) * 36 + 4
                local sel = (i == Bar.acSelected)
                
                if sel then
                    local hl = Drawing.new("Square")
                    hl.Visible = true
                    hl.Filled = true
                    hl.Color = Theme.Accent
                    hl.Opacity = 0.2
                    hl.Rounding = 4
                    hl.Position = Vector2.new(bX + 4, yP)
                    hl.Size = Vector2.new(bW - 8, 32)
                    table.insert(els, hl)
                end
                
                local dot = Drawing.new("Circle")
                dot.Visible = true
                dot.Filled = true
                dot.Color = catColor(cmd.cat)
                dot.NumSides = 12
                dot.Position = Vector2.new(bX + 18, yP + 16)
                dot.Radius = 4
                table.insert(els, dot)
                
                local cmdT = Drawing.new("Text")
                cmdT.Visible = true
                cmdT.Text = ";" .. cmd.name
                cmdT.Size = 13
                cmdT.Color = sel and Theme.AccentLight or Theme.Accent
                cmdT.Outline = true
                cmdT.Position = Vector2.new(bX + 30, yP + 8)
                table.insert(els, cmdT)
                
                local descT = Drawing.new("Text")
                descT.Visible = true
                descT.Text = " - " .. cmd.desc
                descT.Size = 11
                descT.Color = Theme.TextMuted
                descT.Outline = true
                descT.Position = Vector2.new(bX + 30 + (#cmd.name + 1) * 8 + 5, yP + 9)
                table.insert(els, descT)
            end
        end
    end
    
    Bar.needsRedraw = false
end

