-- ============================================
-- FOV (FIXED - IMMEDIATE CHANGE)
-- ============================================
local defaultFov = 70
local fovConn = nil
local currentFovValue = nil

local function writeFovDirect(value)
    pcall(function()
        local cam = workspace.CurrentCamera
        if cam then
            memory.writef32(cam, 0x160, math.rad(value))
        end
    end)
end

local function setFov(value)
    local num = tonumber(value)
    if not num then 
        notify("Invalid FOV value") 
        return 
    end
    num = math.clamp(num, 1, 120)
    currentFovValue = num
    
    for i = 1, 5 do
        writeFovDirect(num)
    end
    
    if fovConn then 
        fovConn:Disconnect() 
        fovConn = nil 
    end
    
    fovConn = RunService.Render:Connect(function()
        if not currentFovValue then return end
        writeFovDirect(currentFovValue)
    end)
    
    notify("FOV set to " .. num)
end

local function resetFov()
    currentFovValue = nil
    
    if fovConn then
        fovConn:Disconnect()
        fovConn = nil
    end
    
    for i = 1, 5 do
        writeFovDirect(defaultFov)
    end
    
    notify("FOV reset to " .. defaultFov)
end

-- ============================================
-- NOCLIP CAM (Camera passes through walls)
-- ============================================
local noclipCamEnabled = false
local noclipCamConn = nil
local noclipCamDistance = 12
local noclipCamHeight = 2

local function noclipCamOn()
    if noclipCamConn then return end
    noclipCamEnabled = true
    
    pcall(function()
        local cam = workspace.CurrentCamera
        local char = LocalPlayer.Character
        if cam and char then
            local root = char:FindFirstChild("HumanoidRootPart")
            if root then
                local offset = cam.CFrame.Position - root.Position
                noclipCamDistance = math.clamp(offset.Magnitude, 5, 20)
            end
        end
    end)
    
    noclipCamConn = RunService.Render:Connect(function()
        if not noclipCamEnabled then return end
        
        pcall(function()
            local cam = workspace.CurrentCamera
            if not cam then return end
            
            local char = LocalPlayer.Character
            if not char then return end
            
            local root = char:FindFirstChild("HumanoidRootPart")
            if not root then return end
            
            local camCFrame = cam.CFrame
            local lookVector = camCFrame.LookVector
            
            local playerPos = root.Position
            local desiredCamPos = playerPos - (lookVector * noclipCamDistance) + Vector3.new(0, noclipCamHeight, 0)
            
            local camPos = vector(desiredCamPos.X, desiredCamPos.Y, desiredCamPos.Z)
            memory.writevector(cam, 0x11C, camPos)
        end)
    end)
    
    notify("NoclipCam enabled")
end

local function noclipCamOff()
    noclipCamEnabled = false
    if noclipCamConn then
        noclipCamConn:Disconnect()
        noclipCamConn = nil
    end
    
    pcall(function()
        local cam = workspace.CurrentCamera
        local char = LocalPlayer.Character
        if cam and char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then
                cam.CameraSubject = hum
            end
        end
    end)
    
    notify("NoclipCam disabled")
end

