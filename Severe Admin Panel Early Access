local function updateIntro()
    if introComplete then return end
    if not introStartTime then return end
    if #introElements == 0 then 
        introComplete = true
        return
    end
    
    local elapsed = os.clock() - introStartTime
    
    if elapsed < 0.4 then
        local alpha = elapsed / 0.4
        for _, el in ipairs(introElements) do
            pcall(function() el.Opacity = alpha end)
        end
    elseif elapsed < 2.2 then
        for _, el in ipairs(introElements) do
            pcall(function() el.Opacity = 1 end)
        end
    elseif elapsed < 2.6 then
        local alpha = 1 - ((elapsed - 2.2) / 0.4)
        for _, el in ipairs(introElements) do
            pcall(function() el.Opacity = alpha end)
        end
    else
        for _, el in ipairs(introElements) do
            pcall(function() 
                el.Visible = false
                el:Remove() 
            end)
        end
        introElements = {}
        introComplete = true
        notify("Severe Admin loaded! Press ;")
    end
end

