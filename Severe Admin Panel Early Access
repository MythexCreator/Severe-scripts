-- COMMAND BAR
-- ============================================
local barOpen = false
local barElements = {}
local barInput = ""
local acResults = {}
local acSelected = 0

local function getAC(input)
    local r = {}
    local c = input:gsub("^;", ""):lower()
    if c == "" or c:find(" ") then return r end
    
    for _, cmd in ipairs(commands) do
        if cmd.name:lower():find(c, 1, true) == 1 then
            table.insert(r, cmd)
            if #r >= 5 then break end
        end
    end
    return r
end

