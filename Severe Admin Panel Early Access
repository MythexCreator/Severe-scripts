-- SPAWNPOINT
-- ============================================
local spawnPointEnabled = false
local spawnPointPosition = nil
local spawnPointCFrame = nil

local sp_lastCharacter = nil
local sp_lastCharacterName = nil
local sp_lastRootPart = nil
local sp_lastHealth = 100
local sp_lastMaxHealth = 100
local sp_wasAlive = true
local sp_lastPosition = nil
local sp_teleportCooldown = 0
local sp_justTeleported = false
local sp_framesSinceRespawn = 0

local function setSpawnpoint()
    local char = LocalPlayer.Character
    if not char then notify("No character") return end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then notify("No HumanoidRootPart") return end
    
    spawnPointCFrame = root.CFrame
    spawnPointPosition = root.Position + Vector3.new(0, 0.5, 0)
    spawnPointEnabled = true
    
    sp_lastCharacter = char
    sp_lastCharacterName = char.Name
    sp_lastRootPart = root
    sp_lastPosition = root.Position
    sp_teleportCooldown = 0
    sp_justTeleported = false
    sp_framesSinceRespawn = 999
    
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then
        sp_lastHealth = hum.Health
        sp_lastMaxHealth = hum.MaxHealth
        sp_wasAlive = hum.Health > 0
    end
    
    notify("Spawnpoint set!")
end

local function clearSpawnpoint()
    spawnPointEnabled = false
    spawnPointPosition = nil
    spawnPointCFrame = nil
    sp_lastCharacter = nil
    sp_lastCharacterName = nil
    sp_lastRootPart = nil
    sp_lastHealth = 100
    sp_lastMaxHealth = 100
    sp_wasAlive = true
    sp_lastPosition = nil
    sp_teleportCooldown = 0
    sp_justTeleported = false
    notify("Spawnpoint cleared")
end

local function doSpawnpointTeleport()
    if not spawnPointPosition then return false end
    
    local char = LocalPlayer.Character
    if not char then return false end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return false end
    
    local randX = (math.random() - 0.5) * 2
    local randZ = (math.random() - 0.5) * 2
    local offset = Vector3.new(randX, 0, randZ)
    
    pcall(function()
        root.CFrame = CFrame.new(spawnPointPosition + offset)
        root.Velocity = Vector3.new(0, 0, 0)
    end)
    
    sp_justTeleported = true
    sp_teleportCooldown = 1.5
    sp_lastPosition = spawnPointPosition + offset
    
    return true
end

local function checkSpawnpoint()
    if not spawnPointEnabled or not spawnPointPosition then return end
    
    if sp_teleportCooldown > 0 then
        sp_teleportCooldown = sp_teleportCooldown - 0.016
        return
    end
    
    local char = LocalPlayer.Character
    
    if not char then
        sp_wasAlive = false
        sp_lastCharacter = nil
        return
    end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then
        sp_wasAlive = false
        return
    end
    
    local hum = char:FindFirstChildOfClass("Humanoid")
    local currentHealth = 100
    local currentMaxHealth = 100
    
    if hum then
        currentHealth = hum.Health or 0
        currentMaxHealth = hum.MaxHealth or 100
    end
    
    local isAlive = currentHealth > 0
    local currentPosition = root.Position
    
    local shouldTeleport = false
    
    if char ~= sp_lastCharacter and sp_lastCharacter ~= nil then
        shouldTeleport = true
    end
    
    if char.Name ~= sp_lastCharacterName and sp_lastCharacterName ~= nil then
        shouldTeleport = true
    end
    
    if root ~= sp_lastRootPart and sp_lastRootPart ~= nil then
        shouldTeleport = true
    end
    
    if not sp_wasAlive and isAlive then
        shouldTeleport = true
    end
    
    if sp_lastHealth <= 0 and currentHealth >= currentMaxHealth * 0.9 then
        shouldTeleport = true
    end
    
    if sp_lastPosition and not sp_justTeleported then
        local distance = getDistance(currentPosition, sp_lastPosition)
        if distance > 100 and currentHealth >= currentMaxHealth * 0.8 then
            shouldTeleport = true
        end
    end
    
    if sp_lastMaxHealth > 0 and currentMaxHealth ~= sp_lastMaxHealth then
        if currentHealth >= currentMaxHealth * 0.9 then
            shouldTeleport = true
        end
    end
    
    if shouldTeleport then
        sp_framesSinceRespawn = 0
    end
    
    if sp_framesSinceRespawn < 60 then
        sp_framesSinceRespawn = sp_framesSinceRespawn + 1
        
        if sp_framesSinceRespawn == 15 or sp_framesSinceRespawn == 30 or sp_framesSinceRespawn == 45 then
            if doSpawnpointTeleport() then
                notify("Respawn → Spawnpoint")
            end
        end
    end
    
    sp_lastCharacter = char
    sp_lastCharacterName = char.Name
    sp_lastRootPart = root
    sp_lastHealth = currentHealth
    sp_lastMaxHealth = currentMaxHealth
    sp_wasAlive = isAlive
    
    if not sp_justTeleported then
        sp_lastPosition = currentPosition
    end
    sp_justTeleported = false
end

