local function getFilteredPanelCommands()
    local filtered = {}
    local query = string.lower(CommandPanel.searchQuery)
    
    for _, cmd in commandsForPanel do
        local matchesCategory = (CommandPanel.selectedCategory == "ALL" or cmd.cat == CommandPanel.selectedCategory)
        local matchesSearch = (query == "" or 
            string.find(string.lower(cmd.name), query, 1, true) or 
            string.find(string.lower(cmd.desc), query, 1, true))
        
        if matchesCategory and matchesSearch then
            table.insert(filtered, cmd)
        end
    end
    
    return filtered
end

