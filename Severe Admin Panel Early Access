        tabText.Color = isSelected and Theme.Primary or Theme.TextSecondary
        tabText.Outline = not isSelected
        tabText.Center = true
        tabText.Position = Vector2.new(tabX + tabWidth / 2, tabY + 11)
        table.insert(els, tabText)
    end
    
    local contentStartY = tabY + Options.TAB_H + 15
    
    -- Content based on tab
    if Options.tab == "keybinds" then
        -- Keybinds content
        local items = getOptionsFiltered()
        local maxScroll = optionsMaxScroll()
        Options.scrollOffset = math.clamp(Options.scrollOffset, 0, maxScroll)
        
        local startIdx = math.floor(Options.scrollOffset) + 1
        local endIdx = math.min(startIdx + Options.VISIBLE - 1, #items)
        
        for i = startIdx, endIdx do
            local cmd = items[i]
            local localIdx = i - startIdx
            local itemY = contentStartY + localIdx * (Options.ITEM_H + 4)
            
            local itemBg = Drawing.new("Square")
            itemBg.Visible = true
            itemBg.Filled = true
            itemBg.Color = Theme.Card
            itemBg.Rounding = 6
            itemBg.Position = Vector2.new(px + Options.PAD, itemY)
            itemBg.Size = Vector2.new(Options.W - Options.PAD * 2 - 15, Options.ITEM_H - 4)
            table.insert(els, itemBg)
            
            -- Category dot
            local dot = Drawing.new("Circle")
            dot.Visible = true
            dot.Filled = true
            dot.Color = catColor(cmd.cat)
            dot.NumSides = 12
            dot.Position = Vector2.new(px + Options.PAD + 18, itemY + Options.ITEM_H / 2 - 2)
            dot.Radius = 5
            table.insert(els, dot)
            
            -- Command name
            local cmdName = Drawing.new("Text")
            cmdName.Visible = true
            cmdName.Text = cmd.name
            cmdName.Size = 13
            cmdName.Color = Theme.TextPrimary
            cmdName.Outline = true
            cmdName.Position = Vector2.new(px + Options.PAD + 35, itemY + 10)
            table.insert(els, cmdName)
            
            -- Description
            local desc = Drawing.new("Text")
            desc.Visible = true
            desc.Text = cmd.desc
            desc.Size = 10
            desc.Color = Theme.TextSecondary
            desc.Outline = true
            desc.Position = Vector2.new(px + Options.PAD + 35, itemY + 28)
            table.insert(els, desc)
            
            -- Keybind button
            local currentKey = getKeybindForCommand(cmd.name)
            local keyText = currentKey and string.upper(currentKey) or "NONE"
            local isWaiting = (Keybinds.settingFor == cmd.name)
            if isWaiting then keyText = "..." end
            
            local keyBtnW = 70
            local keyBtnX = px + Options.W - Options.PAD - keyBtnW - 20
            
            local keyBtn = Drawing.new("Square")
            keyBtn.Visible = true
            keyBtn.Filled = true
            keyBtn.Color = isWaiting and Theme.Accent or Theme.Tertiary
            keyBtn.Rounding = 4
            keyBtn.Position = Vector2.new(keyBtnX, itemY + 12)
            keyBtn.Size = Vector2.new(keyBtnW, 28)
            table.insert(els, keyBtn)
            
            local keyLabel = Drawing.new("Text")
            keyLabel.Visible = true
            keyLabel.Text = keyText
            keyLabel.Size = 10
            keyLabel.Color = isWaiting and Theme.Primary or Theme.TextPrimary
            keyLabel.Outline = not isWaiting
            keyLabel.Center = true
            keyLabel.Position = Vector2.new(keyBtnX + keyBtnW / 2, itemY + 21)
            table.insert(els, keyLabel)
            
            table.insert(Options.keybindItems, {
                cmd = cmd,
                bounds = {pos = Vector2.new(keyBtnX, itemY + 12), size = Vector2.new(keyBtnW, 28)}
            })
        end
        
        -- Scrollbar
        if maxScroll > 0 then
            local scrollbarX = px + Options.W - Options.PAD - 8
            local scrollbarY = contentStartY
            local scrollbarH = Options.VISIBLE * (Options.ITEM_H + 4) - 4
            local thumbH = math.max(30, scrollbarH * (Options.VISIBLE / #items))
            local thumbY = scrollbarY + (Options.scrollOffset / maxScroll) * (scrollbarH - thumbH)
            
            local scrollTrack = Drawing.new("Square")
            scrollTrack.Visible = true
            scrollTrack.Filled = true
            scrollTrack.Color = Theme.Tertiary
            scrollTrack.Rounding = 3
            scrollTrack.Position = Vector2.new(scrollbarX, scrollbarY)
            scrollTrack.Size = Vector2.new(5, scrollbarH)
            table.insert(els, scrollTrack)
            
            local scrollThumb = Drawing.new("Square")
            scrollThumb.Visible = true
            scrollThumb.Filled = true
            scrollThumb.Color = Theme.Accent
            scrollThumb.Rounding = 3
            scrollThumb.Position = Vector2.new(scrollbarX, thumbY)
            scrollThumb.Size = Vector2.new(5, thumbH)
            table.insert(els, scrollThumb)
        end
        
    elseif Options.tab == "theme" then
        -- Theme presets grid
        local gridX = px + Options.PAD
        local gridY = contentStartY
        local itemW = 85
        local itemH = 50
        local gap = 10
        local cols = 6
        
        for i, preset in themePresets do
