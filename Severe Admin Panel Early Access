-- ============================================
-- PHASE (PASS THROUGH ONE WALL)
-- ============================================
local function phase()
    local char = LocalPlayer.Character
    if not char then notify("No character") return end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then notify("No HumanoidRootPart") return end
    
    local cam = workspace.CurrentCamera
    if not cam then notify("No camera") return end
    
    local lookVector = cam.CFrame.LookVector
    local startPos = root.Position
    local phaseDistance = 10
    
    local originalCollisions = {}
    for _, p in pairs(char:GetDescendants()) do
        if p:IsA("BasePart") then
            originalCollisions[p] = p.CanCollide
            p.CanCollide = false
        end
    end
    
    local targetPos = startPos + (lookVector * phaseDistance)
    
    pcall(function()
        root.CFrame = CFrame.new(targetPos) * CFrame.Angles(0, math.atan2(-lookVector.X, -lookVector.Z), 0)
        root.Velocity = Vector3.new(0, 0, 0)
    end)
    
    task.spawn(function()
        task.wait(0.1)
        for p, wasCollide in pairs(originalCollisions) do
            pcall(function()
                if p and p.Parent then
                    p.CanCollide = wasCollide
                end
            end)
        end
    end)
    
    notify("Phased through!")
end

-- ============================================
-- WALL TP (Teleport over walls when running into them)
-- ============================================
local wallTpEnabled = false
local wallTpConn = nil
local wallTpCooldown = 0
local lastWallTpPos = nil

local function checkWallInFront(root, moveDir, char)
    local checkDistance = 2.5
    local checkPoints = {
        root.Position + Vector3.new(0, 0, 0),
        root.Position + Vector3.new(0, 1, 0),
        root.Position + Vector3.new(0, -1, 0),
    }
    
    for _, checkPos in ipairs(checkPoints) do
        for _, part in ipairs(workspace:GetDescendants()) do
            if part:IsA("BasePart") and part.CanCollide and not part:IsDescendantOf(char) then
                local partMin = part.Position - (part.Size / 2)
                local partMax = part.Position + (part.Size / 2)
                
                local rayPoints = 5
                for i = 0, rayPoints do
                    local t = i / rayPoints
                    local pointOnRay = checkPos + (moveDir * checkDistance * t)
                    
                    if pointOnRay.X >= partMin.X - 0.5 and pointOnRay.X <= partMax.X + 0.5 and
                       pointOnRay.Y >= partMin.Y - 0.5 and pointOnRay.Y <= partMax.Y + 0.5 and
                       pointOnRay.Z >= partMin.Z - 0.5 and pointOnRay.Z <= partMax.Z + 0.5 then
                        return part, pointOnRay
                    end
                end
            end
        end
    end
    
    return nil, nil
end

local function wallTpOn()
    if wallTpConn then return end
    wallTpEnabled = true
    wallTpCooldown = 0
    lastWallTpPos = nil
    
    wallTpConn = RunService.Render:Connect(function(dt)
        if not wallTpEnabled then return end
        
        if wallTpCooldown > 0 then
            wallTpCooldown = wallTpCooldown - dt
            return
        end
        
        pcall(function()
            local char = LocalPlayer.Character
            if not char then return end
            
            local root = char:FindFirstChild("HumanoidRootPart")
            if not root then return end
            
            local hum = char:FindFirstChildOfClass("Humanoid")
            if not hum then return end
            
            local moveDir = hum.MoveDirection
            if moveDir.Magnitude < 0.3 then return end
            
            moveDir = Vector3.new(moveDir.X, 0, moveDir.Z).Unit
            
            local vel = root.Velocity
            local horizontalVel = Vector3.new(vel.X, 0, vel.Z).Magnitude
            local expectedSpeed = hum.WalkSpeed * 0.5
            
            if horizontalVel > expectedSpeed then 
                lastWallTpPos = root.Position
                return 
            end
            
            local wallPart, hitPos = checkWallInFront(root, moveDir, char)
            
            if wallPart then
                if lastWallTpPos then
                    local distFromLast = getDistance(root.Position, lastWallTpPos)
                    if distFromLast < 3 then return end
                end
                
                local wallTop = wallPart.Position.Y + (wallPart.Size.Y / 2)
                local heightNeeded = wallTop - root.Position.Y + 4
                
                if heightNeeded > 30 then
                    heightNeeded = 30
                end
                
                if heightNeeded < 1 then return end
                
                local newPos = root.Position + (moveDir * 3) + Vector3.new(0, heightNeeded, 0)
                
                root.CFrame = CFrame.new(newPos)
                root.Velocity = Vector3.new(moveDir.X * 20, 5, moveDir.Z * 20)
                
                lastWallTpPos = newPos
                wallTpCooldown = 0.4
            end
        end)
    end)
    
    notify("WallTP enabled")
end

local function wallTpOff()
    wallTpEnabled = false
    lastWallTpPos = nil
    if wallTpConn then
        wallTpConn:Disconnect()
        wallTpConn = nil
    end
    notify("WallTP disabled")
end

