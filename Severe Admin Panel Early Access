local function notify(msg)
    pcall(function() send_notification(tostring(msg)) end)
end

local function inRect(p, pos, size)
    return p.X >= pos.X and p.X <= pos.X + size.X and p.Y >= pos.Y and p.Y <= pos.Y + size.Y
end

local function catColor(cat)
    if cat == "Movement" or cat == "MOVEMENT" then return Theme.Movement
    elseif cat == "Visual" or cat == "VISUALS" then return Theme.Visual
    elseif cat == "Teleport" or cat == "TELEPORT" then return Theme.Teleport
    elseif cat == "Utility" or cat == "ETC" then return Theme.Utility
    elseif cat == "Fun" or cat == "FUN" then return Theme.Fun
    else return Theme.TextMuted end
end

local function isKey(key, ...)
    local k = string.lower(key)
    for _, v in {...} do 
        if string.find(k, v, 1, true) then return true end 
    end
    return false
end

