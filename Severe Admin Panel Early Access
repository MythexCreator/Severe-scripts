    logoRing.Visible = true
    logoRing.Filled = false
    logoRing.Color = Theme.Accent
    logoRing.NumSides = 24
    logoRing.Thickness = 3
    logoRing.Position = Vector2.new(px + 30, py + Options.HEADER / 2)
    logoRing.Radius = 14
    table.insert(els, logoRing)
    
    local logoT = Drawing.new("Text")
    logoT.Visible = true
    logoT.Text = "S"
    logoT.Size = 16
    logoT.Color = Theme.Accent
    logoT.Outline = true
    logoT.Center = true
    logoT.Position = Vector2.new(px + 30, py + Options.HEADER / 2 - 8)
    table.insert(els, logoT)
    
