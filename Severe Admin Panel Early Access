        local isSelected = Options.tab == tab.id
        
        local tabBg = Drawing.new("Square")
        tabBg.Visible = true
        tabBg.Filled = true
        tabBg.Color = isSelected and Theme.Accent or Theme.Secondary
        tabBg.Rounding = 6
        tabBg.Position = Vector2.new(tabX, tabY)
