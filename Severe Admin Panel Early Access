-- ============================================
-- ANTI FLING (POSITION-BASED)
-- ============================================
local antiFlingEnabled = false
local antiFlingConn = nil

local MAX_SPEED = 100
local SAFE_UPDATE_SPEED = 50
local FREEZE_DURATION = 15

local af_safePosition = nil
local af_safeCFrame = nil
local af_lastPosition = nil
local af_lastTime = 0
local af_freezeFrames = 0

local function antiFlingOn()
    if antiFlingConn then return end
    antiFlingEnabled = true
    
    af_safePosition = nil
    af_safeCFrame = nil
    af_lastPosition = nil
    af_lastTime = os.clock()
    af_freezeFrames = 0
    
    pcall(function()
        local char = LocalPlayer.Character
        if char then
            local root = char:FindFirstChild("HumanoidRootPart")
            if root then
                af_safeCFrame = root.CFrame
                af_safePosition = root.Position
                af_lastPosition = root.Position
            end
        end
    end)
    
    antiFlingConn = RunService.Render:Connect(function()
        if not antiFlingEnabled then return end
        
        pcall(function()
            local char = LocalPlayer.Character
            if not char then return end
            
            local root = char:FindFirstChild("HumanoidRootPart")
            if not root then return end
            
            local currentTime = os.clock()
            local dt = currentTime - af_lastTime
            af_lastTime = currentTime
            
            if dt <= 0 or dt > 1 then
                af_lastPosition = root.Position
                return
            end
            
            local currentPos = root.Position
            
            if af_freezeFrames > 0 then
                af_freezeFrames = af_freezeFrames - 1
                if af_safeCFrame then
                    root.CFrame = af_safeCFrame
                end
                af_lastPosition = af_safePosition or currentPos
                return
            end
            
            if af_lastPosition then
                local dx = currentPos.X - af_lastPosition.X
                local dy = currentPos.Y - af_lastPosition.Y
                local dz = currentPos.Z - af_lastPosition.Z
                local distance = math.sqrt(dx*dx + dy*dy + dz*dz)
                local speed = distance / dt
                
                if speed > MAX_SPEED and distance > 5 then
                    if af_safeCFrame then
                        root.CFrame = af_safeCFrame
                    elseif af_safePosition then
                        root.CFrame = CFrame.new(af_safePosition)
                    end
                    
                    af_freezeFrames = FREEZE_DURATION
                    af_lastPosition = af_safePosition or currentPos
                    return
                end
                
                if speed < SAFE_UPDATE_SPEED then
                    af_safeCFrame = root.CFrame
                    af_safePosition = root.Position
                end
            end
            
            af_lastPosition = currentPos
        end)
    end)
    
    notify("Anti-fling enabled")
end

local function antiFlingOff()
    antiFlingEnabled = false
    af_safePosition = nil
    af_safeCFrame = nil
    af_lastPosition = nil
    af_freezeFrames = 0
    
    if antiFlingConn then
        antiFlingConn:Disconnect()
        antiFlingConn = nil
    end
    notify("Anti-fling disabled")
end

