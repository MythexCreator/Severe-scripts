            local indicator = Drawing.new("Square")
            indicator.Visible = true
            indicator.Filled = true
            indicator.Color = Theme.Accent
            indicator.Rounding = 2
            indicator.Position = Vector2.new(sidebarX + 8, catY + 7)
            indicator.Size = Vector2.new(3, 20)
            table.insert(els, indicator)
        end
        
        -- Category dot
        local dot = Drawing.new("Circle")
        dot.Visible = true
        dot.Filled = true
        dot.Color = category.color
        dot.NumSides = 12
        dot.Position = Vector2.new(sidebarX + 24, catY + 17)
        dot.Radius = 4
        table.insert(els, dot)
        
        -- Category name
        local catLabel = Drawing.new("Text")
        catLabel.Visible = true
        catLabel.Text = category.name
        catLabel.Size = 11
        catLabel.Color = isSelected and Theme.TextPrimary or Theme.TextSecondary
        catLabel.Outline = true
        catLabel.Position = Vector2.new(sidebarX + 38, catY + 10)
        table.insert(els, catLabel)
        
        catY = catY + 40
    end
    
    -- Content area
    local contentX = px + SIDEBAR_W + PAD
    local contentY = py + HEADER_H + PAD
    local contentW = W - SIDEBAR_W - PAD * 2 - 10
    local contentH = H - HEADER_H - FOOTER_H - PAD * 2
    
    -- Get filtered commands
    local filtered = getFilteredPanelCommands()
    local maxScroll = math.max(0, #filtered - CommandPanelDrawing.maxVisible)
    CommandPanelDrawing.scrollOffset = math.clamp(CommandPanelDrawing.scrollOffset, 0, maxScroll)
    
    local startIdx = math.floor(CommandPanelDrawing.scrollOffset) + 1
    local endIdx = math.min(startIdx + CommandPanelDrawing.maxVisible - 1, #filtered)
    
    CommandPanelDrawing.itemBounds = {}
    
    for i = startIdx, endIdx do
        local cmd = filtered[i]
        local localIdx = i - startIdx
        local itemY = contentY + localIdx * (ITEM_H + 6)
        
        -- Item background
        local itemBg = Drawing.new("Square")
        itemBg.Visible = true
        itemBg.Filled = true
        itemBg.Color = Theme.Card
        itemBg.Rounding = 6
        itemBg.Position = Vector2.new(contentX, itemY)
        itemBg.Size = Vector2.new(contentW, ITEM_H)
        table.insert(els, itemBg)
        
        table.insert(CommandPanelDrawing.itemBounds, {
            pos = Vector2.new(contentX, itemY),
            size = Vector2.new(contentW, ITEM_H),
            cmd = cmd
        })
        
        -- Category tag
        local tagW = 70
        local tagBg = Drawing.new("Square")
        tagBg.Visible = true
        tagBg.Filled = true
        tagBg.Color = catColor(cmd.cat)
        tagBg.Rounding = 4
        tagBg.Position = Vector2.new(contentX + 10, itemY + 8)
        tagBg.Size = Vector2.new(tagW, 18)
        table.insert(els, tagBg)
        
        local tagText = Drawing.new("Text")
        tagText.Visible = true
        tagText.Text = cmd.cat
        tagText.Size = 9
        tagText.Color = Theme.TextPrimary
        tagText.Outline = true
        tagText.Center = true
        tagText.Position = Vector2.new(contentX + 10 + tagW / 2, itemY + 11)
        table.insert(els, tagText)
        
        -- Command name
        local cmdName = Drawing.new("Text")
        cmdName.Visible = true
        cmdName.Text = ";" .. cmd.name
        cmdName.Size = 13
        cmdName.Color = Theme.Accent
        cmdName.Outline = true
        cmdName.Position = Vector2.new(contentX + tagW + 20, itemY + 10)
        table.insert(els, cmdName)
        
        -- Description
        local desc = Drawing.new("Text")
        desc.Visible = true
        desc.Text = cmd.desc
        desc.Size = 11
        desc.Color = Theme.TextSecondary
        desc.Outline = true
        desc.Position = Vector2.new(contentX + 10, itemY + 32)
        table.insert(els, desc)
    end
    
    -- Scrollbar
    if maxScroll > 0 then
        local scrollbarX = px + W - 18
        local scrollbarY = contentY
        local scrollbarH = contentH
        local thumbH = math.max(30, scrollbarH * (CommandPanelDrawing.maxVisible / #filtered))
        local thumbY = scrollbarY + (CommandPanelDrawing.scrollOffset / maxScroll) * (scrollbarH - thumbH)
        
        local scrollTrack = Drawing.new("Square")
        scrollTrack.Visible = true
        scrollTrack.Filled = true
        scrollTrack.Color = Theme.Tertiary
        scrollTrack.Rounding = 3
        scrollTrack.Position = Vector2.new(scrollbarX, scrollbarY)
        scrollTrack.Size = Vector2.new(6, scrollbarH)
        table.insert(els, scrollTrack)
        
        local scrollThumb = Drawing.new("Square")
        scrollThumb.Visible = true
        scrollThumb.Filled = true
        scrollThumb.Color = Theme.Accent
        scrollThumb.Rounding = 3
        scrollThumb.Position = Vector2.new(scrollbarX, thumbY)
        scrollThumb.Size = Vector2.new(6, thumbH)
        table.insert(els, scrollThumb)
        
        CommandPanelDrawing.scrollBounds = {
            pos = Vector2.new(scrollbarX, scrollbarY),
            size = Vector2.new(6, scrollbarH),
            thumbH = thumbH
        }
    end
    
    -- Footer
    local footerY = py + H - FOOTER_H
    
    local footerLine = Drawing.new("Square")
    footerLine.Visible = true
    footerLine.Filled = true
    footerLine.Color = Theme.Border
    footerLine.Position = Vector2.new(px + PAD, footerY)
    footerLine.Size = Vector2.new(W - PAD * 2, 1)
    table.insert(els, footerLine)
    
    local cmdCount = Drawing.new("Text")
    cmdCount.Visible = true
    cmdCount.Text = #filtered .. " commands"
    cmdCount.Size = 10
    cmdCount.Color = Theme.TextMuted
    cmdCount.Outline = true
    cmdCount.Position = Vector2.new(px + PAD + 5, footerY + 12)
    table.insert(els, cmdCount)
    
    local hint = Drawing.new("Text")
    hint.Visible = true
    hint.Text = "ESC to close • UP/DOWN to scroll"
    hint.Size = 10
    hint.Color = Theme.TextMuted
    hint.Outline = true
    hint.Position = Vector2.new(px + W - 200, footerY + 12)
    table.insert(els, hint)
end

local function showCommandPanel()
    if CommandPanel.open then return end
    CommandPanel.open = true
    CommandPanel.selectedCategory = "ALL"
    CommandPanel.searchQuery = ""
    CommandPanel.searchFocused = false
    CommandPanelDrawing.scrollOffset = 0
    createCommandPanelDrawing()
end

local function hideCommandPanel()
    if not CommandPanel.open then return end
    CommandPanel.open = false
    CommandPanel.searchFocused = false
    clearCommandPanelDrawing()
end

toggleCommandPanel = function()
    if CommandPanel.open then
        hideCommandPanel()
    else
        showCommandPanel()
    end
end

