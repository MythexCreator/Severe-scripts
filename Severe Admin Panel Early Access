local function tpToPlayer(name)
    local char = LocalPlayer.Character
    if not char then notify("No character") return end
    local target = findPlayer(name)
    if not target then notify("Player not found: " .. name) return end
    local tChar = target.Character
    if not tChar then notify("Target has no character") return end
    local root = tChar:FindFirstChild("HumanoidRootPart")
    if not root then return end
    Teleport.target = root.Position + Vector3.new(0, 3, 0)
    Teleport.frames = 10
    notify("Teleporting to " .. target.Name)
end

local function gotoPos(x, y, z)
    Teleport.target = Vector3.new(x, y, z)
    Teleport.frames = 10
    notify("Teleporting to " .. x .. ", " .. y .. ", " .. z)
end

local function goToSpawn()
    local char = LocalPlayer.Character
    if not char then notify("No character") return end
    Teleport.target = getSpawnLocation()
    Teleport.frames = 10
    notify("Teleporting to spawn")
end

local function noclipOn()
    if Features.noclipEnabled then return end
    Features.noclipEnabled = true
    notify("Noclip enabled")
end

local function noclipOff()
    Features.noclipEnabled = false
    notify("Noclip disabled")
end

local function updateNoclip()
    if not Features.noclipEnabled then return end
    pcall(function()
        local char = LocalPlayer.Character
        if not char then return end
        for _, p in char:GetDescendants() do
            if p:IsA("BasePart") and p.CanCollide then p.CanCollide = false end
        end
    end)
end

local function infJumpOn()
    if Features.infJumpEnabled then return end
    Features.infJumpEnabled = true
    notify("Infinite Jump enabled")
end

local function infJumpOff()
    Features.infJumpEnabled = false
    Features.lastSpaceInf = false
    notify("Infinite Jump disabled")
end

local function updateInfJump()
    if not Features.infJumpEnabled then return end
    pcall(function()
        local char = LocalPlayer.Character
        if not char then return end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then return end
        local keys = getpressedkeys()
        local space = false
        for _, k in keys do
            if string.find(string.lower(k), "space") then space = true break end
        end
        if space and not Features.lastSpaceInf then
            local vel = root.Velocity
            root.Velocity = Vector3.new(vel.X, 60, vel.Z)
        end
        Features.lastSpaceInf = space
    end)
end

local function writeFovDirect(value)
    pcall(function()
        local cam = workspace.CurrentCamera
        if cam then memory.writef32(cam, 0x160, math.rad(value)) end
    end)
end

local function setFov(value)
    local num = tonumber(value)
    if not num then notify("Invalid FOV value") return end
    num = math.clamp(num, 1, 120)
    Features.currentFovValue = num
    Features.fovEnabled = true
    for _ = 1, 5 do writeFovDirect(num) end
    notify("FOV set to " .. num)
end

local function resetFov()
    Features.currentFovValue = nil
    Features.fovEnabled = false
    for _ = 1, 5 do writeFovDirect(Features.defaultFov) end
    notify("FOV reset to " .. Features.defaultFov)
end

local function updateFov()
    if not Features.fovEnabled or not Features.currentFovValue then return end
    writeFovDirect(Features.currentFovValue)
end

local function antiVoidOn()
    if Features.antiVoidEnabled then return end
    Features.antiVoidEnabled = true
    Features.antiVoidCooldown = 0
    notify("Anti-void enabled")
end

local function antiVoidOff()
    Features.antiVoidEnabled = false
    notify("Anti-void disabled")
end

local function updateAntiVoid()
    if not Features.antiVoidEnabled then return end
    if Features.antiVoidCooldown > 0 then
        Features.antiVoidCooldown = Features.antiVoidCooldown - 0.016
        return
    end
    pcall(function()
        local char = LocalPlayer.Character
        if not char then return end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then return end
        if root.Position.Y < Features.voidThreshold then
            root.CFrame = CFrame.new(getSpawnLocation())
            root.Velocity = Vector3.new(0, 0, 0)
            Features.antiVoidCooldown = 2
            notify("Anti-void: Teleported to spawn!")
        end
    end)
end

local function specOn(name)
    local player = findPlayer(name)
    if not player then notify("Player not found: " .. name) return end
    if player == LocalPlayer then notify("Cannot view yourself") return end
    local char = player.Character
    if not char then notify("Target has no character") return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then notify("Target has no humanoid") return end
    Features.specPlayer = player
    pcall(function()
        local cam = workspace.CurrentCamera
        if cam then cam.CameraSubject = hum end
    end)
    notify("Viewing " .. player.Name)
end

local function specOff()
    Features.specPlayer = nil
    pcall(function()
        local cam = workspace.CurrentCamera
        local char = LocalPlayer.Character
        if cam and char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then cam.CameraSubject = hum end
        end
    end)
    notify("Stopped viewing")
end

local function checkSpec()
    if not Features.specPlayer then return end
    if not Features.specPlayer.Parent then specOff() return end
    local char = Features.specPlayer.Character
    if not char or not char:FindFirstChildOfClass("Humanoid") then specOff() end
end

local function diedTpOn()
    if DiedTp.enabled then return end
    DiedTp.enabled = true
    DiedTp.lastHealth = 100
    DiedTp.lastPos = nil
    DiedTp.deathPos = nil
    DiedTp.wasDead = false
    DiedTp.cooldown = 0
    notify("DiedTP enabled")
end

local function diedTpOff()
    DiedTp.enabled = false
    DiedTp.deathPos = nil
    DiedTp.wasDead = false
    notify("DiedTP disabled")
end

local function updateDiedTp(dt)
    if not DiedTp.enabled then return end
    if DiedTp.cooldown > 0 then DiedTp.cooldown = DiedTp.cooldown - dt return end
    pcall(function()
        local char = LocalPlayer.Character
        if not char then DiedTp.wasDead = true return end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then DiedTp.wasDead = true return end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum then return end
        local currentHealth = hum.Health
        if currentHealth > 0 then DiedTp.lastPos = root.Position end
        if DiedTp.lastHealth > 0 and currentHealth <= 0 then
            if DiedTp.lastPos then DiedTp.deathPos = DiedTp.lastPos end
            DiedTp.wasDead = true
        end
        if DiedTp.wasDead and currentHealth > 0 and DiedTp.deathPos then
            root.CFrame = CFrame.new(DiedTp.deathPos + Vector3.new(0, 3, 0))
            root.Velocity = Vector3.new(0, 0, 0)
            notify("But it refused.")
            DiedTp.wasDead = false
            DiedTp.cooldown = 2
        end
        DiedTp.lastHealth = currentHealth
    end)
end

local function setSpawnpoint()
    local char = LocalPlayer.Character
    if not char then notify("No character") return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then notify("No HumanoidRootPart") return end
    Spawnpoint.cframe = root.CFrame
    Spawnpoint.position = root.Position + Vector3.new(0, 0.5, 0)
    Spawnpoint.enabled = true
    Spawnpoint.lastCharacter = char
    Spawnpoint.lastCharacterName = char.Name
    Spawnpoint.lastRootPart = root
    Spawnpoint.lastPosition = root.Position
    Spawnpoint.teleportCooldown = 0
    Spawnpoint.justTeleported = false
    Spawnpoint.framesSinceRespawn = 999
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then
        Spawnpoint.lastHealth = hum.Health
        Spawnpoint.lastMaxHealth = hum.MaxHealth
        Spawnpoint.wasAlive = hum.Health > 0
    end
    notify("Spawnpoint set!")
end

local function clearSpawnpoint()
    Spawnpoint.enabled = false
    Spawnpoint.position = nil
    Spawnpoint.cframe = nil
    Spawnpoint.lastCharacter = nil
    Spawnpoint.lastCharacterName = nil
    Spawnpoint.lastRootPart = nil
    Spawnpoint.lastHealth = 100
    Spawnpoint.lastMaxHealth = 100
    Spawnpoint.wasAlive = true
    Spawnpoint.lastPosition = nil
    Spawnpoint.teleportCooldown = 0
    Spawnpoint.justTeleported = false
    notify("Spawnpoint cleared")
end

local function doSpawnpointTeleport()
    if not Spawnpoint.position then return false end
    local char = LocalPlayer.Character
    if not char then return false end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return false end
    local offset = Vector3.new((math.random() - 0.5) * 2, 0, (math.random() - 0.5) * 2)
    pcall(function()
        root.CFrame = CFrame.new(Spawnpoint.position + offset)
        root.Velocity = Vector3.new(0, 0, 0)
    end)
    Spawnpoint.justTeleported = true
    Spawnpoint.teleportCooldown = 1.5
    Spawnpoint.lastPosition = Spawnpoint.position + offset
    return true
end

local function checkSpawnpoint()
    if not Spawnpoint.enabled or not Spawnpoint.position then return end
    if Spawnpoint.teleportCooldown > 0 then
        Spawnpoint.teleportCooldown = Spawnpoint.teleportCooldown - 0.016
        return
    end
    local char = LocalPlayer.Character
    if not char then Spawnpoint.wasAlive = false Spawnpoint.lastCharacter = nil return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then Spawnpoint.wasAlive = false return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    local currentHealth = hum and hum.Health or 100
    local currentMaxHealth = hum and hum.MaxHealth or 100
    local isAlive = currentHealth > 0
    local currentPosition = root.Position
    local shouldTeleport = false
    
    if char ~= Spawnpoint.lastCharacter and Spawnpoint.lastCharacter ~= nil then shouldTeleport = true end
    if char.Name ~= Spawnpoint.lastCharacterName and Spawnpoint.lastCharacterName ~= nil then shouldTeleport = true end
    if root ~= Spawnpoint.lastRootPart and Spawnpoint.lastRootPart ~= nil then shouldTeleport = true end
    if not Spawnpoint.wasAlive and isAlive then shouldTeleport = true end
    if Spawnpoint.lastHealth <= 0 and currentHealth >= currentMaxHealth * 0.9 then shouldTeleport = true end
    if Spawnpoint.lastPosition and not Spawnpoint.justTeleported then
        local distance = (currentPosition - Spawnpoint.lastPosition).Magnitude
        if distance > 100 and currentHealth >= currentMaxHealth * 0.8 then shouldTeleport = true end
    end
    if Spawnpoint.lastMaxHealth > 0 and currentMaxHealth ~= Spawnpoint.lastMaxHealth then
        if currentHealth >= currentMaxHealth * 0.9 then shouldTeleport = true end
    end
    
    if shouldTeleport then Spawnpoint.framesSinceRespawn = 0 end
    if Spawnpoint.framesSinceRespawn < 60 then
        Spawnpoint.framesSinceRespawn = Spawnpoint.framesSinceRespawn + 1
        if Spawnpoint.framesSinceRespawn == 15 or Spawnpoint.framesSinceRespawn == 30 or Spawnpoint.framesSinceRespawn == 45 then
            if doSpawnpointTeleport() then notify("Respawn → Spawnpoint") end
        end
    end
    
    Spawnpoint.lastCharacter = char
    Spawnpoint.lastCharacterName = char.Name
    Spawnpoint.lastRootPart = root
    Spawnpoint.lastHealth = currentHealth
    Spawnpoint.lastMaxHealth = currentMaxHealth
    Spawnpoint.wasAlive = isAlive
    if not Spawnpoint.justTeleported then Spawnpoint.lastPosition = currentPosition end
    Spawnpoint.justTeleported = false
end

local function savePos(slot)
    local slotNum = math.clamp(tonumber(slot) or 1, 1, 9)
    local char = LocalPlayer.Character
    if not char then notify("No character") return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then notify("No HumanoidRootPart") return end
    Teleport.savedPositions[slotNum] = {cframe = root.CFrame, position = root.Position}
    notify("Position saved to slot " .. slotNum)
end

local function loadPos(slot)
    local slotNum = math.clamp(tonumber(slot) or 1, 1, 9)
    local saved = Teleport.savedPositions[slotNum]
    if not saved then notify("No position saved in slot " .. slotNum) return end
    local char = LocalPlayer.Character
    if not char then notify("No character") return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then notify("No HumanoidRootPart") return end
    pcall(function()
        root.CFrame = saved.cframe
        root.Velocity = Vector3.new(0, 0, 0)
    end)
    notify("Loaded position from slot " .. slotNum)
end

local function initWorldPtr()
    if Gravity.worldPtr then return true end
    pcall(function() Gravity.worldPtr = memory.readu64(workspace, Gravity.workspaceToWorldOffset) end)
    return Gravity.worldPtr ~= nil
end

local function setGravity(value)
    local num = tonumber(value)
    if not num then notify("Invalid gravity value") return end
    if not initWorldPtr() then notify("Failed to get world pointer") return end
    pcall(function() memory.writef32(Gravity.worldPtr, Gravity.offset, num) end)
    notify("Gravity set to " .. num)
end

local function resetGravity()
    if not initWorldPtr() then notify("Failed to get world pointer") return end
    pcall(function() memory.writef32(Gravity.worldPtr, Gravity.offset, Gravity.default) end)
    notify("Gravity reset to " .. Gravity.default)
end

local function forceReset()
    local char = LocalPlayer.Character
    if not char then notify("No character") return end
    local success = false
    pcall(function()
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then memory.writef32(hum, 0x194, 0) success = true end
    end)
    if not success then
        pcall(function()
            local root = char:FindFirstChild("HumanoidRootPart")
            if root then root.CFrame = CFrame.new(0, -500, 0) success = true end
        end)
    end
    if success then notify("Force reset!") else notify("Force reset failed") end
end

local function getUserId(name)
    if not name then
        local userId = LocalPlayer.UserId
        pcall(function() setclipboard(tostring(userId)) end)
        notify("Your UserId: " .. userId .. " (copied)")
        return
    end
    local player = findPlayer(name)
    if not player then notify("Player not found: " .. name) return end
    local userId = player.UserId
    pcall(function() setclipboard(tostring(userId)) end)
    notify(player.Name .. "'s UserId: " .. userId .. " (copied)")
end

