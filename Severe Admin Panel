local function updateStatusBar()
    clearStatusBar()
    
    if not Settings.statusBarEnabled then return end
    if CommandPanel.open or Bar.open or Options.open or ServerInfo.open then return end
    if not State.introComplete then return end
    
    local features = getActiveFeatures()
    if #features == 0 then return end
    
    local cam = workspace.CurrentCamera
    if not cam then return end
    
    local vw, vh = cam.ViewportSize.X, cam.ViewportSize.Y
    local padding = 10
    local gap = 6
    local itemH = 24
    
    local isRight = string_find(Settings.statusBarCorner, "right")
    local isBottom = string_find(Settings.statusBarCorner, "bottom")
    local isVertical = Settings.statusBarOrientation == "vertical"
    
    local totalW, totalH = 0, 0
    if isVertical then
        for _, feature in features do
            local itemW = math.max(#feature.name * 6 + 20, 60)
            totalW = math.max(totalW, itemW)
        end
        totalH = #features * (itemH + gap) - gap
    else
        for _, feature in features do
            local itemW = math.max(#feature.name * 6 + 20, 60)
            totalW = totalW + itemW + gap
        end
        totalW = totalW - gap
        totalH = itemH
    end
    
    local startX, startY
    if isRight then startX = vw - padding - totalW else startX = padding end
    if isBottom then startY = vh - padding - totalH else startY = padding end
    
    local barX, barY = startX, startY
    
    for _, feature in features do
        local itemW = math.max(#feature.name * 6 + 20, 60)
        
        local bg = Drawing.new("Square")
        bg.Visible = true
        bg.Filled = true
        bg.Color = Theme.Secondary
        bg.Rounding = 4
        bg.Opacity = 0.9
        bg.Position = Vector2.new(barX, barY)
        bg.Size = Vector2.new(itemW, itemH)
        table_insert(StatusBar.elements, bg)
        
        local accentBar = Drawing.new("Square")
        accentBar.Visible = true
        accentBar.Filled = true
        accentBar.Color = feature.color
        accentBar.Rounding = 4
        accentBar.Position = Vector2.new(barX, barY)
        accentBar.Size = Vector2.new(3, itemH)
        table_insert(StatusBar.elements, accentBar)
        
        local text = Drawing.new("Text")
        text.Visible = true
        text.Text = feature.name
        text.Size = 10
        text.Color = Theme.TextPrimary
        text.Outline = true
        text.Position = Vector2.new(barX + 10, barY + 6)
        table_insert(StatusBar.elements, text)
        
        if isVertical then barY = barY + itemH + gap else barX = barX + itemW + gap end
    end
end

