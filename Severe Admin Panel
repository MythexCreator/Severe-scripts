}

local function getFiltered()
    local r = {}
    local q = searchQuery:lower()
    for _, c in ipairs(commands) do
        if q == "" or c.name:lower():find(q, 1, true) or c.desc:lower():find(q, 1, true) then
            table.insert(r, c)
        end
    end
    return r
end

local function maxScroll()
    return math.max(0, #getFiltered() - VISIBLE)
end

local function runCmd(input)
    input = input:gsub(";", ""):gsub("^%s+", ""):gsub("%s+$", "")
    local parts = {}
    for p in input:gmatch("%S+") do table.insert(parts, p) end
    if #parts == 0 then return false end
    
    local name = parts[1]:lower()
    table.remove(parts, 1)
    
    for _, c in ipairs(commands) do
        if c.name == name then
            c.fn(parts)
            return true
        end
    end
    notify("Unknown: " .. name)
    return false
end

