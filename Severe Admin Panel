-- Admin Panel for Severe
-- Press ; to open command bar

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local LocalPlayer = Players.LocalPlayer

-- ============================================
-- TELEPORT SYSTEM
-- ============================================
local teleportTarget = nil
local teleportFrames = 0
local TELEPORT_HOLD_FRAMES = 10

local function findPlayer(playerName)
    playerName = playerName:lower()
    
    for _, player in ipairs(Players:GetChildren()) do
        if player:IsA("Player") and player.Name:lower() == playerName then
            return player
        end
    end
    
    for _, player in ipairs(Players:GetChildren()) do
        if player:IsA("Player") and player.DisplayName:lower() == playerName then
            return player
        end
    end
    
    for _, player in ipairs(Players:GetChildren()) do
        if player:IsA("Player") and player.Name:lower():find(playerName) then
            return player
        end
    end
    
    for _, player in ipairs(Players:GetChildren()) do
        if player:IsA("Player") and player.DisplayName:lower():find(playerName) then
            return player
        end
    end
    
    return nil
end

local function teleportToPlayer(playerName)
    local character = LocalPlayer.Character
    if not character then return end
    
    local targetPlayer = findPlayer(playerName)
    if not targetPlayer then return end
    
    local targetChar = targetPlayer.Character
    if not targetChar then return end
    
    local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
    if not targetRoot then return end
    
    local targetPos = targetRoot.Position
    teleportTarget = Vector3.new(targetPos.X, targetPos.Y + 3, targetPos.Z)
    teleportFrames = TELEPORT_HOLD_FRAMES
end

-- ============================================
-- NOCLIP SYSTEM
-- ============================================
local noclipEnabled = false
local noclipConnection = nil

local function enableNoclip()
    if noclipConnection then return end
    
    noclipConnection = RunService.Render:Connect(function()
        local character = LocalPlayer.Character
        if not character then return end
        
        for _, part in pairs(character:GetDescendants()) do
            if part:IsA("BasePart") and part.CanCollide then
                part.CanCollide = false
            end
        end
    end)
    
    noclipEnabled = true
end

local function disableNoclip()
    if noclipConnection then
        noclipConnection:Disconnect()
        noclipConnection = nil
    end
    noclipEnabled = false
end

-- ============================================
-- INFINITE JUMP SYSTEM
-- ============================================
local infJumpEnabled = false
local infJumpConnection = nil
local lastSpaceState = false

local function enableInfJump()
    if infJumpConnection then return end
    
    infJumpConnection = RunService.Render:Connect(function()
        local character = LocalPlayer.Character
        if not character then return end
        
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        if not rootPart then return end
        
        local spacePressed = false
        pcall(function()
            local keys = getpressedkeys()
            for _, key in ipairs(keys) do
                if key:lower() == "space" then
                    spacePressed = true
                    break
                end
            end
        end)
        
        if spacePressed and not lastSpaceState then
            rootPart.Velocity = Vector3.new(rootPart.Velocity.X, 60, rootPart.Velocity.Z)
        end
        
        lastSpaceState = spacePressed
    end)
    
    infJumpEnabled = true
end

local function disableInfJump()
    if infJumpConnection then
        infJumpConnection:Disconnect()
        infJumpConnection = nil
    end
    infJumpEnabled = false
    lastSpaceState = false
end

-- ============================================
-- GOTO SYSTEM
-- ============================================
local function gotoPosition(x, y, z)
    teleportTarget = Vector3.new(x, y, z)
    teleportFrames = TELEPORT_HOLD_FRAMES
end

-- ============================================
-- GUI SYSTEM
-- ============================================
local guiOpen = false
local guiElements = {}
local searchQuery = ""
local scrollOffset = 0
local searchFocused = false
local searchBarPos, searchBarSize = nil, nil

local function clearGUI()
    for _, element in ipairs(guiElements) do
        pcall(function() element:Remove() end)
    end
    guiElements = {}
end

local function toggleGUI() end

-- ============================================
-- COMMANDS
-- ============================================
local commands = {
    { name = "noclip", description = "Walk through walls", usage = ";noclip", category = "Movement", func = function() enableNoclip() end },
    { name = "unnoclip", description = "Disable noclip", usage = ";unnoclip", category = "Movement", func = function() disableNoclip() end },
    { name = "infjump", description = "Enable infinite jump", usage = ";infjump", category = "Movement", func = function() enableInfJump() end },
    { name = "uninfjump", description = "Disable infinite jump", usage = ";uninfjump", category = "Movement", func = function() disableInfJump() end },
    { name = "tp", description = "Teleport to player", usage = ";tp [player]", category = "Teleport", func = function(args) if args[1] then teleportToPlayer(args[1]) end end },
    { name = "goto", description = "Teleport to coords", usage = ";goto [x] [y] [z]", category = "Teleport", func = function(args) gotoPosition(tonumber(args[1]) or 0, tonumber(args[2]) or 100, tonumber(args[3]) or 0) end },
    { name = "cmds", description = "Open command panel", usage = ";cmds", category = "Utility", func = function() toggleGUI() end },
}

local function executeCommand(input)
    input = input:gsub(";", ""):gsub("^%s+", ""):gsub("%s+$", "")
    local parts = {}
    for part in input:gmatch("%S+") do table.insert(parts, part) end
    if #parts == 0 then return false end
    
    local cmdName = parts[1]:lower()
    table.remove(parts, 1)
    
    for _, cmd in ipairs(commands) do
        if cmd.name == cmdName then
            cmd.func(parts)
            return true
        end
    end
    return false
end

