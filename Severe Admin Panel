    if not specPlayer.Parent then specOff() return end
    local char = specPlayer.Character
    if not char or not char:FindFirstChildOfClass("Humanoid") then specOff() end
end

-- ============================================
-- ANTI VOID (Teleports to spawn)
-- ============================================
local antiVoidConn = nil
local antiVoidEnabled = false
local voidThreshold = -150
local antiVoidCooldown = 0

local function antiVoidOn()
    if antiVoidConn then return end
    antiVoidEnabled = true
    antiVoidCooldown = 0
    
    antiVoidConn = RunService.Render:Connect(function()
        if not antiVoidEnabled then return end
        
        if antiVoidCooldown > 0 then
            antiVoidCooldown = antiVoidCooldown - 0.016
            return
        end
        
        pcall(function()
            local char = LocalPlayer.Character
            if not char then return end
            
            local root = char:FindFirstChild("HumanoidRootPart")
            if not root then return end
            
            if root.Position.Y < voidThreshold then
                local spawnPos = findSpawnLocation()
                root.CFrame = CFrame.new(spawnPos)
                root.Velocity = Vector3.new(0, 0, 0)
                antiVoidCooldown = 2
                notify("Anti-void: Teleported to spawn!")
            end
        end)
    end)
    
    notify("Anti-void enabled")
end

local function antiVoidOff()
    antiVoidEnabled = false
    if antiVoidConn then
        antiVoidConn:Disconnect()
        antiVoidConn = nil
    end
    notify("Anti-void disabled")
end

