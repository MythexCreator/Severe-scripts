local function getFilteredCommands()
    local filtered = {}
    local query = searchQuery:lower()
    for _, cmd in ipairs(commands) do
        if query == "" or cmd.name:lower():find(query) or cmd.description:lower():find(query) then
            table.insert(filtered, cmd)
        end
    end
    return filtered
end

