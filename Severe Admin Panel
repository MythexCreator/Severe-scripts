local function headlessOn()
    if Features.headlessEnabled then return end
    
    pcall(function()
        local char = LocalPlayer.Character
        if not char then notify("No character") return end
        
        local head = char:FindFirstChild("Head")
        if not head then notify("No head found") return end
        
        OriginalParts.headTransparency = head.Transparency
        OriginalParts.headDecals = {}
        
        head.Transparency = 1
        pcall(function()
            memory.writef32(head, Offsets.Transparency, 1)
        end)
        
        for _, child in head:GetChildren() do
            if child:IsA("Decal") or child:IsA("Texture") then
                table_insert(OriginalParts.headDecals, {decal = child, transparency = child.Transparency})
                child.Transparency = 1
            end
        end
        
        local face = head:FindFirstChild("face") or head:FindFirstChildOfClass("Decal")
        if face then
            face.Transparency = 1
        end
        
        for _, acc in char:GetChildren() do
            if acc:IsA("Accessory") then
                local handle = acc:FindFirstChild("Handle")
                if handle then
                    local attachment = handle:FindFirstChildOfClass("Attachment")
                    if attachment then
                        local attachName = string_lower(attachment.Name)
                        if string_find(attachName, "hat") or string_find(attachName, "hair") or string_find(attachName, "face") or string_find(attachName, "head") then
                            handle.Transparency = 1
                        end
                    end
                end
            end
        end
        
        Features.headlessEnabled = true
        KeybindsGui.needsRedraw = true
        notify("Headless enabled")
    end)
end

local function headlessOff()
    if not Features.headlessEnabled then return end
    
    pcall(function()
        local char = LocalPlayer.Character
        if not char then return end
        
        local head = char:FindFirstChild("Head")
        if head then
            head.Transparency = OriginalParts.headTransparency or 0
            pcall(function()
                memory.writef32(head, Offsets.Transparency, OriginalParts.headTransparency or 0)
            end)
            
            for _, data in OriginalParts.headDecals do
                if data.decal and data.decal.Parent then
                    data.decal.Transparency = data.transparency or 0
                end
            end
            
            local face = head:FindFirstChild("face") or head:FindFirstChildOfClass("Decal")
            if face then
                face.Transparency = 0
            end
        end
        
        for _, acc in char:GetChildren() do
            if acc:IsA("Accessory") then
                local handle = acc:FindFirstChild("Handle")
                if handle then
                    handle.Transparency = 0
                end
            end
        end
    end)
    
    OriginalParts.headDecals = {}
    Features.headlessEnabled = false
    KeybindsGui.needsRedraw = true
    notify("Headless disabled")
end

