-- ============================================
-- ANIMATION SYSTEM
-- ============================================
local Animation = {
    tweens = {},
    EASE_OUT_QUAD = function(t) return 1 - (1 - t) * (1 - t) end,
    EASE_IN_OUT_QUAD = function(t) return t < 0.5 and 2 * t * t or 1 - (-2 * t + 2)^2 / 2 end,
    EASE_OUT_BACK = function(t) local c1, c3 = 1.70158, 2.70158 return 1 + c3 * (t - 1)^3 + c1 * (t - 1)^2 end,
    EASE_OUT_ELASTIC = function(t)
        if t == 0 or t == 1 then return t end
        return 2^(-10 * t) * math_sin((t * 10 - 0.75) * (2 * math.pi) / 3) + 1
    end,
}

local function animateTo(id, currentValue, targetValue, duration, easingFn, callback)
    Animation.tweens[id] = {
        startValue = currentValue,
        targetValue = targetValue,
        startTime = os_clock(),
        duration = duration,
        easingFn = easingFn or Animation.EASE_OUT_QUAD,
        callback = callback,
    }
end

local function getAnimatedValue(id, defaultValue)
    local tween = Animation.tweens[id]
    if not tween then return defaultValue end
    
    local elapsed = os_clock() - tween.startTime
    local progress = math_clamp(elapsed / tween.duration, 0, 1)
    local easedProgress = tween.easingFn(progress)
    
    local value
    if type(tween.startValue) == "number" then
        value = tween.startValue + (tween.targetValue - tween.startValue) * easedProgress
    elseif typeof(tween.startValue) == "Color3" then
        value = Color3.new(
            tween.startValue.R + (tween.targetValue.R - tween.startValue.R) * easedProgress,
            tween.startValue.G + (tween.targetValue.G - tween.startValue.G) * easedProgress,
            tween.startValue.B + (tween.targetValue.B - tween.startValue.B) * easedProgress
        )
    elseif typeof(tween.startValue) == "Vector2" then
        value = Vector2.new(
            tween.startValue.X + (tween.targetValue.X - tween.startValue.X) * easedProgress,
            tween.startValue.Y + (tween.targetValue.Y - tween.startValue.Y) * easedProgress
        )
    else
        value = progress >= 1 and tween.targetValue or tween.startValue
    end
    
    if progress >= 1 then
        if tween.callback then tween.callback() end
        Animation.tweens[id] = nil
    end
    
    return value
end

local function isAnimating(id)
    return Animation.tweens[id] ~= nil
end

local function cancelAnimation(id)
    Animation.tweens[id] = nil
end

