-- Admin Panel for Severe
-- Press ; to open command bar

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local LocalPlayer = Players.LocalPlayer

-- ============================================
-- NOCLIP SYSTEM
-- ============================================
local noclipEnabled = false
local noclipConnection = nil

local function enableNoclip()
    if noclipConnection then return end
    
    noclipConnection = RunService.Render:Connect(function()
        local character = LocalPlayer.Character
        if not character then return end
        
        for _, part in pairs(character:GetDescendants()) do
            if part:IsA("BasePart") and part.CanCollide then
                part.CanCollide = false
            end
        end
    end)
    
    noclipEnabled = true
end

local function disableNoclip()
    if noclipConnection then
        noclipConnection:Disconnect()
        noclipConnection = nil
    end
    
    local character = LocalPlayer.Character
    if character then
        for _, part in pairs(character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = true
            end
        end
    end
    
    noclipEnabled = false
end

-- ============================================
-- COMMAND SYSTEM
-- ============================================
local commands = {
    {
        name = "noclip",
        description = "Walk through walls",
        usage = ";noclip",
        category = "Movement",
        func = function(args)
            enableNoclip()
        end
    },
    {
        name = "unnoclip",
        description = "Disable noclip",
        usage = ";unnoclip",
        category = "Movement",
        func = function(args)
            disableNoclip()
        end
    },
    {
        name = "cmds",
        description = "Opens command panel",
        usage = ";cmds",
        category = "Utility",
        func = function(args)
            toggleGUI()
        end
    },
}

local function executeCommand(input)
    input = input:gsub(";", ""):gsub("^%s+", ""):gsub("%s+$", "")
    
    local parts = {}
    for part in input:gmatch("%S+") do
        table.insert(parts, part)
    end
    
    if #parts == 0 then return false end
    
    local cmdName = parts[1]:lower()
    table.remove(parts, 1)
    
    for _, command in ipairs(commands) do
        if command.name == cmdName then
            pcall(command.func, parts)
            return true
        end
    end
    return false
end

-- ============================================
-- GUI SYSTEM
-- ============================================
local guiOpen = false
local guiElements = {}
local searchQuery = ""
local scrollOffset = 0
local searchFocused = false
local isDraggingScrollbar = false

local searchBarPos = nil
local searchBarSize = nil
local scrollbarPos = nil
local scrollbarSize = nil

local function clearGUI()
    for _, element in ipairs(guiElements) do
        pcall(function()
            element:Remove()
        end)
    end
    guiElements = {}
end

local function getFilteredCommands()
    local filteredCommands = {}
    for _, cmd in ipairs(commands) do
        local query = searchQuery:lower()
        if query == "" or 
           cmd.name:lower():find(query) or 
           cmd.description:lower():find(query) or
           cmd.category:lower():find(query) then
            table.insert(filteredCommands, cmd)
        end
    end
    return filteredCommands
end

