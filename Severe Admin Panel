local function isKey(key, ...)
    local k = string_lower(key)
    for _, v in ipairs({...}) do
        if string_find(k, string_lower(v), 1, true) then return true end
    end
    return false
end

local function formatKeyName(key)
    if not key then return "NONE" end
    local k = string_lower(key)
    if k == "semicolon" or k == "oem_1" then return ";" end
    if k == "leftcontrol" then return "LCTRL" end
    if k == "rightcontrol" then return "RCTRL" end
    if k == "leftshift" then return "LSHIFT" end
    if k == "rightshift" then return "RSHIFT" end
    if k == "leftalt" then return "LALT" end
    if k == "rightalt" then return "RALT" end
    if k == "backquote" then return "`" end
    return string.upper(k)
end

local function formatSessionTime(seconds)
    local hours = math_floor(seconds / 3600)
    local minutes = math_floor((seconds % 3600) / 60)
    local secs = math_floor(seconds % 60)
    return string.format("%02d:%02d:%02d", hours, minutes, secs)
end

local function findPlayer(name)
    if not name or name == "" then return nil end
    local n = string_lower(name)
    for _, p in Players:GetChildren() do
        if string_lower(p.Name) == n or string_lower(p.DisplayName) == n then return p end
        if string_find(string_lower(p.Name), n, 1, true) == 1 or string_find(string_lower(p.DisplayName), n, 1, true) == 1 then return p end
    end
    return nil
end

local function getPlayerSuggestions(partial)
    local suggestions = {}
    if not partial or partial == "" then
        for _, p in Players:GetChildren() do
            if p ~= LocalPlayer then
                table_insert(suggestions, {name = p.Name, displayName = p.DisplayName})
                if #suggestions >= 5 then break end
            end
        end
    else
        local n = string_lower(partial)
        for _, p in Players:GetChildren() do
            if p ~= LocalPlayer then
                if string_find(string_lower(p.Name), n, 1, true) == 1 or string_find(string_lower(p.DisplayName), n, 1, true) == 1 then
                    table_insert(suggestions, {name = p.Name, displayName = p.DisplayName})
                    if #suggestions >= 5 then break end
                end
            end
        end
    end
    return suggestions
end

local function parseCommandForPlayerArg(input)
    local cleanInput = string_gsub(input, "^;", "")
    local parts = {}
    for p in string.gmatch(cleanInput, "%S+") do table_insert(parts, p) end
    if #parts == 0 then return nil, nil end
    local cmdName = string_lower(parts[1])
    local playerCommands = {tp = true, view = true, userid = true}
    if playerCommands[cmdName] then
        return cmdName, parts[2] or ""
    end
    return nil, nil
end

local function cacheSpawnLocation()
    pcall(function()
        local spawns = workspace:FindFirstChild("SpawnLocation") or workspace:FindFirstChildOfClass("SpawnLocation")
        if spawns then
            cachedSpawnLocation = spawns.Position + Vector3.new(0, 3, 0)
            return
        end
        for _, obj in workspace:GetDescendants() do
            if obj:IsA("SpawnLocation") then
                cachedSpawnLocation = obj.Position + Vector3.new(0, 3, 0)
                return
            end
        end
        cachedSpawnLocation = Vector3.new(0, 50, 0)
    end)
end

local function getSpawnLocation()
    if cachedSpawnLocation then return cachedSpawnLocation end
    cacheSpawnLocation()
    return cachedSpawnLocation or Vector3.new(0, 50, 0)
end

