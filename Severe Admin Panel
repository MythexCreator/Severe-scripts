local function updateCuteIntro()
    if not State.cuteIntroActive then return end
    if not State.cuteIntroStartTime then return end
    
    local elapsed = os_clock() - State.cuteIntroStartTime
    local elements = State.cuteIntroElements
    if #elements == 0 then State.cuteIntroActive = false return end
    
    local fadeIn = 0.4
    local hold = 2.0
    local fadeOut = 0.4
    local total = fadeIn + hold + fadeOut
    
    local opacity = 0
    if elapsed < fadeIn then
        opacity = elapsed / fadeIn
    elseif elapsed < fadeIn + hold then
        opacity = 1
    elseif elapsed < total then
        opacity = 1 - (elapsed - fadeIn - hold) / fadeOut
    else
        clearCuteIntro()
        State.cuteIntroActive = false
        if State.cuteTransitionCallback then
            State.cuteTransitionCallback()
            State.cuteTransitionCallback = nil
        end
        return
    end
    
    local bounce = math_sin(elapsed * 3) * 2
    local sparkleFloat = math_sin(elapsed * 4) * 5
    
    for i, el in ipairs(elements) do
        pcall(function()
            el.Opacity = opacity
            if i == 4 then
                el.Size = 40 + math_floor(bounce)
            elseif i == 5 then
                local cam = workspace.CurrentCamera
                if cam then
                    local cxL = math_floor(cam.ViewportSize.X / 2)
                    local cyL = math_floor(cam.ViewportSize.Y / 2)
                    el.Position = Vector2.new(cxL - 60, cyL - 50 + sparkleFloat)
                end
            elseif i == 6 then
                local cam = workspace.CurrentCamera
                if cam then
                    local cxL = math_floor(cam.ViewportSize.X / 2)
                    local cyL = math_floor(cam.ViewportSize.Y / 2)
                    el.Position = Vector2.new(cxL + 60, cyL - 50 - sparkleFloat)
                end
            end
        end)
    end
end

