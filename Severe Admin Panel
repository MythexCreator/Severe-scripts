local function getFilteredPanelCommands()
    local filtered = {}
    local query = string_lower(CommandPanel.searchQuery)
    for _, cmd in commandsForPanel do
        local matchesCategory = (CommandPanel.selectedCategory == "ALL" or cmd.cat == CommandPanel.selectedCategory)
        local matchesSearch = true
        
        if query ~= "" then
            local nameMatch = string_find(string_lower(cmd.name), query, 1, true)
            local descMatch = string_find(string_lower(cmd.desc), query, 1, true)
            local catMatch = string_find(string_lower(cmd.cat), query, 1, true)
            matchesSearch = nameMatch or descMatch or catMatch
        end
        
        if matchesCategory and matchesSearch then
            table_insert(filtered, cmd)
        end
    end
    return filtered
end

