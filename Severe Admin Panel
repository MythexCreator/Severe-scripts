local function initWorldPtr()
    if Gravity.worldPtr and Gravity.worldPtr ~= 0 then 
        if os_clock() - Gravity.lastCheck > 60 then
            Gravity.worldPtr = nil
        else
            return true
        end
    end
    
    local success, result = pcall(function() 
        return memory.readu64(workspace, Offsets.WorkspaceToWorld)
    end)
    
    if success and result and result ~= 0 then
        Gravity.worldPtr = result
        Gravity.lastCheck = os_clock()
        return true
    end
    
    Gravity.worldPtr = nil
    return false
end

local function setGravity(value)
    local num = tonumber(value)
    if not num then notify("Usage: ;gravity [number]") return end
    
    task.spawn(function()
        local attempts = 0
        local maxAttempts = 5
        
        while attempts < maxAttempts do
            if initWorldPtr() then
                local success = pcall(function() 
                    memory.writef32(Gravity.worldPtr, Offsets.Gravity, num) 
                end)
                if success then
                    notify("Gravity set to " .. num)
                    return
                end
            end
            attempts = attempts + 1
            if attempts < maxAttempts then
                Gravity.worldPtr = nil
                task.wait(0.1)
            end
        end
        
        pcall(function()
            workspace.Gravity = num
            notify("Gravity set to " .. num)
        end)
    end)
end

local function resetGravity()
    task.spawn(function()
        local success = false
        
        if initWorldPtr() then
            success = pcall(function() 
                memory.writef32(Gravity.worldPtr, Offsets.Gravity, Gravity.default) 
            end)
        end
        
        if not success then
            pcall(function()
                workspace.Gravity = Gravity.default
                success = true
            end)
        end
        
        if success then
            notify("Gravity reset to " .. Gravity.default)
        else
            notify("Failed to reset gravity")
        end
    end)
end

local function forceReset()
    local char = LocalPlayer.Character
    if not char then notify("No character") return end
    
    task.spawn(function()
        local success = false
        pcall(function()
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then 
                memory.writef32(hum, Offsets.Health, 0) 
                success = true 
            end
        end)
        if not success then
            pcall(function()
                local hum = char:FindFirstChildOfClass("Humanoid")
                if hum then
                    hum.Health = 0
                    success = true
                end
            end)
        end
        if not success then
            pcall(function()
                local root = char:FindFirstChild("HumanoidRootPart")
                if root then root.CFrame = CFrame.new(0, -500, 0) success = true end
            end)
        end
        if success then notify("Force reset!") else notify("Force reset failed") end
    end)
end

