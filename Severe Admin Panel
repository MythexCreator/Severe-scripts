-- ============================================
-- FOV
-- ============================================
local defaultFov = 70
local fovConn = nil
local currentFovValue = nil

local function setFov(value)
    local num = tonumber(value)
    if not num then 
        notify("Invalid FOV value") 
        return 
    end
    num = math.clamp(num, 1, 120)
    currentFovValue = num
    
    -- Kill old loop
    if fovConn then fovConn:Disconnect() fovConn = nil end
    
    -- Continuously write FOV so game can't reset it
    fovConn = RunService.Render:Connect(function()
        if not currentFovValue then return end
        pcall(function()
            local cam = workspace.CurrentCamera
            if cam then
                memory.writef32(cam, 0x160, currentFovValue)
            end
        end)
    end)
    
    notify("FOV set to " .. num)
end

local function resetFov()
    currentFovValue = nil
    
    if fovConn then
        fovConn:Disconnect()
        fovConn = nil
    end
    
    pcall(function()
        local cam = workspace.CurrentCamera
        if cam then
            memory.writef32(cam, 0x160, defaultFov)
        end
    end)
    
    notify("FOV reset to " .. defaultFov)
end

-- ============================================
-- ANTI AFK (IMPROVED WITH ANTI-DETECTION)
-- ============================================
local antiAfkEnabled = false
local antiAfkThread = nil

local ANTI_AFK_MIN_INTERVAL = 45
local ANTI_AFK_MAX_INTERVAL = 90

local antiAfkActions = {
    { name = "Jump", weight = 30, fn = function()
        keypress(0x20) task.wait(0.05 + math.random() * 0.15) keyrelease(0x20)
    end },
    { name = "Forward", weight = 25, fn = function()
        keypress(0x57) task.wait(0.1 + math.random() * 0.3) keyrelease(0x57)
    end },
    { name = "Backward", weight = 15, fn = function()
        keypress(0x53) task.wait(0.1 + math.random() * 0.2) keyrelease(0x53)
    end },
    { name = "Left", weight = 10, fn = function()
        keypress(0x41) task.wait(0.08 + math.random() * 0.15) keyrelease(0x41)
    end },
    { name = "Right", weight = 10, fn = function()
        keypress(0x44) task.wait(0.08 + math.random() * 0.15) keyrelease(0x44)
    end },
    { name = "Look", weight = 20, fn = function()
        local dx = math.random(-80, 80)
        local dy = math.random(-40, 40)
        for i = 1, math.random(3, 6) do
            mousemoverel(dx / 5, dy / 5)
            task.wait(0.02 + math.random() * 0.03)
        end
    end },
}

local function selectRandomAction()
    local total = 0
    for _, a in ipairs(antiAfkActions) do total = total + a.weight end
    local r = math.random() * total
    local c = 0
    for _, a in ipairs(antiAfkActions) do
        c = c + a.weight
        if r <= c then return a end
    end
    return antiAfkActions[1]
end

local function antiAfkLoop()
    while antiAfkEnabled do
        local interval = math.random(ANTI_AFK_MIN_INTERVAL, ANTI_AFK_MAX_INTERVAL)
        interval = interval + (math.random() - 0.5) * interval * 0.2
        task.wait(interval)
        if not antiAfkEnabled then break end
        pcall(function() selectRandomAction().fn() end)
        task.wait(0.1 + math.random() * 0.3)
    end
end

local function antiAfkOn()
    if antiAfkEnabled then return end
    antiAfkEnabled = true
    antiAfkThread = task.spawn(antiAfkLoop)
    notify("Anti-AFK enabled")
end

local function antiAfkOff()
    antiAfkEnabled = false
    antiAfkThread = nil
    notify("Anti-AFK disabled")
end

