    mainFrame.Color = Color3.fromRGB(25, 25, 25)
    mainFrame.Filled = true
    mainFrame.Opacity = 0.95
    mainFrame.Rounding = 10
    table.insert(guiElements, mainFrame)
    
    local title = Drawing.new("Text")
    title.Visible = true
    title.Text = "Command Panel"
    title.Size = 24
    title.Position = mainFrame.Position + Vector2.new(20, 15)
    title.Color = Color3.fromRGB(100, 200, 255)
    title.Outline = true
    title.Center = false
    table.insert(guiElements, title)
    
    local searchBg = Drawing.new("Square")
    searchBg.Visible = true
    searchBg.Size = Vector2.new(660, 35)
    searchBg.Position = mainFrame.Position + Vector2.new(20, 55)
    searchBg.Color = searchFocused and Color3.fromRGB(50, 50, 50) or Color3.fromRGB(35, 35, 35)
    searchBg.Filled = true
    searchBg.Rounding = 6
    table.insert(guiElements, searchBg)
    searchBarPos = searchBg.Position
    searchBarSize = searchBg.Size
    
    if searchFocused then
        local searchBorder = Drawing.new("Square")
        searchBorder.Visible = true
        searchBorder.Size = Vector2.new(660, 35)
        searchBorder.Position = mainFrame.Position + Vector2.new(20, 55)
        searchBorder.Color = Color3.fromRGB(100, 200, 255)
        searchBorder.Filled = false
        searchBorder.Rounding = 6
        searchBorder.Thickness = 2
        table.insert(guiElements, searchBorder)
    end
    
    local displayText = ""
    if searchQuery ~= "" then
        displayText = searchQuery
    elseif searchFocused then
        displayText = "|"
    else
        displayText = "Click to search..."
    end
    
    local searchText = Drawing.new("Text")
    searchText.Visible = true
    searchText.Text = displayText
    searchText.Size = 18
    searchText.Position = searchBg.Position + Vector2.new(15, 10)
    searchText.Color = (searchQuery ~= "" or searchFocused) and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(150, 150, 150)
    searchText.Outline = true
    searchText.Center = false
    table.insert(guiElements, searchText)
    
    local filteredCommands = getFilteredCommands()
    
    local scrollbarBg = Drawing.new("Square")
    scrollbarBg.Visible = true
    scrollbarBg.Size = Vector2.new(12, 380)
    scrollbarBg.Position = mainFrame.Position + Vector2.new(675, 105)
    scrollbarBg.Color = Color3.fromRGB(35, 35, 35)
    scrollbarBg.Filled = true
    scrollbarBg.Rounding = 6
    table.insert(guiElements, scrollbarBg)
    scrollbarPos = scrollbarBg.Position
    scrollbarSize = scrollbarBg.Size
    
    local maxCommands = 6
    local totalCommands = #filteredCommands
    
    if totalCommands > maxCommands then
        local handleHeight = math.max(40, (maxCommands / totalCommands) * 380)
        local maxScroll = totalCommands - maxCommands
        local handleY = (scrollOffset / maxScroll) * (380 - handleHeight)
        
        local scrollHandle = Drawing.new("Square")
        scrollHandle.Visible = true
        scrollHandle.Size = Vector2.new(12, handleHeight)
        scrollHandle.Position = scrollbarBg.Position + Vector2.new(0, handleY)
        scrollHandle.Color = isDraggingScrollbar and Color3.fromRGB(150, 220, 255) or Color3.fromRGB(100, 200, 255)
        scrollHandle.Filled = true
        scrollHandle.Rounding = 6
        table.insert(guiElements, scrollHandle)
    end
    
    local yOffset = 105
    local startIndex = scrollOffset + 1
    local endIndex = math.min(startIndex + maxCommands - 1, #filteredCommands)
    
    for i = startIndex, endIndex do
        local cmd = filteredCommands[i]
        
