local function updateIntro()
    if State.introComplete then return end
    if not State.introStartTime then return end
    if #State.introElements == 0 then State.introComplete = true return end
    
    local elapsed = os_clock() - State.introStartTime
    local elements = State.introElements
    
    local fadeInDuration = 0.6
    local holdDuration = 1.8
    local fadeOutDuration = 0.5
    local totalDuration = fadeInDuration + holdDuration + fadeOutDuration
    
    local newOpacity = 0
    local ringOffset = elapsed * 1.5
    
    if elapsed < fadeInDuration then
        local progress = elapsed / fadeInDuration
        newOpacity = 1 - math.pow(1 - progress, 3)
    elseif elapsed < fadeInDuration + holdDuration then
        newOpacity = 1
    elseif elapsed < totalDuration then
        local progress = (elapsed - fadeInDuration - holdDuration) / fadeOutDuration
        newOpacity = 1 - math.pow(progress, 2)
    else
        for i = #elements, 1, -1 do
            local el = elements[i]
            pcall(function() 
                el.Visible = false 
                el:Remove() 
            end)
            elements[i] = nil
        end
        State.introElements = {}
        State.introComplete = true
        State.sessionStartTime = os_clock()
        notify("Severe Admin loaded! Press " .. formatKeyName(Settings.commandBarKey))
        return
    end
    
    for i, el in ipairs(elements) do
        pcall(function() 
            el.Opacity = newOpacity
            
            if i == 4 then
                el.Radius = 42 + math_sin(ringOffset * 2) * 2
            elseif i == 5 then
                el.Radius = 32 + math_sin(ringOffset * 2.5 + 1) * 1.5
            elseif i == 6 then
                el.Radius = 22 + math_sin(ringOffset * 3 + 2) * 1
            end
        end)
    end
end

