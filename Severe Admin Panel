-- ============================================
-- FIND PLAYER
-- ============================================
local function findPlayer(name)
    if not name or name == "" then return nil end
    name = name:lower()
    
    for _, p in ipairs(Players:GetChildren()) do
        if p:IsA("Player") and p.Name:lower() == name then return p end
    end
    for _, p in ipairs(Players:GetChildren()) do
        if p:IsA("Player") and p.DisplayName:lower() == name then return p end
    end
    for _, p in ipairs(Players:GetChildren()) do
        if p:IsA("Player") and p.Name:lower():sub(1, #name) == name then return p end
    end
    for _, p in ipairs(Players:GetChildren()) do
        if p:IsA("Player") and p.DisplayName:lower():sub(1, #name) == name then return p end
    end
    for _, p in ipairs(Players:GetChildren()) do
        if p:IsA("Player") and p.Name:lower():find(name, 1, true) then return p end
    end
    for _, p in ipairs(Players:GetChildren()) do
        if p:IsA("Player") and p.DisplayName:lower():find(name, 1, true) then return p end
    end
    
    return nil
end

